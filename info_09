@DataJpaTest
@AutoConfigureTestDatabase(replace = AutoConfigureTestDatabase.Replace.NONE)
class BehaviorPatternMasterRepositoryTest extends RepositoryJpaTestSupport {

    @Autowired
    private BehaviorPatternMasterRepository behaviorPatternMasterRepository;

    @Autowired
    private BehaviorPatternsRepository behaviorPatternsRepository;

    @Test
    void testUpdateBehaviorPattern() {
        UiUserBase createdBy = persistUser("WA40122433", "Will", "Author");
        UiUserBase updatedBy = persistUser("OLDUSER1", "Olive", "Updater");
        persistUser("PP3188253", "Pat", "Updater");
        PrmMbMasterT originalMaster = persistMbMaster(295, "Original Element");
        persistMbMaster(251, "Updated Element");
        var extractRule = persistExtractRule(551);
        persistLuValue("BA_ID", "2", "BA 2", "Behavior View", 1);
        persistBehaviorPattern(585, "Original Pattern", "2", createdBy, updatedBy, originalMaster, extractRule, 4000);
        flushAndClear();

        LocalDateTime currentDate = LocalDateTime.now();
        int updateResult = behaviorPatternMasterRepository.updateBehaviorPattern(
                "Dental, Rend, SSCrowns Age 0-6, #clms - current",
                "4",
                251,
                4001,
                "PP3188253",
                currentDate,
                585);
        flushAndClear();

        assertEquals(1, updateResult);
        PrmBpBehaviorPatsT updated = behaviorPatternsRepository.getBehaviorPatternById(585);
        assertEquals("4", updated.getBaId());
        assertEquals(4001, updated.getBpMaxCtecFieldId());
        assertEquals("PP3188253", updated.getUiUserBaseUpd().getUiSystemId());
        assertEquals(251, updated.getPrmMbMasterT().getMbCtecFid());
    }

    @Test
    void testNewBehaviorPattern() {
        UiUserBase createdBy = persistUser("WA40122434", "Jane", "Creator");
        UiUserBase updatedBy = persistUser("CS39286887", "John", "Modifier");
        PrmMbMasterT prmMbMasterT = persistMbMaster(251, "Dental Element");
        var extractRule = persistExtractRule(700);

        PrmBpBehaviorPatsT prmBpBehaviorPatsT = new PrmBpBehaviorPatsT();
        prmBpBehaviorPatsT.setBpId(999);
        prmBpBehaviorPatsT.setBehaviorPatternName("Dental, basic, treat; max daily #drecips");
        prmBpBehaviorPatsT.setBaId("2");
        prmBpBehaviorPatsT.setBpMaxCtecFieldId(4000);
        prmBpBehaviorPatsT.setCreateDate(LocalDateTime.now());
        prmBpBehaviorPatsT.setUpdateDate(LocalDateTime.now());
        prmBpBehaviorPatsT.setUiUserBaseCr(createdBy);
        prmBpBehaviorPatsT.setUiUserBaseUpd(updatedBy);
        prmBpBehaviorPatsT.setPrmMbMasterT(prmMbMasterT);
        prmBpBehaviorPatsT.setPrmErExtractRuleT(extractRule);

        PrmBpBehaviorPatsT saved = behaviorPatternMasterRepository.save(prmBpBehaviorPatsT);

        assertEquals(prmBpBehaviorPatsT.getBehaviorPatternName(), saved.getBehaviorPatternName());
        assertEquals(prmBpBehaviorPatsT.getBpMaxCtecFieldId(), saved.getBpMaxCtecFieldId());
        assertEquals(prmBpBehaviorPatsT.getBpId(), saved.getBpId());
    }
