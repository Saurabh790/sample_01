package com.optum.fads.pgp.datarules;

import static org.junit.jupiter.api.Assertions.assertEquals;
import static org.junit.jupiter.api.Assertions.assertNotNull;
import static org.junit.jupiter.api.Assertions.assertNull;

import java.time.LocalDateTime;

import org.junit.jupiter.api.BeforeEach;
import org.junit.jupiter.api.Test;
import org.springframework.beans.factory.annotation.Autowired;

import com.optum.fads.pgp.datarules.repo.DataRuleMasterRepository;

class DataRulesMasterRepositoryTests extends RepositoryJpaTestSupport {

    private static final int EXISTING_RULE_ID = 4001;

    @Autowired
    private DataRuleMasterRepository repository;

    @BeforeEach
    void setUp() {
        var creator = persistUser("creator", "Test", "Creator");
        var updater = persistUser("updater", "Test", "Updater");
        var operator = persistOperator("EQ", "Equals");
        var mbMaster = persistMbMaster(701, 1, 1, "Age");
        persistDataRule(EXISTING_RULE_ID, "existing rule", creator, updater, operator, mbMaster);
        flushAndClear();
    }

    @Test
    void testNewDataRule() {
        var creator = entityManager.find(com.optum.fads.pgp.datarules.domain.UiUserBase.class, "creator");
        var updater = entityManager.find(com.optum.fads.pgp.datarules.domain.UiUserBase.class, "updater");
        var operator = entityManager.find(com.optum.fads.pgp.datarules.domain.PrmDrLuOperatorT.class, "EQ");
        var mbMaster = entityManager.find(com.optum.fads.pgp.datarules.domain.PrmMbMasterT.class, 701);

        persistDataRule(4002, "new rule", creator, updater, operator, mbMaster);
        flushAndClear();

        assertNotNull(repository.retrieveDataRuleById(4002));
        assertEquals(4003, repository.retrieveNextDrId());
    }

    @Test
    void testGetDataRule() {
        var result = repository.retrieveDataRule(EXISTING_RULE_ID, "creator");

        assertNotNull(result);
        assertEquals("existing rule", result.getDataRuleName());
    }

    @Test
    void testDeleteDataRule() {
        int deleted = repository.deleteDatarule(EXISTING_RULE_ID);
        flushAndClear();

        assertEquals(1, deleted);
        assertNull(repository.retrieveDataRuleById(EXISTING_RULE_ID));
    }

    @Test
    void testUpdateDataRule() {
        persistUser("newupdater", "New", "Updater");
        persistOperator("BT", "Between");
        persistMbMaster(702, 2, 1, "Updated Field");
        flushAndClear();

        int updated = repository.updateDataRuleDb(
                "updated rule",
                702,
                "BT",
                "newupdater",
                LocalDateTime.of(2026, 3, 26, 11, 0),
                EXISTING_RULE_ID);
        flushAndClear();

        var result = repository.retrieveDataRuleById(EXISTING_RULE_ID);
        assertEquals(1, updated);
        assertEquals("updated rule", result.getDataRuleName());
        assertEquals(702, result.getPrmMbMasterT().getMbCtecFid());
        assertEquals("BT", result.getPrmDrLuOperatorT().getOperatorCd());
        assertEquals("newupdater", result.getUiUserBaseUpd().getUiSystemId());
    }
}
package com.optum.fads.pgp.datarules;

import static org.junit.jupiter.api.Assertions.assertEquals;
