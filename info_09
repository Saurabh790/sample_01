import com.optum.fads.pgp.behavior.api.domain.PrmBpBehaviorPatsT;
import com.optum.fads.pgp.behavior.api.domain.PrmDrDataRuleT;
import com.optum.fads.pgp.behavior.api.domain.PrmDrLuOperatorT;
import com.optum.fads.pgp.behavior.api.domain.PrmErDrT;
import com.optum.fads.pgp.behavior.api.domain.PrmErExtractRuleT;
import com.optum.fads.pgp.behavior.api.domain.PrmErdrTPK;
import com.optum.fads.pgp.behavior.api.domain.PrmMbMasterT;
import com.optum.fads.pgp.behavior.api.domain.UiUserBase;

abstract class RepositoryJpaTestSupport {

    @Autowired
    protected TestEntityManager entityManager;

    protected UiUserBase persistUser(String systemId, String firstName, String lastName) {
        UiUserBase user = new UiUserBase();
        user.setUiSystemId(systemId);
        user.setUiUserId(systemId);
        user.setUiFirstName(firstName);
        user.setUiLastName(lastName);
        user.setUiEMailAddress(systemId + "@example.com");
        entityManager.persist(user);
        return user;
    }

    protected PrmMbMasterT persistMbMaster(int id, String description) {
        PrmMbMasterT master = new PrmMbMasterT();
        master.setMbCtecFid(id);
        master.setDrElementClass(1);
        master.setMbCustFlag(1);
        master.setMbCustDatadesc(description);
        master.setMbCtecFtype("STRING");
        master.setMbLuFlag(1);
        master.setMbLuSql("select 1");
        master.setMbBpFlag(0);
        master.setMbBpType("GEN");
        entityManager.persist(master);
        return master;
    }

    protected FadsLuValuesT persistLuValue(String fieldId, String luValue, String label, String view, int sequence) {
        FadsLuValuesTPK id = new FadsLuValuesTPK();
        id.setFieldId(fieldId);
        id.setLuValue(luValue);

        FadsLuValuesT value = new FadsLuValuesT();
        value.setId(id);
        value.setLuCode(luValue);
        value.setLuLabel(label);
        value.setLuParent("ROOT");
        value.setLuSeq(sequence);
        value.setLuView(view);
        value.setObjId(sequence);
        entityManager.persist(value);
        return value;
    }

    protected PrmErExtractRuleT persistExtractRule(int erId) {
        PrmErExtractRuleT extractRule = new PrmErExtractRuleT();
        extractRule.setErId(erId);
        extractRule.setErName("ER-" + erId);
        extractRule.setCreateUsr("test");
        extractRule.setUpdateUsr("test");
        extractRule.setCreateDte(new Date());
        extractRule.setUpdateDte(new Date());
        entityManager.persist(extractRule);
        return extractRule;
    }

    protected PrmDrLuOperatorT persistOperator(String operatorCode, String description) {
        PrmDrLuOperatorT operator = new PrmDrLuOperatorT();
        operator.setOperatorCd(operatorCode);
        operator.setOperatorDesc(description);
        entityManager.persist(operator);
        return operator;
    }

    protected PrmDrDataRuleT persistDataRule(
            int id,
            String name,
            UiUserBase createdBy,
            UiUserBase updatedBy,
            PrmDrLuOperatorT operator,
            PrmMbMasterT mbMaster) {
        PrmDrDataRuleT dataRule = new PrmDrDataRuleT();
        dataRule.setDrId(id);
        dataRule.setDataRuleName(name);
        dataRule.setCreateDate(new Date());
        dataRule.setUpdateDate(new Date());
        dataRule.setUiUserBaseCr(createdBy);
        dataRule.setUiUserBaseUpd(updatedBy);
        dataRule.setPrmDrLuOperatorT(operator);
        dataRule.setPrmMbMasterT(mbMaster);
        entityManager.persist(dataRule);
        return dataRule;
    }

    protected PrmBpBehaviorPatsT persistBehaviorPattern(
            int id,
            String name,
            String baId,
            UiUserBase createdBy,
            UiUserBase updatedBy,
            PrmMbMasterT mbMaster,
            PrmErExtractRuleT extractRule,
            Integer dateElementCode) {
        PrmBpBehaviorPatsT pattern = new PrmBpBehaviorPatsT();
        pattern.setBpId(id);
        pattern.setBehaviorPatternName(name);
        pattern.setBaId(baId);
        pattern.setUiUserBaseCr(createdBy);
        pattern.setUiUserBaseUpd(updatedBy);
        pattern.setPrmMbMasterT(mbMaster);
        pattern.setPrmErExtractRuleT(extractRule);
        pattern.setBpMaxCtecFieldId(dateElementCode);
        pattern.setCreateDate(LocalDateTime.of(2026, 3, 27, 10, 0));
        pattern.setUpdateDate(LocalDateTime.of(2026, 3, 27, 10, 5));
        entityManager.persist(pattern);
        return pattern;
    }

    protected PrmErDrT persistErDr(int erId, int drId) {
        PrmErDrT erDr = new PrmErDrT();
        PrmErdrTPK id = new PrmErdrTPK();
        id.setErId(erId);
        id.setDrId(drId);
        erDr.setId(id);
        entityManager.persist(erDr);
        return erDr;
    }

    protected void flushAndClear() {
        entityManager.flush();
        entityManager.clear();
    }
}
