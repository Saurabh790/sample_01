@RunWith(SpringRunner.class)
@DataJpaTest
public class BehaviorPatternMasterRepositoryTest {
	
	@Autowired
	private BehaviorPatternMasterRepository behaviorPatternMasterRepository;
	@Autowired
	private BehaviorPatternsRepository behaviorPatternsRepository; 
	
	    @Test
	    public void testUpdateBehaviorPattern() {
	    	Integer behaviorPatternId = 585;
	    	String behaviorPatternName ="Dental, Rend, SSCrowns Age 0-6, #clms - current";
	    	LocalDateTime currentDate = LocalDateTime.now();
	    	String bAId = "4"; 	// current = 2
	    	Integer dataElementCode = 251; // current = 295
	    	Integer dateElementCode = 4001; // current = 4000
	    	String userId = "PP3188253"; // current = "WA40122433"
	    	
	    	int updateResult = behaviorPatternMasterRepository.updateBehaviorPattern(behaviorPatternName, bAId,
	    			dataElementCode, dateElementCode, userId, currentDate, behaviorPatternId); 
	    	assertEquals(1, updateResult);  
	    	PrmBpBehaviorPatsT prmBpBehaviorPatsT = behaviorPatternsRepository.getBehaviorPatternById(behaviorPatternId);
	    	assertEquals(bAId, prmBpBehaviorPatsT.getBaId());
	    	assertEquals(dateElementCode, prmBpBehaviorPatsT.getBpMaxCtecFieldId());
	    	assertEquals(userId, prmBpBehaviorPatsT.getUiUserBaseUpd().getUiSystemId());
	    	assertEquals(dataElementCode, prmBpBehaviorPatsT.getPrmMbMasterT().getMbCtecFid());
	    }  
	   
	    @Test
	    public void testNewBehaviorPattern() {
	    	Integer behaviorPatternId = 999;		// 1876 in FADS DEV DB
	    	LocalDateTime currentDate = LocalDateTime.now();
				
	    	PrmBpBehaviorPatsT prmBpBehaviorPatsT = new PrmBpBehaviorPatsT();
			UiUserBase uiUserBase = new UiUserBase();	
			prmBpBehaviorPatsT.setUiUserBaseCr(uiUserBase);				// Set UiUserBase
			prmBpBehaviorPatsT.getUiUserBaseCr().setUiSystemId("WA40122433");
			prmBpBehaviorPatsT.setUiUserBaseUpd(uiUserBase);
			prmBpBehaviorPatsT.getUiUserBaseUpd().setUiSystemId("CS39286887");
			
			PrmMbMasterT prmMbMasterT = new PrmMbMasterT();
			prmBpBehaviorPatsT.setPrmMbMasterT(prmMbMasterT);			// Set PrmMbMasterT
										
			prmBpBehaviorPatsT.setBehaviorPatternName("Dental, basic, treat; max daily #drecips");
			prmBpBehaviorPatsT.getPrmMbMasterT().setMbCtecFid(251);
			
			prmBpBehaviorPatsT.setBpId(behaviorPatternId);
			prmBpBehaviorPatsT.setBaId("2");
			prmBpBehaviorPatsT.setBpMaxCtecFieldId(4000);
			prmBpBehaviorPatsT.setCreateDate(currentDate);
			prmBpBehaviorPatsT.setUpdateDate(currentDate);
			PrmBpBehaviorPatsT prmBpBehaviorPatsT1 =  behaviorPatternMasterRepository.save(prmBpBehaviorPatsT); 
	    	// The save() method returns the saved entity, including the updated id field
	    	assertEquals(prmBpBehaviorPatsT1.getBehaviorPatternName(), prmBpBehaviorPatsT.getBehaviorPatternName());
	    	assertEquals(prmBpBehaviorPatsT1.getBpMaxCtecFieldId(), prmBpBehaviorPatsT.getBpMaxCtecFieldId());
	    	assertEquals(prmBpBehaviorPatsT1.getBpId(), prmBpBehaviorPatsT.getBpId());
	    } 
	    
}

