package com.optum.fads.pgp.datarules;

import static org.junit.jupiter.api.Assertions.assertEquals;

import java.util.List;

import org.junit.jupiter.api.BeforeEach;
import org.junit.jupiter.api.Test;
import org.springframework.beans.factory.annotation.Autowired;

import com.optum.fads.pgp.datarules.domain.FadsLuValuesT;
import com.optum.fads.pgp.datarules.repo.DataRuleMBRepository;

class DataRuleMBRepositoryTests extends RepositoryJpaTestSupport {

    @Autowired
    private DataRuleMBRepository repository;

    @BeforeEach
    void setUp() {
        persistLuValue("DR_ELEMENT_CLASS", "1", "Claims", "1", 1);
        persistLuValue("DR_ELEMENT_CLASS", "2", "Pharmacy", "0", 2);
        persistMbMaster(101, 1, 1, "Member Age");
        persistMbMaster(102, 2, 1, "Drug Code");
        flushAndClear();
    }

    @Test
    void testGetDataElemntByDeId() {
        List<Object[]> result = repository.retrieveDataElementById(101);

        assertEquals(1, result.size());
        assertEquals(101, ((Number) result.get(0)[0]).intValue());
        assertEquals("Member Age", result.get(0)[1]);
        assertEquals("Claims", result.get(0)[5]);
    }

    @Test
    void testGetDataDataSourceElements() {
        List<FadsLuValuesT> result = repository.retrieveDataSourceElements();

        assertEquals(1, result.size());
        assertEquals("Claims", result.get(0).getLuLabel());
    }

    @Test
    void testGetValidValuesByLvId() {
        List<FadsLuValuesT> result = repository.retrieveLuValuesById("DR_ELEMENT_CLASS");

        assertEquals(2, result.size());
        assertEquals("1", result.get(0).getId().getLuValue());
        assertEquals("2", result.get(1).getId().getLuValue());
    }
}
