package com.optum.fads.pgp.behavior.api.repository;

import static org.junit.Assert.assertEquals;

import java.time.LocalDateTime;

import org.junit.Test;
import org.junit.runner.RunWith;
import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.boot.data.jpa.test.autoconfigure.DataJpaTest;
import org.springframework.test.context.junit4.SpringRunner;

import com.optum.fads.pgp.behavior.api.domain.PrmBpBehaviorPatsT;
import com.optum.fads.pgp.behavior.api.domain.PrmMbMasterT;
import com.optum.fads.pgp.behavior.api.domain.UiUserBase;
import com.optum.fads.pgp.behavior.api.repo.BehaviorPatternMasterRepository;
import com.optum.fads.pgp.behavior.api.repo.BehaviorPatternsRepository;

@RunWith(SpringRunner.class)
@DataJpaTest
public class BehaviorPatternMasterRepositoryTest {
	
	@Autowired
	private BehaviorPatternMasterRepository behaviorPatternMasterRepository;
	@Autowired
	private BehaviorPatternsRepository behaviorPatternsRepository; 
	
	    @Test
	    public void testUpdateBehaviorPattern() {
	    	Integer behaviorPatternId = 585;
	    	String behaviorPatternName ="Dental, Rend, SSCrowns Age 0-6, #clms - current";
	    	LocalDateTime currentDate = LocalDateTime.now();
	    	String bAId = "4"; 	// current = 2
	    	Integer dataElementCode = 251; // current = 295
	    	Integer dateElementCode = 4001; // current = 4000
	    	String userId = "PP3188253"; // current = "WA40122433"
	    	
	    	int updateResult = behaviorPatternMasterRepository.updateBehaviorPattern(behaviorPatternName, bAId,
	    			dataElementCode, dateElementCode, userId, currentDate, behaviorPatternId); 
	    	assertEquals(1, updateResult);  
	    	PrmBpBehaviorPatsT prmBpBehaviorPatsT = behaviorPatternsRepository.getBehaviorPatternById(behaviorPatternId);
	    	assertEquals(bAId, prmBpBehaviorPatsT.getBaId());
	    	assertEquals(dateElementCode, prmBpBehaviorPatsT.getBpMaxCtecFieldId());
	    	assertEquals(userId, prmBpBehaviorPatsT.getUiUserBaseUpd().getUiSystemId());
	    	assertEquals(dataElementCode, prmBpBehaviorPatsT.getPrmMbMasterT().getMbCtecFid());
	    }  
	   
	    @Test
	    public void testNewBehaviorPattern() {
	    	Integer behaviorPatternId = 999;		// 1876 in FADS DEV DB
	    	LocalDateTime currentDate = LocalDateTime.now();
				
	    	PrmBpBehaviorPatsT prmBpBehaviorPatsT = new PrmBpBehaviorPatsT();
			UiUserBase uiUserBase = new UiUserBase();	
			prmBpBehaviorPatsT.setUiUserBaseCr(uiUserBase);				// Set UiUserBase
			prmBpBehaviorPatsT.getUiUserBaseCr().setUiSystemId("WA40122433");
			prmBpBehaviorPatsT.setUiUserBaseUpd(uiUserBase);
			prmBpBehaviorPatsT.getUiUserBaseUpd().setUiSystemId("CS39286887");
			
			PrmMbMasterT prmMbMasterT = new PrmMbMasterT();
			prmBpBehaviorPatsT.setPrmMbMasterT(prmMbMasterT);			// Set PrmMbMasterT
										
			prmBpBehaviorPatsT.setBehaviorPatternName("Dental, basic, treat; max daily #drecips");
			prmBpBehaviorPatsT.getPrmMbMasterT().setMbCtecFid(251);
			
			prmBpBehaviorPatsT.setBpId(behaviorPatternId);
			prmBpBehaviorPatsT.setBaId("2");
			prmBpBehaviorPatsT.setBpMaxCtecFieldId(4000);
			prmBpBehaviorPatsT.setCreateDate(currentDate);
			prmBpBehaviorPatsT.setUpdateDate(currentDate);
			PrmBpBehaviorPatsT prmBpBehaviorPatsT1 =  behaviorPatternMasterRepository.save(prmBpBehaviorPatsT); 
	    	// The save() method returns the saved entity, including the updated id field
	    	assertEquals(prmBpBehaviorPatsT1.getBehaviorPatternName(), prmBpBehaviorPatsT.getBehaviorPatternName());
	    	assertEquals(prmBpBehaviorPatsT1.getBpMaxCtecFieldId(), prmBpBehaviorPatsT.getBpMaxCtecFieldId());
	    	assertEquals(prmBpBehaviorPatsT1.getBpId(), prmBpBehaviorPatsT.getBpId());
	    } 
	    
}


package com.optum.fads.pgp.behavior.api.repository;

import static org.junit.Assert.assertEquals;
import static org.junit.Assert.assertNotNull;
import static org.junit.Assert.assertTrue;

import java.text.ParseException;
import java.util.List;

import org.junit.Test;
import org.junit.runner.RunWith;
import org.slf4j.Logger;
import org.slf4j.LoggerFactory;
import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.boot.data.jpa.test.autoconfigure.DataJpaTest;
import org.springframework.data.domain.PageRequest;
import org.springframework.data.domain.Pageable;
import org.springframework.data.domain.Sort;
import org.springframework.test.context.junit4.SpringRunner;

import com.optum.fads.pgp.behavior.api.domain.PrmBpBehaviorPatsT;
import com.optum.fads.pgp.behavior.api.repo.BehaviorPatternMasterRepository;
import com.optum.fads.pgp.behavior.api.repo.BehaviorPatternsRepository;


@RunWith(SpringRunner.class) 
@DataJpaTest 
public class BehaviorPatternsRepositoryTest {
	@Autowired 
	private BehaviorPatternsRepository behaviorPatternsRepository; 
	@Autowired
	BehaviorPatternMasterRepository behaviorPatternMasterRepository;
 
	private static final Logger logit = LoggerFactory
			.getLogger(BehaviorPatternsRepositoryTest.class);
	
	@Test 
	public void testGetBehaviorPatternsBySearchCrit() throws ParseException{ 
		
		Pageable pageable = null;
		List<PrmBpBehaviorPatsT> prmBpBehaviorPatsList = behaviorPatternsRepository.getBehaviorPatterns(pageable);
		logit.info(" Behavior Patterns list #1 size = {}",prmBpBehaviorPatsList.size());
		for (PrmBpBehaviorPatsT prmBpBehaviorPatsT: prmBpBehaviorPatsList) {
			logit.info(" Behavior Pattern ID {} Name = {}", prmBpBehaviorPatsT.getBpId(), prmBpBehaviorPatsT.getBehaviorPatternName());
		}
		assertTrue(prmBpBehaviorPatsList.size() > 0);
		pageable = PageRequest.of(0, 5, Sort.by(Sort.Direction.DESC, "createDate"));
		prmBpBehaviorPatsList = behaviorPatternsRepository.getBehaviorPatternsBySearchCrit("%dental%", 
				"%","%", pageable );
		logit.info(" Behavior Patterns list #2 size = {}",prmBpBehaviorPatsList.size());
		for (PrmBpBehaviorPatsT prmBpBehaviorPatsT: prmBpBehaviorPatsList) {
			logit.info(" Behavior Pattern ID {} Name = {}", prmBpBehaviorPatsT.getBpId(), prmBpBehaviorPatsT.getBehaviorPatternName());
		}
		assertTrue(prmBpBehaviorPatsList.size() > 0);
	} 
	
	@Test 
	public void testGetBehaviorPatternsBySearchCritEsc() throws ParseException{ 
		
		Pageable pageable = null;
		pageable = PageRequest.of(0, 5, Sort.by(Sort.Direction.DESC, "createDate"));
		List<PrmBpBehaviorPatsT> prmBpBehaviorPatsList = behaviorPatternsRepository.getBehaviorPatternsBySearchCritEsc("% 80\\%%", 
				"%","%", pageable );
		logit.info(" Behavior Patterns list #2 size = {}",prmBpBehaviorPatsList.size());
		for (PrmBpBehaviorPatsT prmBpBehaviorPatsT: prmBpBehaviorPatsList) {
			logit.info(" Behavior Pattern ID {} Name = {}", prmBpBehaviorPatsT.getBpId(), prmBpBehaviorPatsT.getBehaviorPatternName());
		}
		assertTrue(prmBpBehaviorPatsList.size() > 0);
	} 
	
	@Test
    public void testGetBehaviorPatternById(){
    	Integer behaviorPatternId = 585;
    	Integer erId = 551;
    	List<Object[]> behaviorPatternRS;
    	PrmBpBehaviorPatsT prmBpBehaviorPatsT = behaviorPatternsRepository.getBehaviorPatternById(behaviorPatternId);
        assertNotNull(prmBpBehaviorPatsT);
        assertEquals(prmBpBehaviorPatsT.getBpId(), behaviorPatternId);

        behaviorPatternRS =  behaviorPatternMasterRepository.retrieveBehaviorPatternById(behaviorPatternId);
        if (!behaviorPatternRS.isEmpty()) {
	        Object[] behaviorPatternData  = behaviorPatternRS.get(0);
	        assertNotNull(behaviorPatternRS);
	        assertEquals(behaviorPatternData[0], erId);
        } else {
        	logit.info(" behaviorPatternRS is empty");
        }
    }
	
	@Test
    public void testDeleteBehaviorPatterns() {
    	Integer behaviorPatternId = 585;	// 586, 587
    	int deleteResult = behaviorPatternsRepository.deleteBehaviorPattern(behaviorPatternId); 
    	assertEquals(1, deleteResult);   
    }

}
