import com.optum.fads.pgp.datarules.repo.DataRulesRepository;

class DataRulesRepositoryTest extends RepositoryJpaTestSupport {

    @Autowired
    private DataRulesRepository repository;

    @BeforeEach
    void setUp() {
        var creator = persistUser("creator", "Test", "Creator");
        var updater = persistUser("updater", "Test", "Updater");
        var operator = persistOperator("EQ", "Equals");
        var mbMaster = persistMbMaster(801, 1, 1, "Age");

        persistDataRule(5001, "alpharule", creator, updater, operator, mbMaster);
        persistDataRule(5002, "betarule", creator, updater, operator, mbMaster);
        persistConfig(7L, "enabled");
        flushAndClear();
    }

    @Test
    void findDataRulesTest() {
        var pageRequest = PageRequest.of(0, 10);

        assertEquals(2, repository.getDataRules(pageRequest).size());
        assertEquals(1, repository.getAvailableDataRules(List.of(5002), pageRequest).size());
        assertEquals(1, repository.getDataRulesBySearchCrit("%alpha%", "%creator%", "%updater%", pageRequest).size());
        assertNotNull(repository.getDataRuleByName("alpharule"));
        assertEquals("enabled", repository.getFadsConfigByOptionCode(7).getOptionValue());
    }
}
package com.optum.fads.pgp.datarules;

import java.time.LocalDateTime;

import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.boot.test.autoconfigure.jdbc.AutoConfigureTestDatabase;
import org.springframework.boot.test.autoconfigure.orm.jpa.DataJpaTest;
import org.springframework.boot.test.autoconfigure.orm.jpa.TestEntityManager;

import com.optum.fads.pgp.datarules.domain.FadsConfigT;
import com.optum.fads.pgp.datarules.domain.FadsLuValuesT;
import com.optum.fads.pgp.datarules.domain.FadsLuValuesTPK;
import com.optum.fads.pgp.datarules.domain.PrmDrDataRuleT;
import com.optum.fads.pgp.datarules.domain.PrmDrLuOperatorT;
import com.optum.fads.pgp.datarules.domain.PrmMbMasterT;
import com.optum.fads.pgp.datarules.domain.UiUserBase;

@DataJpaTest
@AutoConfigureTestDatabase(replace = AutoConfigureTestDatabase.Replace.ANY)
abstract class RepositoryJpaTestSupport {

    @Autowired
    protected TestEntityManager entityManager;

    protected UiUserBase persistUser(String systemId, String firstName, String lastName) {
        UiUserBase user = new UiUserBase();
        user.setUiSystemId(systemId);
        user.setUiUserId(systemId);
        user.setUiFirstName(firstName);
        user.setUiLastName(lastName);
        user.setUiEMailAddress(systemId + "@example.com");
        entityManager.persist(user);
        return user;
    }

    protected PrmDrLuOperatorT persistOperator(String operatorCode, String description) {
        PrmDrLuOperatorT operator = new PrmDrLuOperatorT();
        operator.setOperatorCd(operatorCode);
        operator.setOperatorDesc(description);
        entityManager.persist(operator);
        return operator;
    }

    protected PrmMbMasterT persistMbMaster(int id, int elementClass, int custFlag, String description) {
        PrmMbMasterT master = new PrmMbMasterT();
        master.setMbCtecFid(id);
        master.setDrElementClass(elementClass);
        master.setMbCustFlag(custFlag);
        master.setMbCustDatadesc(description);
        master.setMbCtecFtype("STRING");
        master.setMbLuFlag(1);
        master.setMbLuSql("select 1");
        master.setMbBpFlag(0);
        master.setMbBpType("GEN");
        entityManager.persist(master);
        return master;
    }

    protected FadsLuValuesT persistLuValue(String fieldId, String luValue, String label, String view, int sequence) {
        FadsLuValuesTPK id = new FadsLuValuesTPK();
        id.setFieldId(fieldId);
        id.setLuValue(luValue);

        FadsLuValuesT value = new FadsLuValuesT();
        value.setId(id);
        value.setLuCode(luValue);
        value.setLuLabel(label);
        value.setLuParent("ROOT");
        value.setLuSeq(sequence);
        value.setLuView(view);
        value.setObjId(sequence);
        entityManager.persist(value);
        return value;
    }

    protected FadsConfigT persistConfig(long optionCode, String optionValue) {
        FadsConfigT config = FadsConfigT.builder()
                .optionCode(optionCode)
                .optionValue(optionValue)
                .description("test config")
                .build();
        entityManager.persist(config);
        return config;
    }

    protected PrmDrDataRuleT persistDataRule(
            int id,
            String name,
            UiUserBase createdBy,
            UiUserBase updatedBy,
            PrmDrLuOperatorT operator,
            PrmMbMasterT mbMaster) {
        PrmDrDataRuleT dataRule = new PrmDrDataRuleT();
        dataRule.setDrId(id);
        dataRule.setDataRuleName(name);
        dataRule.setCreateDate(LocalDateTime.of(2026, 3, 26, 10, 0));
        dataRule.setUpdateDate(LocalDateTime.of(2026, 3, 26, 10, 5));
        dataRule.setUiUserBaseCr(createdBy);
        dataRule.setUiUserBaseUpd(updatedBy);
        dataRule.setPrmDrLuOperatorT(operator);
        dataRule.setPrmMbMasterT(mbMaster);
        entityManager.persist(dataRule);
        return dataRule;
    }

    protected void insertRange(int dataRuleId, long sequence, String rangeFrom, String rangeTo) {
        entityManager.getEntityManager()
                .createNativeQuery(
                        "insert into PRM_DR_RANGES_T (SEQ_NUM, DR_ID, DR_RANGE_FROM, DR_RANGE_TO) values (?, ?, ?, ?)")
                .setParameter(1, sequence)
                .setParameter(2, dataRuleId)
                .setParameter(3, rangeFrom)
                .setParameter(4, rangeTo)
                .executeUpdate();
    }

    protected void insertSingleValue(int dataRuleId, String value, String label) {
        entityManager.getEntityManager()
                .createNativeQuery(
                        "insert into PRM_DR_SINGLE_VALUES_T (DR_VALUE, DR_ID, DR_LABEL) values (?, ?, ?)")
                .setParameter(1, value)
                .setParameter(2, dataRuleId)
                .setParameter(3, label)
                .executeUpdate();
    }

    protected void flushAndClear() {
        entityManager.flush();
        entityManager.clear();
    }
}
