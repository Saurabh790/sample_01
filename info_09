    @Autowired
    private BehaviorPatternErDrRepository behaviorPatternErDrRepository;

    @Test
    void testSaveErDr() {
        var createdBy = persistUser("creator1", "Jane", "Creator");
        var updatedBy = persistUser("updater1", "John", "Updater");
        var operator = persistOperator("EQ", "Equals");
        var mbMaster = persistMbMaster(251, "Data Element 251");
        persistExtractRule(1877);
        persistDataRule(507, "Rule 507", createdBy, updatedBy, operator, mbMaster);
        persistDataRule(508, "Rule 508", createdBy, updatedBy, operator, mbMaster);
        persistDataRule(509, "Rule 509", createdBy, updatedBy, operator, mbMaster);

        persistErDr(1877, 507);
        persistErDr(1877, 508);
        persistErDr(1877, 509);
        flushAndClear();

        List<PrmErDrT> records = behaviorPatternErDrRepository.retrieveErDrValues(1877);
        assertEquals(3, records.size());
    }

    @Test
    void testDeleteErDrById() {
        var createdBy = persistUser("creator2", "Amy", "Creator");
        var updatedBy = persistUser("updater2", "Bob", "Updater");
        var operator = persistOperator("IN", "In");
        var mbMaster = persistMbMaster(252, "Data Element 252");
        persistExtractRule(1888);
        persistDataRule(601, "Rule 601", createdBy, updatedBy, operator, mbMaster);
        persistDataRule(602, "Rule 602", createdBy, updatedBy, operator, mbMaster);
        persistErDr(1888, 601);
        persistErDr(1888, 602);
        flushAndClear();

        int deleted = behaviorPatternErDrRepository.deleteErDrsById(1888);
        flushAndClear();

        assertEquals(2, deleted);
        assertEquals(0, behaviorPatternErDrRepository.retrieveErDrValues(1888).size());
    }
}

