	/**
	 * this method will get the data rule record data corresponding to Data Rule ID
	 * 
	 * Parameters - Data Rule ID
	 */
	public DataRuleDTO getDataRuleById(Integer dataruleRecId) {
		logit.info(" Obtain datarule  for the ID = {}", dataruleRecId);
		DataRuleDTO dataRuleDTO = null;
		boolean details = true;
		List<PrmDrDataRuleT> dataruleList = new ArrayList<>();
		try {
			PrmDrDataRuleT prmDrDataRuleT = dataRuleMasterRepository.retrieveDataRuleById(dataruleRecId);
			if (prmDrDataRuleT != null) {
				dataruleList.add(prmDrDataRuleT);
				List<DataRuleDTO> dataRuleDataList = populateDataRuleList(dataruleList, details);
				logit.info(" Datarule Bean populated with data for ID = {}", dataruleRecId);
				dataRuleDTO = dataRuleDataList.get(0);
			} else {
				logit.info("No data obtained for the Datarule ID = {}", dataruleRecId);
				throw new DataRulesApiException(DataRuleConstants.NO_DATA_FOUND_MSG);
			}
		} catch (Exception e) {
			throw new DataRulesApiException(DataRuleConstants.EXCEPTION_MESSAGE, e);
		}
		return dataRuleDTO;
	}

	/**
	 * this method will give the data rule records data (by filter/sort criteria per
	 * page)
	 * 
	 * Parameters - ListTableParams (contains sort, filter conditions; page number,
	 * page size)
	 */
	public PaginationResult getDataRulesList(ListTableParams listTableParams) {

		int datarulesCount = 0;
		List<DataRuleDTO> dataRuleDataList;
		List<PrmDrDataRuleT> datarulesList = null;
		List<PrmDrDataRuleT> datarulesCntList = null;
		PaginationResult paginationResult;
		Pageable pageable = null;
		if (listTableParams.getSelectedItemIds() == null) {
			listTableParams.setSelectedItemIds(new ArrayList<>());
		}
		try {
			if (listTableParams.getSearchBy() == null) {
				pageable = createPageableDataRules(listTableParams);
				if (!(listTableParams.getSelectedItemIds().isEmpty())) {
					datarulesList = dataRulesRepository.getAvailableDataRules(listTableParams.getSelectedItemIds(),
							pageable);
					datarulesCntList = dataRulesRepository.getAvailableDataRules(listTableParams.getSelectedItemIds(),
							null);
					datarulesCount = datarulesCntList.size();
				} else {
					datarulesList = dataRulesRepository.getDataRules(pageable);
					datarulesCount = (int) dataRulesRepository.count();
				}
				paginationResult = new PaginationResult();
				dataRuleDataList = populateDataRuleList(datarulesList, false);
				paginationResult.setDataRulesData(dataRuleDataList);
				paginationResult.setTotalRecordsCount(datarulesCount);
			} else {
				paginationResult = getDataRulesOnSearchCriteria(listTableParams);
			}
		} catch (Exception e) {
			throw new DataRulesApiException(DataRuleConstants.EXCEPTION_MESSAGE, e);
		}
		return paginationResult;
	}

