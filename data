package com.optum.fads.pgp.datarules.exception;

import org.slf4j.helpers.MessageFormatter;
import org.springframework.http.HttpStatus;

/**
 * Abstract Payment Integrity API exception.
 */
public class PiApiException extends RuntimeException {

	private static final long serialVersionUID = 1L;

	private final String errorCode;

	private final HttpStatus httpStatus;

	/**
	 * Constructor.
	 *
	 * @param code
	 *            exception code
	 * @param message
	 *            exception message
	 */
	private PiApiException(final String code, final String message, final HttpStatus httpStatus) {
		super(message);
		this.errorCode = code;
		this.httpStatus = httpStatus;
	}

	/**
	 * Constructor.
	 *
	 * @param code
	 *            exception code
	 * @param message
	 *            exception message
	 * @param cause
	 *            throwable that caused this exception
	 */
	private PiApiException(final String code, final String message, final HttpStatus httpStatus,
			final Throwable cause) {
		super(message, cause);
		this.errorCode = code;
		this.httpStatus = httpStatus;
	}

	/**
	 * Constructor.
	 *
	 * @param errorDetail
	 *            ErrorDetail instance to provide the message and code
	 */
	public PiApiException(final ErrorDetail errorDetail) {
		this(errorDetail.getCode(), errorDetail.getMessage(), errorDetail.getHttpStatus());
	}

	/**
	 * Constructor.
	 *
	 * @param errorDetail
	 *            ErrorDetail instance to provide the message and code
	 * @param cause
	 *            throwable that caused this exception
	 */
	public PiApiException(final ErrorDetail errorDetail, final Throwable cause) {
		this(errorDetail.getCode(), errorDetail.getMessage(), errorDetail.getHttpStatus(), cause);
	}

	/**
	 * Constructor.
	 *
	 * @param errorDetail
	 *            ErrorDetail instance to provide the message and code
	 * @param messageArgs
	 *            message arguments
	 */
	public PiApiException(final ErrorDetail errorDetail, final Object... messageArgs) {
		this(errorDetail.getCode(),
				MessageFormatter.arrayFormat(errorDetail.getMessage(), messageArgs, null).getMessage(),
				errorDetail.getHttpStatus());
	}

	/**
	 * Constructor.
	 *
	 * @param errorDetail
	 *            ErrorDetail instance to provide the message and code
	 * @param cause
	 *            throwable that caused this exception
	 * @param messageArgs
	 *            message arguments
	 */
	public PiApiException(final ErrorDetail errorDetail, final Throwable cause, final Object... messageArgs) {
		this(errorDetail.getCode(),
				MessageFormatter.arrayFormat(errorDetail.getMessage(), messageArgs, null).getMessage(),
				errorDetail.getHttpStatus(), cause);
	}

	/**
	 * Gets the error code.
	 *
	 * @return error code
	 */
	public String getErrorCode() {
		return errorCode;
	}

	/**
	 * Gets the HTTP Status to return when this exception is thrown by a controller.
	 *
	 * @return HTTP status to return
	 */
	public HttpStatus getHttpStatus() {
		return httpStatus;
	}

}

