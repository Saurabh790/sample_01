import java.util.ArrayList;
import java.util.Collections;
import java.util.Comparator;
import java.util.List;

public class DataRuleDTO {
    private Integer dataRuleId;
    private String dataRuleName;
    private Integer dataElementId;
    private String dataElementName;
    private String dataElementDataType;
    private String rangeValue;
    private List<DrCodeValueDTO> selectedValues;
    private List<DrRangeValuesDTO> rangeValues;
    private String operator;
    private String createdBy;
    private String createdDate;
    private String modifiedBy;
    private String modifiedDate;
    private String createdBySystemId;
    private String modifiedBySystemId;

    public DataRuleDTO() {
        this.selectedValues = new ArrayList<>();
        this.rangeValues = new ArrayList<>();
    }

    public String getOperator() {
        return operator;
    }

    public void setOperator(String operator) {
        this.operator = operator;
    }

    public List<DrRangeValuesDTO> getRangeValues() {
        Comparator<DrRangeValuesDTO> compareByFromTo = Comparator
                .comparing(DrRangeValuesDTO::getFrom)
                .thenComparing(DrRangeValuesDTO::getTo);
        Collections.sort(rangeValues, compareByFromTo);
        return rangeValues;
    }

    public void setRangeValues(List<DrRangeValuesDTO> rangeValues) {
        this.rangeValues = rangeValues;
    }

    public List<DrCodeValueDTO> getSelectedValues() {
        if(selectedValues==null){
            return Collections.emptyList();
        }
        selectedValues.sort((DrCodeValueDTO dcv1, DrCodeValueDTO dcv2)
                -> String.CASE_INSENSITIVE_ORDER.compare(dcv1.getCode().toUpperCase(), dcv2.getCode().toUpperCase()));
        return selectedValues;
    }

    public void setSelectedValues(List<DrCodeValueDTO> selectedValues) {
        this.selectedValues = selectedValues;
    }

    public String getRangeValue() {
        return rangeValue;
    }

    public void setRangeValue(String rangeValue) {
        this.rangeValue = rangeValue;
    }

    public Integer getDataElementId() {
        return dataElementId;
    }

    public void setDataElementId(Integer dataElementId) {
        this.dataElementId = dataElementId;
    }

    public String getDataElementName() {
        return dataElementName;
    }

    public void setDataElementName(String dataElementName) {
        this.dataElementName = dataElementName;
    }

    public String getDataElementDataType() {
        return dataElementDataType;
    }

    public void setDataElementDataType(String dataElementDataType) {
        this.dataElementDataType = dataElementDataType;
    }

    public Integer getDataRuleId() {
        return dataRuleId;
    }

    public void setDataRuleId(Integer dataRuleId) {
        this.dataRuleId = dataRuleId;
    }

    public String getDataRuleName() {
        if(dataRuleName!=null){
            dataRuleName=dataRuleName.trim();
        }
        return dataRuleName;
    }

    public void setDataRuleName(String dataRuleName) {
        this.dataRuleName = dataRuleName;
    }

    public String getCreatedBy() {
        return createdBy;
    }

    public void setCreatedBy(String createdBy) {
        this.createdBy = createdBy;
    }

    public String getCreatedDate() {
        return createdDate;
    }

    public void setCreatedDate(String createdDate) {
        this.createdDate = createdDate;
    }

    public String getModifiedBy() {
        return modifiedBy;
    }

    public void setModifiedBy(String modifiedBy) {
        this.modifiedBy = modifiedBy;
    }

    public String getModifiedDate() {
