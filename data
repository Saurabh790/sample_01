   }
	/**
	* this method will add a data rule 
	 * 
	 * @param - dataRuleDTO
	 */
	@PostMapping(value = {"/newdatarule"})
	public ResponseEntity newDataRule(@RequestBody DataRuleDTO dataRuleDTO) {
		DataRuleDTO retDataRuleDTO = null;
		String userAccess = "";
		boolean userHasAccess = false;
		DateTimeFormatter dateTimeFormatter = DateTimeFormatter.ofPattern(DataRuleConstants.DATE_FORMAT_MMDDYYYY_HHMMSS_A,
				Locale.ENGLISH);
		try {
			AppUser user = (AppUser) SecurityContextHolder.getContext().getAuthentication().getPrincipal();
			dataRuleDTO.setCreatedBySystemId(user.getUserSystemId());
			dataRuleDTO.setModifiedBySystemId(user.getUserSystemId());
			List<AccessLevel> userAccessLevels = user.getRole().getAllowedAccesses();
			for (AccessLevel userAccessLevel : userAccessLevels) {
				if (userAccessLevel.getModuleCode().equals("STUDY")) {
					userAccess = userAccessLevel.getAccess();
					break;
				}
			}
			if (userAccess.equals("A") || userAccess.equals("B")) {
				userHasAccess = true;
			}
			if (userHasAccess) {
				LocalDateTime currentLocalDate = LocalDateTime.now(iDataRuleDataService.getZoneId());
				// Save the update date as per local time zone in the DTO
				dataRuleDTO.setCreatedDate(dateTimeFormatter.format(currentLocalDate));
				dataRuleDTO.setModifiedDate(dateTimeFormatter.format(currentLocalDate));
				retDataRuleDTO = iDataRuleDataService.addDataRule(dataRuleDTO);	
				return ResponseEntity
				        .status(HttpStatus.CREATED)                 
				        .body(retDataRuleDTO);
			} else {
				return new ResponseEntity<String>(DataRuleConstants.NOT_AUTHORIZED, HttpStatus.FORBIDDEN);
			}	
		} catch (DataRulesApiException ex) {
			logit.error(DataRuleConstants.EXCEPTION_MESSAGE, ex.getMessage());
			return ResponseEntity.status(HttpStatus.BAD_REQUEST).body(DataRuleConstants.EXCEPTION_MESSAGE);
		}		
		
   }
	/**
	* this method will update a data rule 
	 * 
	 * @param - dataRuleDTO
	 */
	@PutMapping(value = {"/updatedatarule/{dataRuleId}"})
	public ResponseEntity<String> updateDataRuleById(@PathVariable(name = "dataRuleId") Integer dataRuleId, @RequestBody DataRuleDTO dataRuleDTO) {
		String updDataRuleMessage;
		String userAccess = "";
		boolean userHasAccess = false;
		DateTimeFormatter dateTimeFormatter = DateTimeFormatter.ofPattern(DataRuleConstants.DATE_FORMAT_MMDDYYYY_HHMMSS_A,
				Locale.ENGLISH);
		try {
			AppUser user = (AppUser) SecurityContextHolder.getContext().getAuthentication().getPrincipal();
			dataRuleDTO.setModifiedBySystemId(user.getUserSystemId());
			List<AccessLevel> userAccessLevels = user.getRole().getAllowedAccesses();
			for (AccessLevel userAccessLevel : userAccessLevels) {
				if (userAccessLevel.getModuleCode().equals("STUDY")) {
					userAccess = userAccessLevel.getAccess();
					break;
				}
			}
			if (userAccess.equals("A") || 
					(userAccess.equals("B") && dataRuleDTO.getCreatedBySystemId().equals(user.getUserSystemId()))) {
				userHasAccess = true;
			}
			if (userHasAccess) {
				LocalDateTime currentLocalDate = LocalDateTime.now(iDataRuleDataService.getZoneId());
				// Save the update date as per local time zone in the DTO
				dataRuleDTO.setModifiedDate(dateTimeFormatter.format(currentLocalDate));
				updDataRuleMessage = iDataRuleDataService.updateDataRule(dataRuleId, dataRuleDTO);
				return ResponseEntity
				        .status(HttpStatus.OK)                 
				        .body(updDataRuleMessage);
			} else {
				return new ResponseEntity<String>(DataRuleConstants.NOT_AUTHORIZED, HttpStatus.FORBIDDEN);
			}
		} catch (DataRulesApiException ex) {
			logit.error(DataRuleConstants.EXCEPTION_MESSAGE, ex.getMessage());
			return ResponseEntity.status(HttpStatus.BAD_REQUEST).body(DataRuleConstants.EXCEPTION_MESSAGE);
		}		
		
   }
	 /**
		 * this method will delete the data rule record corresponding to input data rule ID  
		 * @param - Data Rule ID 
		 */
	@DeleteMapping(value = "/deletedatarule/{dataruleId}")
