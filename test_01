	    @Test
	    public void testNewDataRule() {
	    	Integer dataruleId = 999;		// 981 in FADS DEV DB
	    	LocalDateTime currentDate = LocalDateTime.now();
				
			PrmDrDataRuleT prmDrDataRuleT = new PrmDrDataRuleT();
			UiUserBase uiUserBase = new UiUserBase();	
			prmDrDataRuleT.setUiUserBaseCr(uiUserBase);				// Set UiUserBase
			prmDrDataRuleT.setUiUserBaseUpd(uiUserBase);
			prmDrDataRuleT.getUiUserBaseCr().setUiSystemId("WA40122433");
			
			PrmMbMasterT prmMbMasterT = new PrmMbMasterT();
			prmDrDataRuleT.setPrmMbMasterT(prmMbMasterT);			// Set PrmMbMasterT
			
			PrmDrLuOperatorT prmDrLuOperatorT= new PrmDrLuOperatorT();
			prmDrLuOperatorT.setOperatorCd("1");
			prmDrLuOperatorT.setOperatorDesc("Inclusive");
			prmDrDataRuleT.setPrmDrLuOperatorT(prmDrLuOperatorT);	// Set PrmDrLuOperatorT
				
			prmDrDataRuleT.setDrId(dataruleId);							
			prmDrDataRuleT.setDataRuleName("AW:Prov Role = Referring/Servicing");
			prmDrDataRuleT.getPrmMbMasterT().setMbCtecFid(316);
								
			prmDrDataRuleT.setCreateDate(currentDate);
			prmDrDataRuleT.setUpdateDate(currentDate);
			PrmDrDataRuleT prmDrDataRuleT1 =  dataRuleMasterRepository.save(prmDrDataRuleT); 
	    	// The save() method returns the saved entity, including the updated id field
	    	assertEquals(prmDrDataRuleT1.getDataRuleName(), prmDrDataRuleT.getDataRuleName());
	    	assertEquals(prmDrDataRuleT1.getPrmDrLuOperatorT().getOperatorCd(), prmDrDataRuleT.getPrmDrLuOperatorT().getOperatorCd());
	    } 
}



