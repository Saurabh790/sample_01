	    	Integer dataruleId = 988;
	    	int dataElementId = 117;
	    	LocalDateTime modifiedDate = LocalDateTime.now();
	    	int updateResult = dataRuleMasterRepository.updateDataRuleDb("AW:Proc cd=98940-3, Chiro Manipulation 1-4 Regions",
