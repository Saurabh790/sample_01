    @Override
    public List<FinancialHistoryBean> findFinancialHistory(Map<String, String> filterConditions,
                                                           Map<String, String> sortConditions,
                                                           int firstRecord, int maxRecords, Integer caseId) {
        List<FinancialHistoryBean> resultList = new ArrayList<>();
        try {


            Criteria criteria = getCurrentSession().createCriteria(CaFinancialLedgerHistT.class);
            criteria.add(Restrictions.eq("id.caseId", new Integer(caseId)));    //.addOrder(Order.desc("id.histSeqNum"));

            if (sortConditions != null && !sortConditions.isEmpty()) {
                for (Map.Entry<String, String> entry : sortConditions.entrySet()) {
                    if ("histSeqNum".equals(entry.getKey())) {
                        if ("1".equals(entry.getValue())) {
                            criteria.addOrder(Order.asc("id.histSeqNum"));
                        } else if ("-1".equals(entry.getValue())) {
                            criteria.addOrder(Order.desc("id.histSeqNum"));
                        }
                    } else if ("paySeqNo".equals(entry.getKey())) {
                        if ("1".equals(entry.getValue())) {
                            criteria.addOrder(Order.asc("id.paySeqNum"));
                        } else if ("-1".equals(entry.getValue())) {
                            criteria.addOrder(Order.desc("id.paySeqNum"));
                        }
                    }
