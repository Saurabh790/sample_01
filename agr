package com.optum.fads.CaseClaimCorrections.api.common.verifier;

import org.junit.Test;

import static org.junit.Assert.assertTrue;

/**
 * Unit tests for GetterSetterVerifier.
 *
 * @param <T>
 */
public class VerifierDTOTest {

    @Test
    public void testGetterSetterVerifier() {
        assertTrue("Verify GetterSetter returns true", GetterSetterVerifier.forClass(VerifierDTO.class).verify());
    }

    @Test
    public void testGetterSetterVerifierInclude() {
        assertTrue(
                "Verify GetterSetter returns true",
                GetterSetterVerifier.forClass(VerifierDTO.class).include("verifyString").verify());
    }

    @Test
    public void testGetterSetterVerifierExclude() {
        assertTrue(
                "Verify GetterSetter returns true",
                GetterSetterVerifier.forClass(VerifierDTO.class).exclude("verifyString").verify());
    }

    @Test(expected = AssertionError.class)
    public void testGetterSetterVerifierFailure() {
        assertTrue(
                "Verify GetterSetter returns assertion error",
                GetterSetterVerifier.forClass(VerifierFailDTO.class).verify());
    }
}
