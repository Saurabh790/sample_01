    @Test
    public void createCaGeneralTentryBuildsTrackingDataWithoutCaseSource() {
        CaIntelligentKeyT key = CaIntelligentKeyT.builder().caseId(55).build();
        CaUniverseT caUniverseT = createUniverse();
        caUniverseT.setCaseSourceCd(null);

        CaGeneralT result = caseBatchIndividualService.createCaGeneralTentry(key, "PART-1", "John Smith", caUniverseT);

        assertEquals(Integer.valueOf(55), result.getCaseId());
        assertEquals("PART-1", result.getParticipantId());
        assertEquals("John Smith", result.getParticipantName());
        assertEquals(CaseEntryConstants.BATCH_CASE + 10, result.getTrackingId());
        assertEquals("ACTIVE", result.getProtectStatus());
        assertNull(result.getCaLuCaseSourceT());
        assertSame(key, result.getCaIntelligentKeyT());
    }

    @Test
    public void createCaGeneralTentryAddsCaseSourceWhenProvided() {
        CaIntelligentKeyT key = CaIntelligentKeyT.builder().caseId(56).build();
