    private List<CaLuValuesT> findByFieldIdAndOrderBySeq(String fieldId) {
		logger.debug("findByFieldIdAndOrderBySeq CaLuValuesT instance with fieldId: " + fieldId );
		try {
			String text = "from CaLuValuesT as model where model.id.fieldId = :fieldId  and model.luView='1' order by model.id.luSeq asc ";
			Query queryObject = getCurrentSession().createQuery(text);
			queryObject.setParameter("fieldId", fieldId);
			return queryObject.list();

		} catch (RuntimeException re) {
			logger.error("find by findByFieldIdAndOrderBySeq failed", re);
			throw re;
		}
	}

