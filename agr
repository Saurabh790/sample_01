import org.springframework.security.core.context.SecurityContextHolder;
import org.springframework.web.bind.annotation.*;

import java.util.*;
import java.util.stream.Collectors;

@RestController
public class CustomMetabaseController {

	@Autowired
	private ICustomFieldService customFieldService;


	/**
	  * @return the Special Info Custom fields by node
	  */
	@RequestMapping(method = RequestMethod.GET, value="/claimCorrectionsCustomFields/{node}")
	public @ResponseBody Collection<CaseMetaBaseDTO> findClaimCorrectionsFields(@PathVariable("node") String node){
        AppUser user =  null;
        Authentication auth =  SecurityContextHolder.getContext().getAuthentication();
        if (auth != null) {
             user = (AppUser) auth.getPrincipal();
        }
		Collection<CaseMetaBaseDTO>  caMetaBaseList = customFieldService.findClaimCorrectionsCustomFields();
		caMetaBaseList.stream().forEach(mbItem->{
			if(Objects.nonNull(mbItem.getFieldValidValues())){
				Collection<LabelValueBean> luValues=	mbItem.getFieldValidValues();
				luValues=luValues.stream().filter(l ->l.getFilter()== null || node.equals(l.getFilter())).collect(Collectors.toList());
				mbItem.setFieldValidValues(luValues);
			}
		});
		return caMetaBaseList;
		 
	}

}
