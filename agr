    @Test
    void updateClaimCorrectionCreatesHistoryAndNewFindingWhenClaimChanges() {
        ClaimCorrectionDTO dto = baseClaimCorrectionDto();
        dto.setFindingObservations(List.of(FindingObservation.builder()
                .seqNum(0)
                .operation(FindingOperation.NEW)
                .discrepancyTypeCd("O")
                .versionCd("V1")
                .typeCd("TYPE1")
                .note("note")
                .build()));

        CaClaimCorrectionsT existing = correctionEntity(10, 4, "TCN-10", BigDecimal.valueOf(50));
        CaClaimCorrectionsT current = correctionEntity(10, 4, "TCN-10", BigDecimal.valueOf(70));
        CaClaimCorrectionsHistT history = CaClaimCorrectionsHistT.builder()
                .id(CaClaimCorrectionsHistTId.builder().caseId(10).clmSeqNum(4).histSeqNum(0).build())
                .build();
        CaClaimFindingsObsT newFinding = CaClaimFindingsObsT.builder()
                .id(CaClaimFindingsObsTId.builder().caseId(10).seqNum(BigDecimal.ZERO).build())
                .discrepancyTypeCd("O")
                .findingsVersionCd("V1")
                .build();

        when(claimCorrectionsRepo.findById(CaClaimCorrectionsTId.builder().caseId(10).clmSeqNum(4).build()))
                .thenReturn(Optional.of(existing));
        when(claimCorrectionMapper.convertToCaClaimCorrectionsT(dto)).thenReturn(current);
        when(claimCorrectionMapper.convertToCaClaimCorrectionsHisT(dto)).thenReturn(history);
        when(caClaimCorrectionsHistRepo.getNextClmCorrHistSequenceId(10, 4)).thenReturn(null);
        when(claimFindingsObsMapper.convertToCaClaimFindingsObsT(dto.getFindingObservations().get(0))).thenReturn(newFinding);
        when(caClaimFindingsObsRepo.getNextSequnceId(10)).thenReturn(null);
        when(caClaimFindingsObsRepo.getNextObservationVersionSequnceId(10, 4)).thenReturn(null);
        when(caseConfigRepo.findById("CLAIMS_CORR_FIN_UPD")).thenReturn(Optional.empty());
        doReturn(ZoneId.of("UTC")).when(caseDetailClaimsService).getZoneId();

        caseDetailClaimsService.updateClaimCorrection(dto, "USR2");

        verify(caClaimListRepo).updateClaimCorrectPdAmt(10, 4, BigDecimal.valueOf(70));
        verify(caClaimCorrectionsHistRepo).save(argThat(saved ->
                saved.getId().getHistSeqNum() == 1
                        && saved.getChangeUsr() != null
                        && "USR2".equals(saved.getChangeUsr().getUiSystemId())
                        && saved.getCaIntelligentKeyT() != null
                        && saved.getCaIntelligentKeyT().getId().equals(10)));
        verify(caClaimFindingsObsRepo).save(argThat(saved ->
                saved.getId().getSeqNum().equals(BigDecimal.ONE)
                        && saved.getVersionSeqNum().equals(BigDecimal.ONE)
                        && saved.getCorrectPdAmt().equals(70.0)
                        && "USR2".equals(saved.getFindingsObsUser().getUiSystemId())));
    }

