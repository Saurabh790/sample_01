package com.optum.fads.pgp.study.repo.specs;

import java.text.MessageFormat;
import java.util.ArrayList;
import java.util.List;
import java.util.Map;

import jakarta.persistence.criteria.*;

import org.apache.commons.lang3.StringUtils;
import org.springframework.data.jpa.domain.Specification;

import com.optum.fads.pgp.study.common.util.StudyConstants;
import com.optum.fads.pgp.study.common.util.StudyEnum;
import com.optum.fads.pgp.study.domain.PrmStudyMasterT;
import com.optum.fads.pgp.study.domain.UiUserBase;

/**
 * @author sbiry
 *
 */
public class StudySpecification {

//	private static final String[] metaCharacters = { "\\", "^", "$", "{", "}", "[", "]", ".", "*", "+", "?", "|", "<",
//			"-", "(", ")", "&", ">", "%" };//

	
	public static Specification<PrmStudyMasterT> findAllStudySpecification(Map<String, String> filterOptions) {

		return new Specification<PrmStudyMasterT>() {
			private static final long serialVersionUID = 1L;

			@Override
			public Predicate toPredicate(Root<PrmStudyMasterT> root, CriteriaQuery<?> query, CriteriaBuilder cb) {
				List<Predicate> predicates = new ArrayList<>();
				boolean myItems = false;
				if (filterOptions != null) {
					if (filterOptions.containsKey(StudyConstants.USER_SYSTEM_ID)) {
						myItems = true;
					}
					
					for (Map.Entry<String, String> criteria : filterOptions.entrySet()) {
						
						if (criteria.getKey().equals(StudyEnum.studyName.name())) {
							if (StringUtils.containsAny(criteria.getValue(), StudyConstants.PLUS_REPL_STR)) {
								criteria.setValue(criteria.getValue().replaceAll(StudyConstants.PLUS_REPL_STR, StudyConstants.PLUS_STR));
							}
							if (StringUtils.containsAny(criteria.getValue(), StudyConstants.COMMA_REPL_STR)) {
								criteria.setValue(criteria.getValue().replaceAll(StudyConstants.COMMA_REPL_STR, StudyConstants.COMMA_STR));
							}
							if (StringUtils.containsAny(criteria.getValue(), StudyConstants.SPACE_ENCODED_STR)) {
								criteria.setValue(criteria.getValue().replaceAll(StudyConstants.SPACE_ENCODED_STR, StudyConstants.BLANK_STR));
							} 
							predicates.add(cb.like(cb.lower(root.get("pbName")),
									replaceSpecialCharacters(criteria.getValue().toLowerCase()), '/'));// '/'));
						}
						
						if (criteria.getKey().equals(StudyEnum.createdUser.name())) {
							Join<PrmStudyMasterT, UiUserBase> createdBy = root.join("createdByUiUserBase");
	
							predicates.add(cb.like(cb.lower(createdBy.get("userFullName")),
									replaceSpecialCharacters(criteria.getValue().toLowerCase()), '/'));
						}
						if (criteria.getKey().equals(StudyEnum.updatedUser.name())) {
							Join<PrmStudyMasterT, UiUserBase> updatedBy = root.join("updatedByUiUserBase");
							predicates.add(cb.like(cb.lower(updatedBy.get("userFullName")),
									replaceSpecialCharacters(criteria.getValue().toLowerCase()), '/'));
						}
						// My Items
						if (criteria.getKey().equals(StudyConstants.USER_SYSTEM_ID)) {
							Join<PrmStudyMasterT, UiUserBase> createdByUserId = root.join("createdByUiUserBase");
							Join<PrmStudyMasterT, UiUserBase> updatedByByUserId = root.join("updatedByUiUserBase");
							Predicate createdByUserIdRestriction = cb.equal(createdByUserId.get("uiSystemId"), criteria.getValue());
							Predicate updatedByByUserIdRestriction = cb.equal(updatedByByUserId.get("uiSystemId"), criteria.getValue());
							predicates.add(cb.or(createdByUserIdRestriction, updatedByByUserIdRestriction));
							
						}
						
					}
				}
				return query.where(predicates.toArray(new Predicate[predicates.size()])).getRestriction();
			}
		};

	}

	
	private static String replaceSpecialCharacters(String inputString) {
		String returnValue=inputString;
			returnValue= inputString.replaceAll("/", "//").replaceAll("_","/_").replaceAll("%", "/%");
		return MessageFormat.format("%{0}%", returnValue);
	}
}
