        Page<Study> expectedPage = new PageImpl<>(List.of(study));
        when(studyService.findAllStudies(expectedMap, pageable)).thenReturn(expectedPage);

        Page<Study> result = studyController.findAllByPageable(
                pageNumber, recordsPerPage, sortBy, sortOrder, searchKeys, searchInput);

        assertThat(result, is(equalTo(expectedPage)));
    }

