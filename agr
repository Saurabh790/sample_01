package com.optum.fads.pgp.study.exception;

import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.http.ResponseEntity;
import org.springframework.web.bind.annotation.ExceptionHandler;
import org.springframework.web.servlet.mvc.method.annotation.ExceptionHandlerExceptionResolver;

import com.optum.fads.pgp.study.common.rest.ResponseBuilder;
import com.optum.fads.pgp.study.dto.rest.ErrorResponse;

import lombok.extern.slf4j.Slf4j;

/**
 * The RestExceptionHandler is used to act and respond based on the type of
 * exception thrown by API controllers.
 */
//@ControllerAdvice
@Slf4j
public class RestExceptionHandler extends ExceptionHandlerExceptionResolver {

	private final ResponseBuilder responseBuilder;

	/**
	 * Constructor.
	 *
	 * @param responseBuilder response builder
	 */
	@Autowired
	public RestExceptionHandler(final ResponseBuilder responseBuilder) {
		super();
		this.responseBuilder = responseBuilder;
	}

	/**
	 * Exception handler for StudyApiException.
	 *
	 * @param e exception to handle
	 * @return response entitys
	 */
	@ExceptionHandler(StudyApiException.class)
	public ResponseEntity<ErrorResponse> exceptionHandler(final StudyApiException e) {
		log.error("StudyApiException occurred", e);

		final ErrorResponse errorResponse = responseBuilder.buildErrorResponse(e);

		return new ResponseEntity<>(errorResponse, e.getHttpStatus());
	}

}
