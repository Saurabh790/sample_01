class DataRuleDataServiceTest {

    @Mock
    private DataRuleMasterRepository dataRuleMasterRepository;
    @Mock
    private DataRulesRepository dataRulesRepository;
    @Mock
    private DataRuleSingleValuesRepository dataRuleSingleValuesRepository;
    @Mock
    private DataRuleRangesRepository dataRuleRangesRepository;
    @Mock
    private FadsConfigRepository fadsConfigRepository;
    @Mock
    private DataRuleDetailMapper dataRuleDetailMapper;

    @InjectMocks
    private DataRuleDataService service;

    @Test
    void getDataRuleByIdMapsDetailedData() {
        when(dataRuleMasterRepository.retrieveDataRuleById(5001)).thenReturn(buildRule());

        DataRuleDTO dto = service.getDataRuleById(5001);

        assertEquals(5001, dto.getDataRuleId());
        assertEquals("alpharule", dto.getDataRuleName());
        assertEquals("Age", dto.getDataElementName());
        assertEquals("EQ", dto.getOperator());
        assertEquals("Test Creator", dto.getCreatedBy());
        assertEquals("Test Updater", dto.getModifiedBy());
        assertEquals(DataRuleConstants.HAS_VALUE, dto.getRangeValue());
        assertEquals(1, dto.getRangeValues().size());
    }

    @Test
    void loadCodeValuesByIdMapsRepositoryRows() {
        PrmDrSingleValuesT value = new PrmDrSingleValuesT();
        PrmDrSingleValuesTPK id = new PrmDrSingleValuesTPK();
        id.setDrId(1);
        id.setDrValue("A");
        value.setId(id);
        value.setDrLabel("Adult");
        when(dataRuleSingleValuesRepository.retrieveCodeValues(1)).thenReturn(List.of(value));

        List<DrCodeValueDTO> result = service.loadCodeValuesById(1);

        assertEquals(1, result.size());
        assertEquals("A", result.get(0).getCode());
        assertEquals("Adult", result.get(0).getValue());
    }

    @Test
    void loadRangeValuesByIdMapsRepositoryRows() {
        PrmDrRangesT range = new PrmDrRangesT();
        PrmDrRangesTPK id = new PrmDrRangesTPK();
        id.setDrId(1);
        id.setSeqNum(1L);
        range.setId(id);
        range.setDrRangeFrom("10");
        range.setDrRangeTo("20");
        when(dataRuleRangesRepository.retrieveRangeValues(1)).thenReturn(List.of(range));

        List<DrRangeValuesDTO> result = service.loadRangeValuesById(1);

        assertEquals(1, result.size());
        assertEquals("10", result.get(0).getFrom());
        assertEquals("20", result.get(0).getTo());
    }

    @Test
    void getSearchCriteriaNormalizesAndEscapesInputs() {
        ListTableParams params = new ListTableParams();
        params.setSearchBy(List.of(
                DataRuleConstants.DATA_RULE_NAME,
                DataRuleConstants.CREATED_BY,
                DataRuleConstants.MODIFIED_BY,
                DataRuleConstants.USER_SYSTEM_ID));
        params.setSearchInput(List.of("alpha%", "  Test   Creator ", "Test   Updater", "SYS1"));

        String[] result = ReflectionTestUtils.invokeMethod(service, "getSearchCriteria", params);

        assertEquals("%alpha\%%", result[0]);
        assertEquals("%test creator%", result[1]);
        assertEquals("%test updater%", result[2]);
        assertEquals(DataRuleConstants.SEARCH_SP_CH_IN_NM_STR, result[3]);
        assertEquals("sys1", result[4]);
    }

    @Test
    void getDataRulesListUsesRepositoryPagingWhenSearchByMissing() {
        ListTableParams params = new ListTableParams();
        params.setSortBy(DataRuleConstants.DATA_RULE_NAME);
        params.setSortOrder(1);
        params.setPageNumber(1);
        params.setRecordsPerPage(10);
        params.setSelectedItemIds(List.of());

        when(dataRulesRepository.getDataRules(org.mockito.ArgumentMatchers.any(Pageable.class)))
                .thenReturn(List.of(buildRule()));
        when(dataRulesRepository.count()).thenReturn(1L);

        var result = service.getDataRulesList(params);

        assertEquals(1, result.getTotalRecordsCount());
        assertEquals(1, result.getDataRulesData().size());
        assertEquals("alpharule", result.getDataRulesData().get(0).getDataRuleName());
    }

    @Test
    void getDataRulesListUsesSearchCriteriaBranch() {
        ListTableParams params = new ListTableParams();
        params.setSortBy(DataRuleConstants.DATA_RULE_NAME);
        params.setSortOrder(1);
        params.setPageNumber(1);
        params.setRecordsPerPage(10);
        params.setSelectedItemIds(List.of());
        params.setSearchBy(List.of(DataRuleConstants.DATA_RULE_NAME));
        params.setSearchInput(List.of("alpha"));

        when(dataRulesRepository.getDataRulesBySearchCrit(
                org.mockito.ArgumentMatchers.eq("%alpha%"),
                org.mockito.ArgumentMatchers.eq("%"),
                org.mockito.ArgumentMatchers.eq("%"),
                org.mockito.ArgumentMatchers.any(Pageable.class)))
                .thenReturn(List.of(buildRule()));
        when(dataRulesRepository.getDataRulesBySearchCrit("%alpha%", "%", "%", null))
                .thenReturn(List.of(buildRule()));

        var result = service.getDataRulesList(params);

        assertEquals(1, result.getTotalRecordsCount());
        assertEquals(1, result.getDataRulesData().size());
        assertEquals("alpharule", result.getDataRulesData().get(0).getDataRuleName());
    }

    @Test
    void getZoneIdReturnsConfiguredTimeZone() {
        when(fadsConfigRepository.findById(DataRuleConstants.DATE_TIME_ZONE_ID))
                .thenReturn(Optional.of(FadsConfigT.builder().optionCode(700).optionValue("America/Chicago").build()));

        ZoneId zoneId = service.getZoneId();

        assertEquals(ZoneId.of("America/Chicago"), zoneId);
    }

    @Test
    void addDataRuleReturnsNameExistsForDuplicateRule() {
        PrmDrDataRuleT existing = buildRule();
        when(dataRulesRepository.getDataRuleByName("alpharule")).thenReturn(existing);

        DataRuleDTO input = new DataRuleDTO();
        input.setDataRuleName(" alpharule ");

        DataRuleDTO result = service.addDataRule(input);

        assertEquals(DataRuleConstants.DATA_RULE_NAME_EXISTS, result.getDataRuleName());
        assertEquals(existing.getDrId(), result.getDataRuleId());
        assertEquals(existing.getUiUserBaseCr().getUiSystemId(), result.getCreatedBySystemId());
        assertEquals(existing.getUiUserBaseUpd().getUiSystemId(), result.getModifiedBySystemId());
    }

    @Test
    void deleteDataRuleDeletesWhenNoConstraintsExist() {
        when(dataRuleMasterRepository.retrieveDataRuleById(5001)).thenReturn(buildRule());
        when(dataRuleMasterRepository.retrieveErDrValues(5001)).thenReturn(List.of());
        when(dataRuleMasterRepository.retrievePgDrValues(5001)).thenReturn(List.of());
        when(dataRuleMasterRepository.deleteDatarule(5001)).thenReturn(1);

        List<String> result = service.deleteDataRule(5001);

        assertEquals(List.of(DataRuleConstants.DELETE_SUCCESS_MESSAGE), result);
        verify(dataRuleRangesRepository).deleteRangesByDataRuleId(5001);
        verify(dataRuleSingleValuesRepository).deleteSingleValuesByDataRuleId(5001);
    }

    @Test
    void deleteDataRuleReturnsDoesNotExistWhenRuleMissing() {
        when(dataRuleMasterRepository.retrieveDataRuleById(5001)).thenReturn(null);

        List<String> result = service.deleteDataRule(5001);

        assertEquals(List.of(DataRuleConstants.DATA_RULE_DOES_NOT_EXIST), result);
    }

    @Test
    void getDataRuleByIdThrowsWrappedExceptionWhenMissing() {
        when(dataRuleMasterRepository.retrieveDataRuleById(9999)).thenReturn(null);

        assertThrows(DataRulesApiException.class, () -> service.getDataRuleById(9999));
    }

    @Test
    void formatLocalDateReturnsNullForNullInput() {
        String result = service.formatLocalDate(null);
        assertEquals(null, result);
    }

    private PrmDrDataRuleT buildRule() {
        UiUserBase creator = new UiUserBase();
        creator.setUiSystemId("creator");
        creator.setUiFirstName("Test");
        creator.setUiLastName("Creator");

        UiUserBase updater = new UiUserBase();
        updater.setUiSystemId("updater");
        updater.setUiFirstName("Test");
        updater.setUiLastName("Updater");

        PrmMbMasterT mbMaster = new PrmMbMasterT();
        mbMaster.setMbCtecFid(801);
        mbMaster.setMbCustDatadesc("Age");
        mbMaster.setMbCtecFtype("CHAR");

        PrmDrLuOperatorT operator = new PrmDrLuOperatorT();
        operator.setOperatorCd("EQ");

        PrmDrSingleValuesTPK singleId = new PrmDrSingleValuesTPK();
        singleId.setDrId(5001);
        singleId.setDrValue("A");
        PrmDrSingleValuesT singleValue = new PrmDrSingleValuesT();
        singleValue.setId(singleId);
        singleValue.setDrLabel("Adult");

        PrmDrRangesTPK rangeId = new PrmDrRangesTPK();
        rangeId.setDrId(5001);
        rangeId.setSeqNum(1L);
        PrmDrRangesT rangeValue = new PrmDrRangesT();
        rangeValue.setId(rangeId);
        rangeValue.setDrRangeFrom("10");
        rangeValue.setDrRangeTo("20");

        PrmDrDataRuleT rule = new PrmDrDataRuleT();
        rule.setDrId(5001);
        rule.setDataRuleName("alpharule");
        rule.setCreateDate(LocalDateTime.of(2026, 4, 1, 10, 0));
        rule.setUpdateDate(LocalDateTime.of(2026, 4, 1, 11, 0));
        rule.setUiUserBaseCr(creator);
        rule.setUiUserBaseUpd(updater);
        rule.setPrmMbMasterT(mbMaster);
        rule.setPrmDrLuOperatorT(operator);
        rule.setPrmDrSingleValuesTs(List.of(singleValue));
        rule.setPrmDrRangesTs(List.of(rangeValue));
        return rule;
    }
}
package com.optum.fads.pgp.datarules;

import static org.junit.jupiter.api.Assertions.assertEquals;
import static org.junit.jupiter.api.Assertions.assertTrue;

import java.util.List;

import org.junit.jupiter.api.BeforeEach;
import org.junit.jupiter.api.Test;
import org.springframework.beans.factory.annotation.Autowired;

import com.optum.fads.pgp.datarules.domain.PrmDrRangesT;
import com.optum.fads.pgp.datarules.domain.PrmDrRangesTPK;
import com.optum.fads.pgp.datarules.repo.DataRuleRangesRepository;

class DataRuleRangesRepositoryTest extends RepositoryJpaTestSupport {

    private static final int DATA_RULE_ID = 2001;

    @Autowired
    private DataRuleRangesRepository repository;

    @BeforeEach
    void setUp() {
        var creator = persistUser("creator", "Test", "Creator");
        var updater = persistUser("updater", "Test", "Updater");
        var operator = persistOperator("EQ", "Equals");
        var mbMaster = persistMbMaster(501, 1, 1, "Age");
        persistDataRule(DATA_RULE_ID, "Range Rule", creator, updater, operator, mbMaster);
        insertRange(DATA_RULE_ID, 1L, "10", "20");
        insertRange(DATA_RULE_ID, 2L, "21", "30");
        flushAndClear();
    }

    @Test
    void testGetRangeValues() {
        List<PrmDrRangesT> result = repository.retrieveRangeValues(DATA_RULE_ID);

        assertEquals(2, result.size());
    }

    @Test
    void saveRangesTest() {
        insertRange(DATA_RULE_ID, 3L, "31", "40");
        flushAndClear();

        List<PrmDrRangesT> result = repository.retrieveRangeValues(DATA_RULE_ID);

        assertEquals(3, result.size());
        assertTrue(result.stream().anyMatch(range ->
                range.getId().getSeqNum() == 3L
                        && "31".equals(range.getDrRangeFrom())
                        && "40".equals(range.getDrRangeTo())));
    }

    @Test
    void deleteRangesTest() {
        int deleted = repository.deleteRangesByDataRuleId(DATA_RULE_ID);
        flushAndClear();

        assertEquals(2, deleted);
        assertTrue(repository.retrieveRangeValues(DATA_RULE_ID).isEmpty());
    }
}
package com.optum.fads.pgp.datarules;

import static org.junit.jupiter.api.Assertions.assertEquals;
import static org.junit.jupiter.api.Assertions.assertTrue;

import java.util.List;

import org.junit.jupiter.api.BeforeEach;
import org.junit.jupiter.api.Test;
import org.springframework.beans.factory.annotation.Autowired;

import com.optum.fads.pgp.datarules.domain.PrmDrSingleValuesT;
import com.optum.fads.pgp.datarules.domain.PrmDrSingleValuesTPK;
import com.optum.fads.pgp.datarules.repo.DataRuleSingleValuesRepository;

class DataRuleSingleValuesRepositoryTest extends RepositoryJpaTestSupport {

    private static final int DATA_RULE_ID = 3001;

    @Autowired
    private DataRuleSingleValuesRepository repository;

    @BeforeEach
    void setUp() {
        var creator = persistUser("creator", "Test", "Creator");
        var updater = persistUser("updater", "Test", "Updater");
        var operator = persistOperator("EQ", "Equals");
        var mbMaster = persistMbMaster(601, 1, 1, "Gender");
        persistDataRule(DATA_RULE_ID, "Single Value Rule", creator, updater, operator, mbMaster);
        insertSingleValue(DATA_RULE_ID, "M", "Male");
        insertSingleValue(DATA_RULE_ID, "F", "Female");
        flushAndClear();
    }

    @Test
    void testGetCodeValues() {
        List<PrmDrSingleValuesT> result = repository.retrieveCodeValues(DATA_RULE_ID);

        assertEquals(2, result.size());
    }

    @Test
    void saveSingleValuesTest() {
        insertSingleValue(DATA_RULE_ID, "U", "Unknown");
        flushAndClear();

        List<PrmDrSingleValuesT> result = repository.retrieveCodeValues(DATA_RULE_ID);

        assertEquals(3, result.size());
        assertTrue(result.stream().anyMatch(value ->
                "U".equals(value.getId().getDrValue())
                        && "Unknown".equals(value.getDrLabel())));
    }

    @Test
    void deleteSingleValuesTest() {
        int deleted = repository.deleteSingleValuesByDataRuleId(DATA_RULE_ID);
        flushAndClear();

        assertEquals(2, deleted);
        assertTrue(repository.retrieveCodeValues(DATA_RULE_ID).isEmpty());
    }
}
