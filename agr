package com.optum.fads.casereminders.api.config;

import java.io.StringReader;
import java.security.KeyFactory;
import java.security.PrivateKey;
import java.security.Security;
import java.security.interfaces.RSAPrivateCrtKey;
import java.security.spec.RSAPrivateCrtKeySpec;

import org.bouncycastle.asn1.pkcs.PrivateKeyInfo;
import org.bouncycastle.jce.provider.BouncyCastleProvider;
import org.bouncycastle.openssl.PEMEncryptedKeyPair;
import org.bouncycastle.openssl.PEMParser;
import org.bouncycastle.openssl.PKCS8Generator;
import org.bouncycastle.openssl.jcajce.JcaPEMKeyConverter;
import org.bouncycastle.openssl.jcajce.JceOpenSSLPKCS8DecryptorProviderBuilder;
import org.bouncycastle.operator.InputDecryptorProvider;
import org.bouncycastle.pkcs.PKCS8EncryptedPrivateKeyInfo;
import org.slf4j.Logger;
import org.slf4j.LoggerFactory;

public class PemKeyLoader {

    private static final Logger logger = LoggerFactory.getLogger(PemKeyLoader.class);

    static {
        Security.addProvider(new BouncyCastleProvider());
    }

    public static PrivateKey loadPrivateKeyPem(String pemContent, char[] passphrase) throws Exception {
        try (PEMParser pemParser = new PEMParser(new StringReader(pemContent))) {
            Object pemObject = pemParser.readObject();
            PrivateKeyInfo privateKeyInfo = null;

            if (pemObject instanceof PKCS8EncryptedPrivateKeyInfo) {
                if (passphrase == null) {
                    throw new IllegalArgumentException("Encrypted PKCS#8 key but no passphrase provided.");
                }
                logger.info("Detected PKCS#8 encrypted private key.");
                PKCS8EncryptedPrivateKeyInfo encInfo = (PKCS8EncryptedPrivateKeyInfo) pemObject;
                InputDecryptorProvider decProv = new JceOpenSSLPKCS8DecryptorProviderBuilder().build(passphrase);
                privateKeyInfo = encInfo.decryptPrivateKeyInfo(decProv);

            } else if (pemObject instanceof PrivateKeyInfo) {
                logger.info("Detected unencrypted PKCS#8 private key.");
                privateKeyInfo = (PrivateKeyInfo) pemObject;

            } else if (pemObject instanceof PEMEncryptedKeyPair) {
                // If you have this format in your org, we can extend to decrypt it.
                throw new IllegalStateException("Old-format encrypted PEM key pair detected. Add support if needed.");

            } else {
                throw new IllegalStateException("Unsupported PEM content type: " +
                        (pemObject == null ? "null" : pemObject.getClass().getName()));
            }

            // Convert to BC PrivateKey
            JcaPEMKeyConverter converter = new JcaPEMKeyConverter().setProvider(BouncyCastleProvider.PROVIDER_NAME);
            PrivateKey bcKey = converter.getPrivateKey(privateKeyInfo);

            // Ensure it becomes a standard JDK RSA key (Snowflake typically expects RSA)
            KeyFactory keyFactory = KeyFactory.getInstance("RSA");
            RSAPrivateCrtKey rsaKey = (RSAPrivateCrtKey) bcKey;

            RSAPrivateCrtKeySpec keySpec = new RSAPrivateCrtKeySpec(
                    rsaKey.getModulus(),
                    rsaKey.getPublicExponent(),
                    rsaKey.getPrivateExponent(),
                    rsaKey.getPrimeP(),
                    rsaKey.getPrimeQ(),
                    rsaKey.getPrimeExponentP(),
                    rsaKey.getPrimeExponentQ(),
                    rsaKey.getCrtCoefficient()
            );

            return keyFactory.generatePrivate(keySpec);
        }
    }
}



package com.optum.fads.casereminders.api.config;

import java.security.PrivateKey;
import java.util.HashMap;
import java.util.Properties;

import javax.sql.DataSource;

import org.slf4j.Logger;
import org.slf4j.LoggerFactory;
import org.springframework.beans.factory.annotation.Qualifier;
import org.springframework.beans.factory.annotation.Value;
import org.springframework.boot.autoconfigure.EnableAutoConfiguration;
import org.springframework.boot.autoconfigure.jdbc.DataSourceAutoConfiguration;
import org.springframework.context.annotation.Bean;
import org.springframework.context.annotation.Configuration;
import org.springframework.data.jpa.repository.config.EnableJpaRepositories;
import org.springframework.jdbc.core.JdbcTemplate;
import org.springframework.jdbc.datasource.DriverManagerDataSource;
import org.springframework.orm.jpa.JpaTransactionManager;
import org.springframework.orm.jpa.LocalContainerEntityManagerFactoryBean;
import org.springframework.orm.jpa.vendor.HibernateJpaVendorAdapter;
import org.springframework.transaction.PlatformTransactionManager;
import org.springframework.transaction.annotation.EnableTransactionManagement;

import com.azure.security.keyvault.secrets.SecretClient;
import com.zaxxer.hikari.HikariDataSource;

import jakarta.persistence.EntityManagerFactory;
import net.snowflake.client.jdbc.SnowflakeBasicDataSource;

@Configuration
@EnableAutoConfiguration(exclude = { DataSourceAutoConfiguration.class })
@EnableTransactionManagement
@EnableJpaRepositories(
        entityManagerFactoryRef = "snfkEntityManagerFactory",
        transactionManagerRef = "txManagerSNFK",
        basePackages = { "com.optum.fads.casereminders.api.snowflakeRepo" } // <-- change if different
)
public class ServiceConfigSNFK {

    private static final Logger logger = LoggerFactory.getLogger(ServiceConfigSNFK.class);

    @Value("${spring.datasource.snfk.jdbcUrl}")
    private String url;

    // These should be *secret names* in Key Vault if you want everything in KV
    @Value("${spring.datasource.snfk.userName}")
    private String userName;

    @Value("${spring.datasource.snfk.password}")
    private String password;

    @Value("${spring.datasource.snfk.certKey:}")
    private String certKey;

    @Value("${spring.datasource.snfk.passphrase:}")
    private String passphrase;

    @Value("${spring.datasource.snfk.database:}")
    private String database;

    @Value("${spring.datasource.snfk.schema:}")
    private String schema;

    @Value("${spring.datasource.snfk.warehouse:}")
    private String warehouse;

    @Value("${spring.datasource.snfk.account:}")
    private String account;

    @Value("${spring.datasource.snfk.role:}")
    private String role;

    @Value("${db.snfk-login.useCert:false}")
    private Boolean useCert;

    private final SecretClient secretClient;

    public ServiceConfigSNFK(SecretClient secretClient) {
        this.secretClient = secretClient;
    }

    @Bean(name = "fadsSNFKDataSource")
    public DataSource snfkDataSource() throws Exception {

        if (Boolean.TRUE.equals(useCert)) {
            if (certKey == null || certKey.isBlank()) {
                throw new IllegalStateException("useCert=true but spring.datasource.snfk.certKey is empty");
            }

            logger.info("Snowflake login using certificate/private key from Key Vault secret.");

            // certKey contains secret NAME; secret value is PEM content
            String pemContent = secretClient.getSecret(certKey).getValue();

            // passphrase contains secret NAME; secret value is passphrase (optional)
            char[] passChars = null;
            if (passphrase != null && !passphrase.isBlank()) {
                String passValue = secretClient.getSecret(passphrase).getValue();
                if (passValue != null && !passValue.isBlank()) {
                    passChars = passValue.toCharArray();
                }
            }

            PrivateKey privateKey = PemKeyLoader.loadPrivateKeyPem(pemContent, passChars);

            // IMPORTANT: in cert flow, your 'userName' can be either actual user OR secret name.
            // To keep consistent with "all in KV", treat it as secret name:
            String sfUser = secretClient.getSecret(userName).getValue();

            SnowflakeBasicDataSource sf = new SnowflakeBasicDataSource();
            sf.setUrl(url);

            if (database != null && !database.isBlank()) sf.setDatabaseName(database);
            if (schema != null && !schema.isBlank()) sf.setSchema(schema);
            if (warehouse != null && !warehouse.isBlank()) sf.setWarehouse(warehouse);
            if (account != null && !account.isBlank()) sf.setAccount(account);
            if (role != null && !role.isBlank()) sf.setRole(role);

            sf.setUser(sfUser);
            sf.setPrivateKey(privateKey);

            HikariDataSource hikari = new HikariDataSource();
            hikari.setDataSource(sf);
            return hikari;

        } else {
            logger.info("Snowflake login using username + password from Key Vault secrets.");

            String sfUser = secretClient.getSecret(userName).getValue();
            String sfPass = secretClient.getSecret(password).getValue();

            Properties props = new Properties();
            props.put("user", sfUser);
            props.put("password", sfPass);

            if (database != null && !database.isBlank()) props.put("database", database);
            if (schema != null && !schema.isBlank()) props.put("schema", schema);
            if (warehouse != null && !warehouse.isBlank()) props.put("warehouse", warehouse);
            if (role != null && !role.isBlank()) props.put("role", role);
            if (account != null && !account.isBlank()) props.put("account", account);

            return new DriverManagerDataSource(url, props);
        }
    }

    @Bean(name = "snfkEntityManagerFactory")
    public LocalContainerEntityManagerFactoryBean snfkEntityManagerFactory(
            @Qualifier("fadsSNFKDataSource") DataSource ds) throws Exception {

        LocalContainerEntityManagerFactoryBean em = new LocalContainerEntityManagerFactoryBean();
        em.setDataSource(ds);

        em.setPackagesToScan("com.optum.fads.casereminders.api.snowflakeDomain"); // <-- change if different

        HibernateJpaVendorAdapter vendorAdapter = new HibernateJpaVendorAdapter();
        em.setJpaVendorAdapter(vendorAdapter);

        HashMap<String, Object> properties = new HashMap<>();
        properties.put("hibernate.allow_update_outside_transaction", true);
        properties.put("hibernate.dialect", "com.optum.fads.casereminders.api.config.SnowflakeDialect");
        em.setJpaPropertyMap(properties);

        return em;
    }

    @Bean(name = "txManagerSNFK")
    public PlatformTransactionManager txManagerSNFK(
            @Qualifier("snfkEntityManagerFactory") EntityManagerFactory snfkEntityManagerFactory) {

        JpaTransactionManager txManager = new JpaTransactionManager();
        // FIX: use injected EMF (don’t call method again)
        txManager.setEntityManagerFactory(snfkEntityManagerFactory);
        return txManager;
    }

    @Bean(name = "jdbcSnowflake")
    public JdbcTemplate snowflakeJdbcTemplate(@Qualifier("fadsSNFKDataSource") DataSource ds) {
        return new JdbcTemplate(ds);
    }
}


package com.optum.fads.casereminders.api.config;

import javax.sql.DataSource;

import org.springframework.beans.factory.annotation.Qualifier;
import org.springframework.beans.factory.annotation.Value;
import org.springframework.boot.autoconfigure.EnableAutoConfiguration;
import org.springframework.boot.autoconfigure.jdbc.DataSourceAutoConfiguration;
import org.springframework.context.annotation.Bean;
import org.springframework.context.annotation.Configuration;
import org.springframework.data.jpa.repository.config.EnableJpaRepositories;
import org.springframework.jdbc.datasource.DriverManagerDataSource;
import org.springframework.orm.jpa.JpaTransactionManager;
import org.springframework.orm.jpa.LocalContainerEntityManagerFactoryBean;
import org.springframework.orm.jpa.vendor.HibernateJpaVendorAdapter;
import org.springframework.transaction.PlatformTransactionManager;
import org.springframework.transaction.annotation.EnableTransactionManagement;

import com.azure.security.keyvault.secrets.SecretClient;

import jakarta.persistence.EntityManagerFactory;

@Configuration
@EnableAutoConfiguration(exclude = { DataSourceAutoConfiguration.class })
@EnableTransactionManagement
@EnableJpaRepositories(
        entityManagerFactoryRef = "sqlEntityManagerFactory",
        transactionManagerRef = "txManagerSQL",
        basePackages = "com.optum.fads.casereminders.api.repo"
)
public class ServiceConfigSQL {

    @Value("${spring.datasource.sql.userName}")
    private String userName;

    @Value("${spring.datasource.sql.password}")
    private String password;

    @Value("${spring.datasource.sql.jdbcUrl}")
    private String url;

    @Value("${spring.datasource.sql.driverClassName}")
    private String driverClassName;

    private final SecretClient secretClient;

    public ServiceConfigSQL(SecretClient secretClient) {
        this.secretClient = secretClient;
    }

    @Bean(name = "fadsSQLDataSource")
    public DataSource fadsSQLDataSource() {
        String userNameValue = secretClient.getSecret(userName).getValue();
        String passwordValue = secretClient.getSecret(password).getValue();

        DriverManagerDataSource dataSource = new DriverManagerDataSource();
        dataSource.setDriverClassName(driverClassName);
        dataSource.setUsername(userNameValue);
        dataSource.setPassword(passwordValue);
        dataSource.setUrl(url);

        return dataSource;
    }

    @Bean(name = "sqlEntityManagerFactory")
    public LocalContainerEntityManagerFactoryBean sqlEntityManagerFactory(
            @Qualifier("fadsSQLDataSource") DataSource ds) {

        LocalContainerEntityManagerFactoryBean em = new LocalContainerEntityManagerFactoryBean();
        em.setDataSource(ds);
        em.setPackagesToScan("com.optum.fads.casereminders.api.domain");

        HibernateJpaVendorAdapter vendorAdapter = new HibernateJpaVendorAdapter();
        em.setJpaVendorAdapter(vendorAdapter);
        return em;
    }

    @Bean(name = "txManagerSQL")
    public PlatformTransactionManager txManagerSQL(
            @Qualifier("sqlEntityManagerFactory") EntityManagerFactory sqlEntityManagerFactory) {

        JpaTransactionManager txManager = new JpaTransactionManager();
        // FIX: use injected EMF (don’t call method again)
        txManager.setEntityManagerFactory(sqlEntityManagerFactory);
        return txManager;
    }
}


server:
  port: 8080
  servlet:
    contextPath: /casereminders

quickstart:
  generateOrderPeriod: 10s
  processOrderPeriod: 30s

spring:
  application:
    name: casereminders

  cloud:
    azure:
      keyvault:
        secrets:
          endpoint: ${AZURE_KV_URL}
        credential:
          client-id: ${AZURE_KV_CLIENT_ID}
          client-secret: ${AZURE_KV_CLIENT_SECRET}
          tenant-id: ${AZURE_TENANT_ID}

  # If you are using 2 EntityManagerFactories (SQL + SNFK), keep JPA settings minimal/global here.
  jpa:
    show-sql: false
    properties:
      hibernate:
        format_sql: true
        globally_quoted_identifiers: true

  datasource:
    hikari:
      maximum-pool-size: ${MAXIMUM_DB_POOL_SIZE:50}
      minimum-idle: ${MIN_POOL_IDLE:1}
      connection-timeout: ${DB_CONNECTION_TIMEOUT:60000}
      idle-timeout: ${DB_POOL_IDLE_TIMEOUT:60000}
      leak-detection-threshold: ${LEAK_DETETCTION_THRESHOLD:0}

    # ------------------------------------------------------------
    # SQL SERVER (values below are SECRET NAMES in KeyVault)
    # ------------------------------------------------------------
    sql:
      type: com.zaxxer.hikari.HikariDataSource
      jdbcUrl: ${DB_URL}
      userName: ${DB_USR}            # KeyVault secret name (ex: sql-admin-user)
      password: ${DB_PWD}            # KeyVault secret name (ex: sql-admin-password)
      driverClassName: com.microsoft.sqlserver.jdbc.SQLServerDriver

      # optional (only if you read these in code / bind)
      jpa:
        database-platform: org.hibernate.dialect.SQLServer2016Dialect
        database: SQL_SERVER
        show-sql: false
        hibernate:
          naming:
            implicit-strategy: org.hibernate.boot.model.naming.ImplicitNamingStrategyLegacyHbmImpl
            physical-strategy: org.springframework.boot.orm.jpa.hibernate.SpringPhysicalNamingStrategy

    # ------------------------------------------------------------
    # SNOWFLAKE (values below are SECRET NAMES in KeyVault)
    # ------------------------------------------------------------
    snfk:
      type: com.zaxxer.hikari.HikariDataSource
      driver-class-name: net.snowflake.client.jdbc.SnowflakeDriver

      # JDBC URL (usually contains account host). Keep it in env var.
      jdbcUrl: ${SNFK_DB_URL}

      # Snowflake logical settings (plain values, not secrets)
      database: ${SNFK_DATABASE}
      schema: ${SNFK_SCHEMA}
      warehouse: ${SNFK_WAREHOUSE}
      role: ${SNFK_ROLE:}
      account: ${SNFK_ACCOUNT:}

      # ---- login (both flows use KeyVault secret NAMES) ----
      # For USE_CERT=false: these two must exist
      userName: ${SNFK_USR}          # KeyVault secret name containing the Snowflake username value
      password: ${SNFK_PWD}          # KeyVault secret name containing the Snowflake password value

      # For USE_CERT=true: these two must exist
      certKey: ${SNFK_CERT_KEY:}         # KeyVault secret name containing PEM content (private key)
      passphrase: ${SNFK_CERT_PASSPHRASE:} # KeyVault secret name containing passphrase (optional)

      jpa:
        database-platform: com.optum.fads.casereminders.api.config.SnowflakeDialect
        database: default
        show-sql: false
        hibernate:
          naming:
            implicit-strategy: org.hibernate.boot.model.naming.ImplicitNamingStrategyLegacyHbmImpl
            physical-strategy: org.springframework.boot.orm.jpa.hibernate.SpringPhysicalNamingStrategy

  quartz:
    properties:
      org:
        quartz:
          threadPool:
            class: org.quartz.simpl.SimpleThreadPool
            threadCount: 3

management:
  endpoint:
    metrics:
      enabled: true
    prometheus:
      enabled: true
  endpoints:
    web:
      exposure:
        include:
          - health
          - info
          - prometheus
  prometheus:
    metrics:
      export:
        enabled: true

# Toggle Snowflake auth mode:
# - false => username/password flow
# - true  => certificate/private key PEM flow
db:
  snfk-login:
    useCert: ${USE_CERT:false}

# Optional security block (keep if you need it)
