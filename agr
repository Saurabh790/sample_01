    @Test
    void loadUserByUsernameThrowsWhenUserMissing() {
        when(userRepository.findByUiEMailAddressOrUiUserId("missing", "missing")).thenReturn(Optional.empty());

        UsernameNotFoundException ex =
                assertThrows(UsernameNotFoundException.class, () -> userDetailsService.loadUserByUsername("missing"));

        assertTrue(ex.getMessage().contains("missing"));
        verify(userDetailMapper, never()).toAppUser(org.mockito.ArgumentMatchers.any());
    }

    @Test
    void loadUserByUsernameMapsCaseRoleModulesAndNodes() {
        UiUserBase userEntity = new UiUserBase();
        userEntity.setUiSystemId("SYS1");
        userEntity.setUiUserId("user1");
        userEntity.setUiEMailAddress("user1@test.com");

        SeUsrGrp userGroup = new SeUsrGrp();
        SeCaseGrp caseGroup = new SeCaseGrp();
        caseGroup.setId(BigDecimal.valueOf(21));
        caseGroup.setCaseGrpName("Auditor");
        userGroup.setSeCaseGrp(caseGroup);
        userEntity.setSeUsrGrp(userGroup);

        caseGroup.setSeCaseGrpModAccesses(List.of(
                moduleAccess("RX", "Pharmacy", BigDecimal.valueOf(1), "M1", "Module One", "RW"),
                moduleAccess("RX", "Pharmacy", BigDecimal.valueOf(2), "M2", "Module Two", "R"),
                moduleAccess("MED", "Medical", BigDecimal.valueOf(3), "M3", "Module Three", "RW")));
        caseGroup.setSeCaseGrpNodeAccesses(List.of(nodeAccess(caseGroup.getId(), "N101", "RW", "Y", "N")));

        AppUser mappedUser = new AppUser();
        mappedUser.setUserSystemId("SYS1");
        mappedUser.setRole(new com.optum.fads.caseclaimcorrections.api.dto.Role());

        when(userRepository.findByUiEMailAddressOrUiUserId("user1", "user1")).thenReturn(Optional.of(userEntity));
        when(userDetailMapper.toAppUser(userEntity)).thenReturn(mappedUser);

        AppUser result = (AppUser) userDetailsService.loadUserByUsername("user1");

        assertEquals("SYS1", result.getUsername());
        CaseRole caseRole = result.getRole().getCaseRole();
        assertNotNull(caseRole);
        assertEquals(BigDecimal.valueOf(21), caseRole.getGroupId());
        assertEquals("Auditor", caseRole.getRoleName());
        assertEquals(2, caseRole.getCaseTypeModules().size());
        assertEquals(1, caseRole.getNodePermissions().size());
        assertTrue(caseRole.getCaseTypeModules().stream().anyMatch(ctm ->
                "RX".equals(ctm.getCaseTypeId()) && ctm.getModulePermissions().size() == 2));
        assertTrue(caseRole.getCaseTypeModules().stream().anyMatch(ctm ->
                "MED".equals(ctm.getCaseTypeId()) && ctm.getModulePermissions().size() == 1));
        assertTrue(caseRole.getNodePermissions().stream().anyMatch(node ->
                "N101".equals(node.getNodeId())
                        && "RW".equals(node.getNodeAccess())
                        && "Y".equals(node.getRestrictAccess())
                        && "N".equals(node.getDeleteAccess())));
    }

    @Test
    void loadUserByUsernameLeavesMappedUserUntouchedWhenNoCaseGroupExists() {
        UiUserBase userEntity = new UiUserBase();
        SeUsrGrp userGroup = new SeUsrGrp();
        userEntity.setSeUsrGrp(userGroup);
        AppUser mappedUser = new AppUser();
        mappedUser.setRole(new com.optum.fads.caseclaimcorrections.api.dto.Role());

        when(userRepository.findByUiEMailAddressOrUiUserId("plain", "plain")).thenReturn(Optional.of(userEntity));
        when(userDetailMapper.toAppUser(userEntity)).thenReturn(mappedUser);

        AppUser result = (AppUser) userDetailsService.loadUserByUsername("plain");

        assertEquals(mappedUser, result);
        assertNull(result.getRole().getCaseRole());
    }

    private static SeCaseGrpModAccess moduleAccess(
            String typeCd,
            String typeDesc,
            BigDecimal moduleId,
            String moduleCd,
            String moduleName,
            String accessId) {
        CaLuCaseTypeT caseType = new CaLuCaseTypeT();
        caseType.setTypeCd(typeCd);
        caseType.setTypeDesc(typeDesc);

        SeCaseModule module = new SeCaseModule();
        module.setId(moduleId);
        module.setCaseModuleCd(moduleCd);
        module.setCaseModuleName(moduleName);

        SeCaseAccess access = new SeCaseAccess();
        access.setAccessId(accessId);

        SeCaseGrpModAccess grpModAccess = new SeCaseGrpModAccess();
        grpModAccess.setCaLuCaseTypeT(caseType);
        grpModAccess.setSeCaseModule(module);
        grpModAccess.setSeCaseAccess(access);
        return grpModAccess;
    }

    private static SeCaseGrpNodeAccess nodeAccess(
            BigDecimal caseGroupId,
            String nodeId,
            String accessId,
            String restrictAccess,
            String deleteAccess) {
        SeCaseAccess access = new SeCaseAccess();
        access.setAccessId(accessId);

        SeCaseGrpNodeAccessId id = new SeCaseGrpNodeAccessId();
        id.setCaseGrpId(caseGroupId);
        id.setCaseNodeId(nodeId);

        SeCaseGrpNodeAccess nodeAccess = new SeCaseGrpNodeAccess();
        nodeAccess.setId(id);
        nodeAccess.setSeCaseAccess(access);
        nodeAccess.setAnyRestrictApply(restrictAccess);
        nodeAccess.setCanDeleteCases(deleteAccess);
        return nodeAccess;
    }
}
