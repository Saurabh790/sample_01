     */
    @Override
    public synchronized Integer saveCaseDetail(CaIntelligentKeyT caIntelligentKeyT, Integer id, CaseDetailDTO caseDto) throws CaseException {
        logger.info(" CaseDetailDAO saveCaseDetail starts");

        try {
            Session session = getCurrentSession();
    
                Integer caseId = caIntelligentKeyT.getCaseId();

                if (caseId <= 0) {
                    caseId = (Integer) session.createQuery(" select max(model.caseId) from CaIntelligentKeyT model ").uniqueResult();
                    if (caseId == null) {
                        caseId = 0;
                    }
                    caseId = caseId + 1;
                    caIntelligentKeyT.setCaseId(caseId);
                    Criteria criteria = session.createCriteria(CaIntelligentKeyT.class);
                    criteria.setProjection(Projections.max("caSequenceId"));
                    criteria.add(Restrictions.eq("caLuPrmNodeT.nodeCd", caIntelligentKeyT.getCaLuPrmNodeT().getNodeCd()));

                    if (CaseGlobalConstants.SCND_NODE_VISIBLE.equalsIgnoreCase("Y")) {
                        criteria.add(Restrictions.eq("caLuScndNodeT.nodeCd", caIntelligentKeyT.getCaLuScndNodeT().getNodeCd()));
                    }
                    criteria.add(Restrictions.eq("caYearId", caIntelligentKeyT.getCaYearId()));
                    Integer sequenceId = (Integer) criteria.uniqueResult();
                    if (sequenceId == null) {
                        sequenceId = 0;
                    }
                    caIntelligentKeyT.setCaSequenceId(++sequenceId);
                }

                session.saveOrUpdate(caIntelligentKeyT);

                saveGeneralAndCaseType(caIntelligentKeyT, caseId, session);

                investHelper.loadPreliminaryHistory(session, caIntelligentKeyT, caseId);
                savePreliminary(caIntelligentKeyT, id, caseId, session);
            savePreliminaryHistory(caIntelligentKeyT, id, caseId, session);

                investHelper.loadFullscaleHistory(session, caIntelligentKeyT, caseId);
                saveFullscale(caIntelligentKeyT, id, caseId, session);
            saveFullscaleHistory(caIntelligentKeyT, id, caseId, session);

				saveNotes(caIntelligentKeyT,id, caseId, session);
				saveReminders(caIntelligentKeyT,id, caseId, session);
		//		saveNotesAndReminders(caIntelligentKeyT,id, caseId, session);
				saveFinancials(caIntelligentKeyT,caseId, session);

                if (caseDto.isJobsChange()) {
                    //logger.debug("CaseDetailDAO to saveSur");
                    saveSur(caIntelligentKeyT, id, caseId, session);
                }
                if (caseDto.isAlgorithmsChange()) {
                    saveAnalytic(caIntelligentKeyT, id, caseId, session);
                }
                if (caseDto.isFilesChange()) {
                    saveFiles(caIntelligentKeyT, id, caseId, session);
                }
                if (caseDto.isAppealsVisited()) {
                    //logger.debug("CaseDetailDAO - saveCaseDetail - AppealsVisited");
                    appealHistoryHelper.loadAppealHistory(session, caIntelligentKeyT, caseId);
                    saveAppeals(caIntelligentKeyT, id, caseId, session);
                    saveAppealHistory(caIntelligentKeyT, caseId, session);
                }
                if (caseDto.isAssociationsChange()) {
                    saveAssociations(caIntelligentKeyT, id, caseId, session);
                }
                if (caseDto.isContactsChange()) {
                    saveReferences(caIntelligentKeyT, id, caseId, session);
                }

				//saveSurAndAnalytics(caIntelligentKeyT,id,caseId, session);

				saveFinancialHistory(caIntelligentKeyT, id, caseId, session);
				
				specialInfoHistoryHelper.loadSpecialInfoHistory(session, caIntelligentKeyT, caseId);
				saveSpecialInfo(caIntelligentKeyT, id, caseId, session);
				saveSpecialInfoHistory(caIntelligentKeyT, id, caseId, session);

                id = caseId;
                logger.debug("saveCaseDetail()");
            } catch (HibernateException he) {

                //System.out.println(he);
                logger.error("Exception in CaseDetailDAO :: saveCaseDetail()", he);

                throw new CaseException(he);
            } catch (RuntimeException e) {

            	  throw new CaseException(e);
           
        } catch (Exception re) {
            logger.error("attach failed", re);
            throw re;
        }
        return id;
    }

    private void saveSpecialInfoHistory(CaIntelligentKeyT caIntelligentKeyT, Integer id, Integer caseId,
    		Session session) throws HistoryException {
    	try{
    		Iterator<CaSpecialInfoHistT> caSpecialInfoHistTs = caIntelligentKeyT.getCaSpecialInfoHistTs().iterator();
    		while (caSpecialInfoHistTs.hasNext()) {
    			CaSpecialInfoHistT caSpecialInfoHistT = (CaSpecialInfoHistT) caSpecialInfoHistTs.next();
    			caSpecialInfoHistT.getId().setCaseId(caseId);
    			session.saveOrUpdate(caSpecialInfoHistT);
    		}
    	} catch (HibernateException e) {

    		logger.error("Error at  CaseDetailDAO saveSpecialInfoHistory:" + e);
    		throw new HistoryException("Error at saveSpecialInfoHistory" + e);
    	} catch (RuntimeException e) {
    		throw e;
    		//e.printStackTrace();
    	} finally {
    		session.flush();
    		session.clear();
    	}
    	 
		
	}

