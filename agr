package com.optum.fads.pgp.study.api.repo.specs;

import com.optum.fads.pgp.study.common.util.StudyConstants;
import com.optum.fads.pgp.study.common.util.StudyEnum;
import com.optum.fads.pgp.study.domain.PrmStudyMasterT;
import com.optum.fads.pgp.study.domain.UiUserBase;
import com.optum.fads.pgp.study.repo.specs.StudySpecification;
import jakarta.persistence.criteria.CriteriaBuilder;
import jakarta.persistence.criteria.CriteriaQuery;
import jakarta.persistence.criteria.Expression;
import jakarta.persistence.criteria.Join;
import jakarta.persistence.criteria.Path;
import jakarta.persistence.criteria.Predicate;
import jakarta.persistence.criteria.Root;
import org.junit.jupiter.api.Test;
import org.springframework.data.jpa.domain.Specification;

import java.util.LinkedHashMap;
import java.util.Map;

import static org.junit.jupiter.api.Assertions.assertNotNull;
import static org.mockito.ArgumentMatchers.any;
import static org.mockito.ArgumentMatchers.eq;
import static org.mockito.Mockito.mock;
import static org.mockito.Mockito.verify;
import static org.mockito.Mockito.when;

class StudySpecificationTest {

    @Test
    @SuppressWarnings({"rawtypes", "unchecked"})
    void findAllStudySpecification_withNullFilterOptions_returnsRestrictionFromEmptyPredicateList() {
        Specification<PrmStudyMasterT> specification = StudySpecification.findAllStudySpecification(null);

        Root root = mock(Root.class);
        CriteriaQuery query = mock(CriteriaQuery.class);
        CriteriaBuilder criteriaBuilder = mock(CriteriaBuilder.class);
        Predicate restriction = mock(Predicate.class);

        when(query.where(any(Predicate[].class))).thenReturn(query);
        when(query.getRestriction()).thenReturn(restriction);

        Predicate result = specification.toPredicate(root, query, criteriaBuilder);

        assertNotNull(result);
        verify(query).where(any(Predicate[].class));
        verify(query).getRestriction();
    }

    @Test
    @SuppressWarnings({"rawtypes", "unchecked"})
    void findAllStudySpecification_withStudyNameCreatedUserUpdatedUserAndMyItems_buildsExpectedPredicates() {
        Map<String, String> filterOptions = new LinkedHashMap<>();
        filterOptions.put(StudyEnum.studyName.name(), "Cancerspch2bStudy%20Aspch2c1");
        filterOptions.put(StudyEnum.createdUser.name(), "John");
        filterOptions.put(StudyEnum.updatedUser.name(), "Jane");
        filterOptions.put(StudyConstants.USER_SYSTEM_ID, "user123");

        Specification<PrmStudyMasterT> specification = StudySpecification.findAllStudySpecification(filterOptions);

        Root root = mock(Root.class);
        CriteriaQuery query = mock(CriteriaQuery.class);
        CriteriaBuilder criteriaBuilder = mock(CriteriaBuilder.class);
        Predicate finalRestriction = mock(Predicate.class);

        Path studyNamePath = mock(Path.class);
        Expression loweredStudyName = mock(Expression.class);

        Join createdByJoin = mock(Join.class);
        Join updatedByJoin = mock(Join.class);
        Path createdUserFullName = mock(Path.class);
        Expression loweredCreatedUser = mock(Expression.class);
        Path updatedUserFullName = mock(Path.class);
        Expression loweredUpdatedUser = mock(Expression.class);
        Path createdUserSystemId = mock(Path.class);
        Path updatedUserSystemId = mock(Path.class);

        Predicate studyNamePredicate = mock(Predicate.class);
        Predicate createdUserPredicate = mock(Predicate.class);
        Predicate updatedUserPredicate = mock(Predicate.class);
        Predicate createdUserIdPredicate = mock(Predicate.class);
        Predicate updatedUserIdPredicate = mock(Predicate.class);
        Predicate myItemsPredicate = mock(Predicate.class);

        when(root.get("pbName")).thenReturn(studyNamePath);
        when(criteriaBuilder.lower(studyNamePath)).thenReturn(loweredStudyName);
        when(criteriaBuilder.like(loweredStudyName, "%cancer+study a,1%", '/')).thenReturn(studyNamePredicate);

        when(root.join("createdByUiUserBase")).thenReturn(createdByJoin);
        when(root.join("updatedByUiUserBase")).thenReturn(updatedByJoin);

        when(createdByJoin.get("userFullName")).thenReturn(createdUserFullName);
        when(criteriaBuilder.lower(createdUserFullName)).thenReturn(loweredCreatedUser);
        when(criteriaBuilder.like(loweredCreatedUser, "%john%", '/')).thenReturn(createdUserPredicate);

        when(updatedByJoin.get("userFullName")).thenReturn(updatedUserFullName);
        when(criteriaBuilder.lower(updatedUserFullName)).thenReturn(loweredUpdatedUser);
        when(criteriaBuilder.like(loweredUpdatedUser, "%jane%", '/')).thenReturn(updatedUserPredicate);

        when(createdByJoin.get("uiSystemId")).thenReturn(createdUserSystemId);
        when(updatedByJoin.get("uiSystemId")).thenReturn(updatedUserSystemId);
        when(criteriaBuilder.equal(createdUserSystemId, "user123")).thenReturn(createdUserIdPredicate);
        when(criteriaBuilder.equal(updatedUserSystemId, "user123")).thenReturn(updatedUserIdPredicate);
        when(criteriaBuilder.or(createdUserIdPredicate, updatedUserIdPredicate)).thenReturn(myItemsPredicate);

        when(query.where(any(Predicate[].class))).thenReturn(query);
        when(query.getRestriction()).thenReturn(finalRestriction);

        Predicate result = specification.toPredicate(root, query, criteriaBuilder);

        assertNotNull(result);
        verify(criteriaBuilder).like(loweredStudyName, "%cancer+study a,1%", '/');
        verify(criteriaBuilder).like(loweredCreatedUser, "%john%", '/');
        verify(criteriaBuilder).like(loweredUpdatedUser, "%jane%", '/');
        verify(criteriaBuilder).equal(createdUserSystemId, "user123");
        verify(criteriaBuilder).equal(updatedUserSystemId, "user123");
        verify(criteriaBuilder).or(createdUserIdPredicate, updatedUserIdPredicate);
        verify(query).where(any(Predicate[].class));
        verify(query).getRestriction();
    }

    @Test
    @SuppressWarnings({"rawtypes", "unchecked"})
    void findAllStudySpecification_withStudyNameContainingSlashUnderscoreAndPercent_escapesSpecialCharacters() {
        Map<String, String> filterOptions = new LinkedHashMap<>();
        filterOptions.put(StudyEnum.studyName.name(), "A/B_C%");

        Specification<PrmStudyMasterT> specification = StudySpecification.findAllStudySpecification(filterOptions);

        Root root = mock(Root.class);
        CriteriaQuery query = mock(CriteriaQuery.class);
        CriteriaBuilder criteriaBuilder = mock(CriteriaBuilder.class);
        Predicate restriction = mock(Predicate.class);

        Path studyNamePath = mock(Path.class);
        Expression loweredStudyName = mock(Expression.class);
        Predicate studyNamePredicate = mock(Predicate.class);

        when(root.get("pbName")).thenReturn(studyNamePath);
        when(criteriaBuilder.lower(studyNamePath)).thenReturn(loweredStudyName);
        when(criteriaBuilder.like(loweredStudyName, "%a//b/_c/%%", '/')).thenReturn(studyNamePredicate);
        when(query.where(any(Predicate[].class))).thenReturn(query);
        when(query.getRestriction()).thenReturn(restriction);

        Predicate result = specification.toPredicate(root, query, criteriaBuilder);

        assertNotNull(result);
        verify(criteriaBuilder).like(loweredStudyName, "%a//b/_c/%%", '/');
    }
}
