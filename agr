    @Test
    public void testFindAll_shouldReturnPageOfStudies() {

        List<String> searchKeys = List.of("studyName");
        List<String> searchValues = List.of("Cancer Research");

        Map<String, String> expectedMap = Map.of("studyName", "Cancer Research");
        String sortValue = StudySortEnum.valueOf(StudyEnum.studyName.name()).value;

        Pageable expectedPageable = PageRequest.of(0, Integer.MAX_VALUE, Sort.by(Sort.Order.desc(sortValue).ignoreCase()));


        Study study = Study.builder()
                .studyId(1L)
                .studyName("Cancer Research")
                .build();

        Page<Study> expectedPage = new PageImpl<>(List.of(study));

        when(studyService.findAllStudies(expectedMap, expectedPageable)).thenReturn(expectedPage);

        Page<Study> result = studyController.findAll(StudyEnum.studyName, SortOrder.desc, searchKeys, searchValues);

        assertThat(result, is(equalTo(expectedPage)));
    }


    @Test
    public void testFindAllByPageable_shouldReturnPageOfStudies() {

        int pageNumber = 1;
        int recordsPerPage = 10;
        StudyEnum sortBy = StudyEnum.studyName;
        Integer sortOrder = 1; // Assuming 1 = asc
        List<String> searchKeys = List.of("studyName");
        String searchInput = "Cancer Research";

