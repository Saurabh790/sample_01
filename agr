    @Test
    public void getCaseIndValueUsesRepositoryValuesWhenPresent() {
        when(caIntelligentKeyRepository.getNextCaseId()).thenReturn(42);
        when(caIntelligentKeyRepository.getNextSequenceId("PAU", (short) 2024)).thenReturn(7);

        CaseBaseInfo result = caseBatchIndividualService.getCaseIndValue("PAU", 2024, "P100");

        assertEquals(Integer.valueOf(42), result.getCaseId());
        assertEquals(Integer.valueOf(7), result.getSequenceId());
        assertEquals("PAU-2024-00007", result.getCaseIdStr());
        assertEquals("P100", result.getParticpantId());
    }

    @Test
    public void getCaseIndValueFallsBackToOneWhenRepositoryReturnsNull() {
        when(caIntelligentKeyRepository.getNextCaseId()).thenReturn(null);
        when(caIntelligentKeyRepository.getNextSequenceId("PAU", (short) 2024)).thenReturn(null);

        CaseBaseInfo result = caseBatchIndividualService.getCaseIndValue("PAU", 2024, "P100");

        assertEquals(Integer.valueOf(1), result.getCaseId());
        assertEquals(Integer.valueOf(1), result.getSequenceId());
        assertEquals("PAU-2024-00001", result.getCaseIdStr());
    }

