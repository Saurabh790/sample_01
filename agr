package com.optum.fads.caseentrybatch.api.config;

import static org.junit.Assert.assertEquals;
import static org.junit.Assert.assertNotNull;
import static org.junit.Assert.assertTrue;
import static org.mockito.Mockito.mock;
import static org.mockito.Mockito.when;

import javax.sql.DataSource;

import org.junit.Before;
import org.junit.Test;
import org.springframework.jdbc.datasource.DriverManagerDataSource;
import org.springframework.orm.jpa.JpaTransactionManager;
import org.springframework.orm.jpa.LocalContainerEntityManagerFactoryBean;
import org.springframework.test.util.ReflectionTestUtils;

import com.azure.security.keyvault.secrets.SecretClient;
import com.azure.security.keyvault.secrets.models.KeyVaultSecret;

import jakarta.persistence.EntityManagerFactory;

public class ServiceConfigSQLTest {

    private SecretClient secretClient;
    private ServiceConfigSQL serviceConfigSQL;

    @Before
    public void setUp() {
        secretClient = mock(SecretClient.class);
        serviceConfigSQL = new ServiceConfigSQL(secretClient);

        ReflectionTestUtils.setField(serviceConfigSQL, "userName", "sql-username-secret");
        ReflectionTestUtils.setField(serviceConfigSQL, "password", "sql-password-secret");
        ReflectionTestUtils.setField(serviceConfigSQL, "url", "jdbc:sqlserver://localhost:1433;databaseName=testdb");
        ReflectionTestUtils.setField(serviceConfigSQL, "driverClassName", "com.microsoft.sqlserver.jdbc.SQLServerDriver");

        when(secretClient.getSecret("sql-username-secret")).thenReturn(new KeyVaultSecret("sql-username-secret", "db_user"));
        when(secretClient.getSecret("sql-password-secret")).thenReturn(new KeyVaultSecret("sql-password-secret", "db_password"));
    }

    @Test
    public void fadsSQLDataSourceBuildsDriverManagerDataSourceFromSecrets() {
        DataSource dataSource = serviceConfigSQL.fadsSQLDataSource();

        assertNotNull(dataSource);
        assertTrue(dataSource instanceof DriverManagerDataSource);

        DriverManagerDataSource driverManagerDataSource = (DriverManagerDataSource) dataSource;
        assertEquals("com.microsoft.sqlserver.jdbc.SQLServerDriver", driverManagerDataSource.getDriverClassName());
        assertEquals("db_user", driverManagerDataSource.getUsername());
        assertEquals("db_password", driverManagerDataSource.getPassword());
        assertEquals("jdbc:sqlserver://localhost:1433;databaseName=testdb", driverManagerDataSource.getUrl());
    }

    @Test
    public void sqlEntityManagerFactoryUsesConfiguredDataSourceAndPackages() {
        LocalContainerEntityManagerFactoryBean entityManagerFactoryBean = serviceConfigSQL.sqlEntityManagerFactory();

        assertNotNull(entityManagerFactoryBean);
        assertNotNull(entityManagerFactoryBean.getDataSource());
        assertNotNull(entityManagerFactoryBean.getJpaVendorAdapter());
        String[] packagesToScan = (String[]) ReflectionTestUtils.getField(entityManagerFactoryBean, "packagesToScan");
        assertNotNull(packagesToScan);
        assertEquals("com.optum.fads.caseentrybatch.api.domain", packagesToScan[0]);
    }

    @Test
    public void txManagerSQLReturnsJpaTransactionManager() {
        EntityManagerFactory entityManagerFactory = mock(EntityManagerFactory.class);

        JpaTransactionManager transactionManager = (JpaTransactionManager) serviceConfigSQL.txManagerSQL(entityManagerFactory);

        assertNotNull(transactionManager);
    }
}



