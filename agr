package com.optum.fads.caseclaimcorrections.api.util;

import static org.junit.jupiter.api.Assertions.assertEquals;
import static org.junit.jupiter.api.Assertions.assertTrue;

import java.math.BigDecimal;
import java.util.Date;

import org.junit.jupiter.api.Test;

import com.optum.fads.caseclaimcorrections.api.entity.CaClaimCorrectionsT;

class CaClaimCorrectionsComparatorTest {

    private final CaClaimCorrectionsComparator comparator = new CaClaimCorrectionsComparator();

    @Test
    void compareHandlesNullSides() {
        assertEquals(1, comparator.compare(new CaClaimCorrectionsT(), null));
        assertEquals(1, comparator.compare(null, new CaClaimCorrectionsT()));
        assertEquals(0, comparator.compare(null, null));
    }

    @Test
    void compareUsesClaimFieldsWhenBothObjectsExist() {
        CaClaimCorrectionsT left = buildCorrection("A", "1", "ABC");
        CaClaimCorrectionsT right = buildCorrection("B", "1", "ABC");

        int result = comparator.compare(left, right);

        assertTrue(result < 0);
    }

    private static CaClaimCorrectionsT buildCorrection(String tcn, String liNum, String findingsCode) {
        CaClaimCorrectionsT correction = new CaClaimCorrectionsT();
        correction.setHdrClmTcn(tcn);
        correction.setLiNum(liNum);
        correction.setHdrClmPdDt(new Date());
        correction.setLiDrugNdc("12345678901");
        correction.setLiPdUosQty(BigDecimal.ONE);
        correction.setLiDrugDosageFormDesc("TAB");
        correction.setLiDrugDaysSupply(BigDecimal.TEN);
        correction.setHdrDrugDispensingFee(BigDecimal.ONE);
        correction.setHdrPdAmt(BigDecimal.TEN);
        correction.setHdrCopayAmt(BigDecimal.ONE);
        correction.setCtIngredientCost(BigDecimal.ONE);
        correction.setCtFindingsCd(findingsCode);
        correction.setDocReceivedInd("Y");
        return correction;
    }
}
