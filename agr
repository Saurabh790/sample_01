package com.optum.fads.pgp.study.exception;

import java.util.Locale;

import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.context.MessageSource;
import org.springframework.stereotype.Component;
import org.springframework.validation.Errors;
import org.springframework.validation.ValidationUtils;
import org.springframework.validation.Validator;

import com.optum.fads.pgp.study.dto.Study;
import com.optum.fads.pgp.study.dto.StudyDTO;

/**
 * @author sbiry
 *
 */
@Component
public class StudyValidator implements Validator {

	@Autowired
	private MessageSource messageSource;
	 
	@Override
	public boolean supports(Class<?> clazz) {
		// TODO Auto-generated method stub
		return Study.class.equals(clazz);
	}

	@Override
	public void validate(Object target, Errors errors) {
	StudyDTO study =(StudyDTO) target;

	ValidationUtils.rejectIfEmpty(errors, "name",
            messageSource.getMessage("study.name.error", null, Locale.getDefault()));
	
	if (null != study.getPeerGroup() && Boolean.TRUE.equals(study.getPeerGroup())
            && null == study.getPeerGroup().getStudyGroupId()) {
        errors.rejectValue("peerGroup", messageSource.getMessage("study.peerGroup.error", null, Locale.getDefault()),
                "PeerGroup details should not be empty");
    }
	
	}

}
