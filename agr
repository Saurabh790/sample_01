import org.springframework.web.cors.CorsConfiguration;
import org.springframework.web.cors.UrlBasedCorsConfigurationSource;

import com.optum.fads.caseclaimcorrections.api.security.UserJwtAuthenticationConverter;
import com.optum.fads.caseclaimcorrections.api.service.IUserDetailsService;

class SecurityConfigTest {

    private final SecurityConfig config = new SecurityConfig(new NoOpUserDetailsService());

    @Test
    void jwtDecoderParsesJwtClaims() {
        JwtDecoder decoder = config.jwtDecoder();
        String token =
                "eyJhbGciOiJub25lIn0.eyJzdWIiOiJ1c2VyMSIsImlhdCI6MTcxMjM2MDAwMCwiZXhwIjoxNzEyMzYzNjAwfQ.";

        Jwt jwt = decoder.decode(token);

        assertEquals("user1", jwt.getSubject());
        assertInstanceOf(Instant.class, jwt.getClaim("iat"));
        assertInstanceOf(Instant.class, jwt.getClaim("exp"));
    }

    @Test
    void jwtDecoderRejectsInvalidToken() {
        JwtDecoder decoder = config.jwtDecoder();

        assertThrows(JwtException.class, () -> decoder.decode("not-a-jwt"));
    }

    @Test
    void createsConverterPasswordEncoderAndCorsConfig() throws Exception {
        Field field = SecurityConfig.class.getDeclaredField("uniqueIdClaims");
        field.setAccessible(true);
        field.set(config, List.of("email", "sub"));

        UserJwtAuthenticationConverter converter = config.userJwtAuthenticationConverter();
        PasswordEncoder encoder = config.passwordEncoder();
        UrlBasedCorsConfigurationSource source =
                (UrlBasedCorsConfigurationSource) config.corsConfigurationSource();
        CorsConfiguration corsConfiguration = source.getCorsConfiguration(new MockHttpServletRequest());

        assertNotNull(converter);
        assertNotNull(encoder);
        assertEquals(List.of(CorsConfiguration.ALL), corsConfiguration.getAllowedOrigins());
        assertEquals(List.of(CorsConfiguration.ALL), corsConfiguration.getAllowedMethods());
        assertEquals(List.of(CorsConfiguration.ALL), corsConfiguration.getAllowedHeaders());
    }

    static class NoOpUserDetailsService implements IUserDetailsService {
        @Override
        public org.springframework.security.core.userdetails.UserDetails loadUserByUsername(String username) {
            return null;
        }
    }
}
