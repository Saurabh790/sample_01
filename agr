package com.optum.fads.caseentrybatch.api.controller;

import static org.junit.Assert.assertEquals;
import static org.mockito.Mockito.when;

import org.junit.Test;
import org.junit.runner.RunWith;
import org.mockito.InjectMocks;
import org.mockito.Mock;
import org.mockito.junit.MockitoJUnitRunner;
import org.springframework.http.HttpStatus;
import org.springframework.http.ResponseEntity;
import org.springframework.test.util.ReflectionTestUtils;

import com.optum.fads.caseentrybatch.api.exception.CaseEntryApiException;
import com.optum.fads.caseentrybatch.api.service.ICaseBatchService;

@RunWith(MockitoJUnitRunner.class)
public class CaseBatchControllerTests {

    @Mock
    private ICaseBatchService caseBatchService;

    @InjectMocks
    private CaseBatchController caseBatchController;

    @Test
    public void runCaseBatchReturnsOkWhenBatchCreationSucceeds() {
        ReflectionTestUtils.setField(caseBatchController, "iCaseBatchService", caseBatchService);
        when(caseBatchService.createBatchCase()).thenReturn("Success");

        ResponseEntity<String> response = caseBatchController.runCaseBatch();

        assertEquals(HttpStatus.OK, response.getStatusCode());
        assertEquals("Success", response.getBody());
    }

    @Test
    public void runCaseBatchReturnsBadRequestWhenBatchCreationFails() {
        ReflectionTestUtils.setField(caseBatchController, "iCaseBatchService", caseBatchService);
        when(caseBatchService.createBatchCase()).thenThrow(new CaseEntryApiException("boom"));

        ResponseEntity<String> response = caseBatchController.runCaseBatch();

        assertEquals(HttpStatus.BAD_REQUEST, response.getStatusCode());
        assertEquals("Error in creating batch case", response.getBody());
    }
}
