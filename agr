        reportSectionEntity.setPrmRsRiTs(List.of(reportItem));

        PrmStudyRsRiTPK studyRsRiId = new PrmStudyRsRiTPK();
        studyRsRiId.setPbId(1L);
        studyRsRiId.setRsId(33L);
        studyRsRiId.setRiId(25L);
