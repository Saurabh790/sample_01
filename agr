        CaClaimFindingsObsT existingFinding = CaClaimFindingsObsT.builder()
                .id(CaClaimFindingsObsTId.builder().caseId(10).seqNum(BigDecimal.valueOf(22)).build())
                .build();

        when(claimCorrectionsRepo.findById(CaClaimCorrectionsTId.builder().caseId(10).clmSeqNum(4).build()))
                .thenReturn(Optional.empty());
        when(claimCorrectionMapper.convertToCaClaimCorrectionsT(dto)).thenReturn(current);
        when(caClaimFindingsObsRepo.findById(CaClaimFindingsObsTId.builder().caseId(10).seqNum(BigDecimal.valueOf(22)).build()))
