    private ErrorDetail mockErrorDetail;

    @Test
    public void testCode() {
        final String code = "Code";

        when(mockErrorDetail.getCode()).thenReturn(code);

        final var exception = new PiApiException(mockErrorDetail);

        assertThat(exception.getErrorCode(), is(equalTo(code)));
    }

    @Test
    public void testMessage() {
        final String message = "Message";

        when(mockErrorDetail.getMessage()).thenReturn(message);

        final var exception = new PiApiException(mockErrorDetail);

        assertThat(exception.getMessage(), is(equalTo(message)));
    }

    @Test
    public void testMessageFormat() {
        final String message = "Message {}";
        final String messageParam = "test";

        when(mockErrorDetail.getMessage()).thenReturn(message);

        final var exception = new PiApiException(mockErrorDetail, messageParam);

        assertThat(exception.getMessage(), is(equalTo("Message test")));
    }

    @Test
    public void testMessageFormatWithCause() {
        final var message = "Message {}";
        final var messageParam = "test";
        final var cause = new Exception();

        when(mockErrorDetail.getMessage()).thenReturn(message);

        final var exception = new PiApiException(mockErrorDetail, cause, messageParam);

        assertThat(exception.getMessage(), is(equalTo("Message test")));
        assertThat(exception.getCause(), is(sameInstance(cause)));
    }

    @Test
    public void testStatus() {
        final var httpStatus = BAD_REQUEST;

        when(mockErrorDetail.getHttpStatus()).thenReturn(httpStatus);

        final var exception = new PiApiException(mockErrorDetail);

        assertThat(exception.getHttpStatus(), is(equalTo(httpStatus)));
    }

    @Test
    public void testCause() {
        final var e = new Exception();

        final var exception = new PiApiException(mockErrorDetail, e);

        assertThat(exception.getCause(), is(sameInstance(e)));
    }

}
