    @Test
    void comparatorSortSupportsObservationVersionAscending() {
        CaClaimFindingsObsT newer = new CaClaimFindingsObsT();
        newer.setVersionSeqNum(BigDecimal.valueOf(5));
        CaClaimFindingsObsT older = new CaClaimFindingsObsT();
        older.setVersionSeqNum(BigDecimal.valueOf(1));

        int result = readComparator().compare(newer, older);

        assertTrue(result > 0);
    }

    @SuppressWarnings("unchecked")
    private static java.util.Comparator<CaClaimFindingsObsT> readComparator() {
        try {
            var field = CaseDetailClaimsService.class.getDeclaredField("FINDINGS_VERSION_SEQ_ASC_ORDER");
            field.setAccessible(true);
            return (java.util.Comparator<CaClaimFindingsObsT>) field.get(null);
