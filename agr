    @Test
    public void findCaseProviderMapsValuesFromJdbcResult() {
        CaseBatchIndividualService spyService = org.mockito.Mockito.spy(caseBatchIndividualService);
        ReflectionTestUtils.setField(spyService, "modelMapper", createConfiguredModelMapper());

        java.util.Collection<com.optum.fads.caseentrybatch.api.dto.CaseMetabaseField> fields = Arrays.asList(
                new com.optum.fads.caseentrybatch.api.dto.CaseMetabaseField("PARTICIPANT_ID", "PARTICIPANT_ID", "participantId", null, "TEXT"),
                new com.optum.fads.caseentrybatch.api.dto.CaseMetabaseField("PARTICIPANT_NAME", "PARTICIPANT_NAME", "participantName", null, "TEXT"));
        doReturn(new Object[] { "SELECT X", fields }).when(spyService).findSqlAndPopulateFields(CaseEntryConstants.PROVIDER);

        Map<String, Object> row = new HashMap<>();
        row.put("PARTICIPANT_ID", "PV-100");
        row.put("PARTICIPANT_NAME", "Provider Name");

        when(jdbcTemplate.queryForMap(eq("SELECT X"), any(Object[].class))).thenReturn(row);
        when(caseBatchUtil.findCaseMetabaseField(fields, "PARTICIPANT_ID")).thenReturn((com.optum.fads.caseentrybatch.api.dto.CaseMetabaseField) fields.toArray()[0]);
        when(caseBatchUtil.findCaseMetabaseField(fields, "PARTICIPANT_NAME")).thenReturn((com.optum.fads.caseentrybatch.api.dto.CaseMetabaseField) fields.toArray()[1]);

        CaseProviderDTO result = spyService.findCaseProvider(CaseEntryConstants.PROVIDER, "PV-100");

        assertEquals("PV-100", result.getParticipantId());
        assertEquals("Provider Name", result.getParticipantName());
    }

    private CaUniverseT createUniverse() {
        CaUniverseTPK id = new CaUniverseTPK();
        id.setCtBatchId(10);

        UiUserBase userBase = new UiUserBase();
        userBase.setUiSystemId("WA123456");

        CaUniverseT caUniverseT = new CaUniverseT();
        caUniverseT.setId(id);
        caUniverseT.setUiUserBase(userBase);
        caUniverseT.setCaPrmNodeCd("PAU");
        caUniverseT.setCaYearId(2024);
        caUniverseT.setProjectStatus("ACTIVE");
        caUniverseT.setAssignUsr("WA123456");
        caUniverseT.setAssignSectionCd("PR");
        caUniverseT.setAssignDate(new Date());
        caUniverseT.setCaseStatusCd("OPEN");
        caUniverseT.setCaseStatusDt(new Date());
        caUniverseT.setCaseTypeCd(CaseEntryConstants.PROVIDER);
        return caUniverseT;
    }

    private CaMetaBaseT createMetaBase(String fieldId, String caseType, String sqlClauseType, String tableName,
            String columnName, String htmlFieldType) {
        CaMetaBaseT caMetaBaseT = new CaMetaBaseT();
        caMetaBaseT.setId(new CaMetaBaseTPK(fieldId, caseType));
        caMetaBaseT.setSqlClauseType(sqlClauseType);
        caMetaBaseT.setTableName(tableName);
        caMetaBaseT.setColumnName(columnName);
        caMetaBaseT.setHtmlFieldType(htmlFieldType);
        return caMetaBaseT;
    }

    private ModelMapper createConfiguredModelMapper() {
        ModelMapper modelMapper = new ModelMapper();
        modelMapper.getConfiguration().setAmbiguityIgnored(true);
        modelMapper.typeMap(CaseProviderDTO.class, com.optum.fads.caseentrybatch.api.domain.CaProviderT.class)
                .addMappings(mapper -> mapper.skip(com.optum.fads.caseentrybatch.api.domain.CaProviderT::setCaseId));
        modelMapper.typeMap(CaseRecipientDTO.class, com.optum.fads.caseentrybatch.api.domain.CaRecipientT.class)
                .addMappings(mapper -> mapper.skip(com.optum.fads.caseentrybatch.api.domain.CaRecipientT::setCaseId));
        return modelMapper;
    }
