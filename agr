package com.optum.fads.config.dao.impl;

import java.util.ArrayList;
import java.util.List;

import org.hibernate.query.Query;
import org.hibernate.Session;
import org.hibernate.SessionFactory;
import org.slf4j.Logger;
import org.slf4j.LoggerFactory;
import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.stereotype.Repository;

import com.optum.fads.config.dao.FadsModElemConfigDAO;
import com.optum.fads.security.domain.FadsModElemConfig;
import com.optum.fads.security.dto.FadsModElemConfigDto;

@Repository
public class FadsModElemConfigDAOImpl implements FadsModElemConfigDAO {

	private static final Logger log = LoggerFactory
			.getLogger(FadsModElemConfigDAOImpl.class);
	
	@Autowired
	private SessionFactory sessionFactory;

	public void setSessionFactory(SessionFactory sessionFactory) {
		this.sessionFactory = sessionFactory;
	}

	private Session getCurrentSession() {
		return sessionFactory.getCurrentSession();
	}

	protected void initDao() {
		// do nothing
	}
	@Override
	public List<FadsModElemConfigDto> findAllFadsModElemConfigValues() {
		log.debug("finding all fads mod elem config instances");
		List<FadsModElemConfigDto> configDtos = new ArrayList<>();
		Session session= getCurrentSession();
		
	
		try {
				String [REDACTED] = "from FadsModElemConfig";			
				Query queryObject =session.createQuery([REDACTED]);
				
				
				try {
					List<FadsModElemConfig> configs =  queryObject.list();
					for(FadsModElemConfig fadsModElemConfig :configs){
						FadsModElemConfigDto dto = new FadsModElemConfigDto();
						dto.setElementCd(fadsModElemConfig.getElementCd());
						dto.setElementId(fadsModElemConfig.getElementId());
						dto.setElementName(fadsModElemConfig.getElementName());
						dto.setElementUrl(fadsModElemConfig.getElementUrl());
						if(fadsModElemConfig.getSeFadsModule() != null){
							dto.setParentModuleId(fadsModElemConfig.getSeFadsModule().getFadsModuleId());
							dto.setParentModuleName(fadsModElemConfig.getSeFadsModule().getFadsModuleName());
						}
						configDtos.add(dto);
						
					}
					
				}

				catch (Exception ex) {
					log.error("loadFadsModConfigValues", ex);
				}
				log.debug(" loadFadsModConfigValues() done :: ");
				
			return configDtos;
		} catch (RuntimeException re) {
			log.error("find all failed", re);
			throw re;
		}
	}

}





