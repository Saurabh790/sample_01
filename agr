@ExtendWith(MockitoExtension.class)
class DataElementDataServiceTest {

    @Mock
    private DataRuleMBRepository dataRuleMBRepository;

    @Mock
    private JdbcTemplate jdbcTemplate;

    @InjectMocks
    private DataElementDataService service;

    @Test
    void getdataelementLoadsLookupValuesWhenLuFlagEnabled() {
        Object[] row = {101, "Age", "CHAR", 1, "select DATA_VALUE, DATA_LABEL from dual", "MEMBER"};
        when(dataRuleMBRepository.retrieveDataElementById(101)).thenReturn(List.of(row));
        when(jdbcTemplate.queryForList("select DATA_VALUE, DATA_LABEL from dual"))
                .thenReturn(List.of(Map.of("DATA_VALUE", "A", "DATA_LABEL", "Adult")));

        DataElementDTO dto = service.getdataelement(101, List.of());

        assertNotNull(dto);
        assertEquals(101, dto.getId());
        assertEquals("Age", dto.getName());
        assertEquals(1, dto.getAvailValues().size());
        assertEquals("A", dto.getAvailValues().get(0).getCode());
        assertEquals("Adult", dto.getAvailValues().get(0).getValue());
    }

    @Test
    void getDataElementsUsesAllQueryForAllSource() {
        Object[] row = {201, "DOB", "DATE", 0, null, "ALL"};
        when(dataRuleMBRepository.retrieveDataElements()).thenReturn(List.of(row));

        List<DataElementDTO> result = service.getDataElements("ALL");

        assertEquals(1, result.size());
        assertEquals("DOB", result.get(0).getName());
        verify(dataRuleMBRepository).retrieveDataElements();
    }

    @Test
    void getBpTypeDataElementsMapsRepositoryResults() {
        PrmMbMasterT mb = new PrmMbMasterT();
        mb.setMbCtecFid(301);
        mb.setMbCustDatadesc("Gender");
        when(dataRuleMBRepository.retrieveBpTypeDataElements("%BP1%")).thenReturn(List.of(mb));

        List<DataElementDTO> result = service.getBpTypeDataElements("BP1");

        assertEquals(1, result.size());
        assertEquals(301, result.get(0).getId());
        assertEquals("Gender", result.get(0).getName());
    }

    @Test
    void findAllDataSourceElementsMapsZeroValueToAll() {
        FadsLuValuesTPK allId = new FadsLuValuesTPK();
        allId.setFieldId("DR_ELEMENT_CLASS");
        allId.setLuValue("0");
        FadsLuValuesT all = new FadsLuValuesT();
        all.setId(allId);
        all.setLuLabel("Ignored");
        all.setLuView("Y");
        all.setObjId(10);
        all.setLuSeq(1);

        FadsLuValuesTPK claimId = new FadsLuValuesTPK();
        claimId.setFieldId("DR_ELEMENT_CLASS");
        claimId.setLuValue("2");
        FadsLuValuesT claim = new FadsLuValuesT();
        claim.setId(claimId);
        claim.setLuLabel("Claim");
        claim.setLuView("Y");
        claim.setObjId(20);
        claim.setLuSeq(2);

        when(dataRuleMBRepository.retrieveDataSourceElements()).thenReturn(List.of(all, claim));

        var result = service.findAllDataSourceElements();

        assertEquals(2, result.size());
        assertEquals("All", result.get(0).getLuValue());
        assertEquals("All", result.get(0).getLuLabel());
        assertEquals("2", result.get(1).getLuValue());
        assertEquals("Claim", result.get(1).getLuLabel());
    }

    @Test
    void getAllDateElementsThrowsWrappedExceptionWhenNoRowsFound() {
        when(dataRuleMBRepository.retrieveDateElements("%5%")).thenReturn(List.of());

        DataRulesApiException ex = assertThrows(DataRulesApiException.class, () -> service.getAllDateElements());

        assertTrue(ex.getMessage().contains("Exception occured"));
    }
}
