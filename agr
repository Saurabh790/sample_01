        caseBatchEmailService.saveEmailBatchT(emailData, "user@test.com");

        ArgumentCaptor<CaEmailsBatchT> captor = ArgumentCaptor.forClass(CaEmailsBatchT.class);
        verify(caEmailsBatchRepository).saveAndFlush(captor.capture());
        CaEmailsBatchT saved = captor.getValue();

        assertNotNull(saved.getId());
        assertEquals(Integer.valueOf(35), saved.getId().getCtBatchId());
        assertEquals(Integer.valueOf(1), saved.getId().getSeqNum());
        assertEquals(CaseEntryConstants.SUCCESS_MESSAGE, saved.getEmailType());
        assertEquals("user@test.com", saved.getToEmail());
        assertEquals("CT_ADMIN", saved.getUserId());
        assertEquals("subject", saved.getEmailSubj());
        assertEquals("body", saved.getEmailText());
    }

