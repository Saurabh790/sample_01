package com.optum.fads.pgp.datarules.config;

import static org.junit.jupiter.api.Assertions.assertEquals;
import static org.junit.jupiter.api.Assertions.assertThrows;
import static org.junit.jupiter.api.Assertions.assertTrue;
import static org.mockito.Mockito.when;

import java.time.Instant;
import java.util.Collection;
import java.util.List;
import java.util.Map;

import org.junit.jupiter.api.Test;
import org.junit.jupiter.api.extension.ExtendWith;
import org.mockito.Mock;
import org.mockito.junit.jupiter.MockitoExtension;
import org.springframework.security.authentication.BadCredentialsException;
import org.springframework.security.authentication.UsernamePasswordAuthenticationToken;
import org.springframework.security.core.GrantedAuthority;
import org.springframework.security.oauth2.jwt.Jwt;
import org.springframework.test.util.ReflectionTestUtils;

import com.optum.fads.pgp.datarules.dto.AppUser;
import com.optum.fads.pgp.datarules.service.IUserDetailsService;

@ExtendWith(MockitoExtension.class)
class UserJwtAuthenticationConverterTest {

    @Mock
    private IUserDetailsService userDetailsService;

    @Test
    void convertMapsGroupsToAuthoritiesAndUsesFirstNonBlankUniqueClaim() {
        UserJwtAuthenticationConverter converter =
                new UserJwtAuthenticationConverter(userDetailsService, List.of("email", "preferred_username"));
        AppUser user = new AppUser();
        user.setUserId("creator");
        when(userDetailsService.loadUserByUsername("creator")).thenReturn(user);

        Jwt jwt = new Jwt(
                "token",
                Instant.now(),
                Instant.now().plusSeconds(60),
                Map.of("alg", "none"),
                Map.of("email", "", "preferred_username", "creator", "groups", List.of("admins", "users")));

        UsernamePasswordAuthenticationToken token =
                (UsernamePasswordAuthenticationToken) converter.convert(jwt);

        assertEquals(user, token.getPrincipal());
        assertEquals(2, token.getAuthorities().size());
        assertEquals("ROLE_ADMINS", token.getAuthorities().iterator().next().getAuthority());
    }

    @Test
    void convertUsesEmptyAuthoritiesWhenGroupsClaimMissing() {
        UserJwtAuthenticationConverter converter =
                new UserJwtAuthenticationConverter(userDetailsService, List.of("preferred_username"));
        AppUser user = new AppUser();
        user.setUserId("creator");
        when(userDetailsService.loadUserByUsername("creator")).thenReturn(user);

        Jwt jwt = new Jwt(
                "token",
                Instant.now(),
                Instant.now().plusSeconds(60),
                Map.of("alg", "none"),
                Map.of("preferred_username", "creator"));

        UsernamePasswordAuthenticationToken token =
                (UsernamePasswordAuthenticationToken) converter.convert(jwt);

        assertEquals(user, token.getPrincipal());
        assertEquals(0, token.getAuthorities().size());
    }

    @Test
    void convertThrowsWhenUserNotFound() {
        UserJwtAuthenticationConverter converter =
                new UserJwtAuthenticationConverter(userDetailsService, List.of("preferred_username"));
        when(userDetailsService.loadUserByUsername("missing")).thenReturn(null);

        Jwt jwt = new Jwt(
                "token",
                Instant.now(),
                Instant.now().plusSeconds(60),
                Map.of("alg", "none"),
                Map.of("preferred_username", "missing"));

        assertThrows(BadCredentialsException.class, () -> converter.convert(jwt));
    }

    @Test
    void convertThrowsWhenNoConfiguredUniqueIdClaimHasAValue() {
        UserJwtAuthenticationConverter converter =
                new UserJwtAuthenticationConverter(userDetailsService, List.of("email", "preferred_username"));
        when(userDetailsService.loadUserByUsername(null)).thenReturn(null);

        Jwt jwt = new Jwt(
                "token",
                Instant.now(),
                Instant.now().plusSeconds(60),
                Map.of("alg", "none"),
                Map.of("groups", List.of("admins")));

        assertThrows(BadCredentialsException.class, () -> converter.convert(jwt));
    }

    @Test
    void getUniqueIdReturnsFirstNonBlankConfiguredClaim() {
        UserJwtAuthenticationConverter converter =
                new UserJwtAuthenticationConverter(userDetailsService, List.of("email", "preferred_username", "upn"));

        Jwt jwt = new Jwt(
                "token",
                Instant.now(),
                Instant.now().plusSeconds(60),
                Map.of("alg", "none"),
                Map.of("email", " ", "preferred_username", "", "upn", "creator@optum.com"));

        String uniqueId = ReflectionTestUtils.invokeMethod(converter, "getUniqueID", jwt);

        assertEquals("creator@optum.com", uniqueId);
    }

    @Test
    void getGroupsReturnsEmptyCollectionWhenClaimIsNotACollection() {
        UserJwtAuthenticationConverter converter =
                new UserJwtAuthenticationConverter(userDetailsService, List.of("preferred_username"));

        Jwt jwt = new Jwt(
                "token",
                Instant.now(),
                Instant.now().plusSeconds(60),
                Map.of("alg", "none"),
                Map.of("preferred_username", "creator", "groups", "admins"));

        Collection<String> groups = ReflectionTestUtils.invokeMethod(converter, "getGroups", jwt);

        assertEquals(0, groups.size());
    }

    @Test
    void extractAuthoritiesUpperCasesGroupsIntoRoleAuthorities() {
        UserJwtAuthenticationConverter converter =
                new UserJwtAuthenticationConverter(userDetailsService, List.of("preferred_username"));

        Jwt jwt = new Jwt(
                "token",
                Instant.now(),
                Instant.now().plusSeconds(60),
                Map.of("alg", "none"),
                Map.of("preferred_username", "creator", "groups", List.of("admins", "reviewers")));

        Collection<GrantedAuthority> authorities = ReflectionTestUtils.invokeMethod(converter, "extractAuthorities", jwt);

        assertEquals(2, authorities.size());
        assertTrue(authorities.stream().anyMatch(a -> "ROLE_ADMINS".equals(a.getAuthority())));
        assertTrue(authorities.stream().anyMatch(a -> "ROLE_REVIEWERS".equals(a.getAuthority())));
    }
}
