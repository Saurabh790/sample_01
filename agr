	protected String[] getSearchCriteria(ListTableParams listTableParams) {
		String[] searchCriteriaItems = { DataRuleConstants.PERCENT_STR, // [0][ Data Rule Name
				DataRuleConstants.PERCENT_STR, // [1] Created by
				DataRuleConstants.PERCENT_STR, // [2] Modified by
				DataRuleConstants.ZERO_STR, // [3] if Name contains sp ch
				DataRuleConstants.NULL_STR }; // [4] User System Id
		String searchInput;
		String searchBy;
		int searchCritSize = listTableParams.getSearchBy().size();

		for (int index = 0; index < searchCritSize; index++) {
			searchInput = listTableParams.getSearchInput().get(index).toLowerCase();
			searchBy = listTableParams.getSearchBy().get(index);
			switch (searchBy) {
				case DataRuleConstants.DATA_RULE_NAME:
					if (StringUtils.containsAny(searchInput, DataRuleConstants.PERCENT_CHAR)
							|| StringUtils.containsAny(searchInput, DataRuleConstants.UNDERSCORE_CHAR)) {
						searchCriteriaItems[3] = DataRuleConstants.SEARCH_SP_CH_IN_NM_STR;
					}
					searchCriteriaItems[0] = replDataRuleName(searchInput); /// dataRuleNameVal
					break;
				case DataRuleConstants.CREATED_BY:
					if (StringUtils.containsWhitespace(searchInput)) {
						searchInput = searchInput.trim();
						searchInput = searchInput.replaceAll("\\s+", " ");
					}
					searchCriteriaItems[1] = DataRuleConstants.PERCENT_STR + searchInput
							+ DataRuleConstants.PERCENT_STR; // createdByVal
					break;
				case DataRuleConstants.MODIFIED_BY:
					if (StringUtils.containsWhitespace(searchInput)) {
						searchInput = searchInput.trim();
						searchInput = searchInput.replaceAll("\\s+", " ");
					}
					searchCriteriaItems[2] = DataRuleConstants.PERCENT_STR + searchInput
							+ DataRuleConstants.PERCENT_STR; // updatedByVal
					break;
				case DataRuleConstants.USER_SYSTEM_ID:
					searchCriteriaItems[4] = searchInput;
					break;
				default:
					break;
			}
		}

		return searchCriteriaItems;
	}

	/**
	 * this method will get all the Code Values for a data rule
	 * 
	 * Parameters - data rule id
	 */
	public List<DrCodeValueDTO> loadCodeValuesById(Integer dataruleRecId) {
		logit.info(" Obtain code values for the ID = {}", dataruleRecId);
		List<DrCodeValueDTO> codeValuesList = new ArrayList<>();
		try {
			List<PrmDrSingleValuesT> singleValuesList = dataRuleSingleValuesRepository
					.retrieveCodeValues(dataruleRecId);
			if (!singleValuesList.isEmpty()) {
				for (PrmDrSingleValuesT singleValue : singleValuesList) {
					DrCodeValueDTO codeBean = new DrCodeValueDTO();
					codeBean.setValue(singleValue.getDrLabel());
					codeBean.setCode(singleValue.getId().getDrValue());
					codeValuesList.add(codeBean);
				}
				logit.info(" Code Values list populated with {} code Value data", codeValuesList.size());
			} else {
				logit.info("No code Values obtained for the Datarule ID = {}", dataruleRecId);
			}
		} catch (Exception e) {
			throw new DataRulesApiException(DataRuleConstants.EXCEPTION_MESSAGE, e);
		}
		return codeValuesList;
	}

