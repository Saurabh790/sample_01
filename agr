        notice.setNoticeId(CaseEntryConstants.BATCH_ASSIGNMENT_NOTIFICATION);
        notice.setNoticeFlag(CaseEntryConstants.ONE_STR);
        notice.setSubjEmail("Batch [BATCH ID]");
        notice.setRemComment("Assigned to [ASSIGNED TO] for [INVESTIGATION TYPE] cases [CASE ID] on [ASSIGNED DATE]");

        EmailData emailData = new EmailData();
        emailData.setNoticeId(CaseEntryConstants.BATCH_ASSIGNMENT_NOTIFICATION);
        emailData.setAssignUser("WA111111");
        emailData.setBatchId(21);
        emailData.setInvestigationType(CaseEntryConstants.INVESTIGATION_TYPE_PRELIMINARY);
        emailData.setCaseIdList(Arrays.asList("PAU-2024-00001"));
        emailData.setAssignDate(new java.util.Date(0));

        when(caMetaBaseNoticeRepository.findById(CaseEntryConstants.BATCH_ASSIGNMENT_NOTIFICATION)).thenReturn(Optional.of(notice));
        when(userRepository.findById("WA111111")).thenReturn(Optional.of(assignedUser));
        when(caLuValuesRepository.findByIdFieldId(CaseEntryConstants.INVST_TYPE_CODE))
                .thenReturn(Arrays.asList(createLuValue(CaseEntryConstants.INVESTIGATION_TYPE_PRELIMINARY, "Preliminary")));
