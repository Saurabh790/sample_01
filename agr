@ExtendWith(MockitoExtension.class)
class UserJwtAuthenticationConverterTest {

    @Mock
    private IUserDetailsService userDetailsService;

    @Test
    void convertLoadsUserUsingFirstNonBlankUniqueIdClaim() {
        UserJwtAuthenticationConverter converter =
                new UserJwtAuthenticationConverter(userDetailsService, List.of("upn", "email", "sub"));
        AppUser user = new AppUser();
        user.setUserSystemId("system-user");
        when(userDetailsService.loadUserByUsername("person@example.com")).thenReturn(user);

        Jwt jwt = Jwt.withTokenValue("token")
                .header("alg", "none")
                .claim("groups", List.of("admin", "auditor"))
                .claim("upn", "")
                .claim("email", "person@example.com")
                .build();

        UsernamePasswordAuthenticationToken token =
                (UsernamePasswordAuthenticationToken) converter.convert(jwt);

        assertEquals(user, token.getPrincipal());
        assertEquals(2, token.getAuthorities().size());
    }

    @Test
    void convertThrowsWhenUserLookupReturnsNull() {
        UserJwtAuthenticationConverter converter =
                new UserJwtAuthenticationConverter(userDetailsService, List.of("email"));
        when(userDetailsService.loadUserByUsername("missing@example.com")).thenReturn(null);

        Jwt jwt = Jwt.withTokenValue("token")
                .header("alg", "none")
                .claim("email", "missing@example.com")
                .build();

        assertThrows(BadCredentialsException.class, () -> converter.convert(jwt));
    }
}
