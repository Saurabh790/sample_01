@ExtendWith(MockitoExtension.class)
class CommonServiceTest {

    @InjectMocks
    private CommonService commonService;

    @Mock
    private LuValuesRepository luValuesRepository;

    @Mock
    private FadsConfigRepository fadsConfigRepository;

    @Mock
    private CommonMapper commonMapper;

    @Test
    void findAllEncClaimTypesReturnsMappedValues() {
        List<FadsLuValueT> entities = List.of(new FadsLuValueT());
        List<LabelValue> expected = List.of(LabelValue.builder().label("ENC").value(1).build());

        when(luValuesRepository.findByIdFieldId(StudyConstants.ENC_TYPES_FIELD_ID)).thenReturn(entities);
        when(commonMapper.convertToLabelValues(entities)).thenReturn(expected);

        List<LabelValue> result = commonService.findAllEncClaimTypes();

        assertSame(expected, result);
        verify(luValuesRepository).findByIdFieldId(StudyConstants.ENC_TYPES_FIELD_ID);
        verify(commonMapper).convertToLabelValues(entities);
    }

    @Test
    void findAllCrossOverTypesReturnsMappedValues() {
        List<FadsLuValueT> entities = List.of(new FadsLuValueT());
        List<LabelValue> expected = List.of(LabelValue.builder().label("XOVER").value(2).build());

        when(luValuesRepository.findByIdFieldId(StudyConstants.XOVERS_TYPES_FIELD_ID)).thenReturn(entities);
        when(commonMapper.convertToLabelValues(entities)).thenReturn(expected);

        List<LabelValue> result = commonService.findAllCrossOverTypes();

        assertSame(expected, result);
        verify(luValuesRepository).findByIdFieldId(StudyConstants.XOVERS_TYPES_FIELD_ID);
        verify(commonMapper).convertToLabelValues(entities);
    }

    @Test
    void findAllConfigValuesMapsKnownEnumsByName() {
        FadsConfigT beginDate = FadsConfigT.builder().optionCode(54L).optionValue("2026-01-01").build();
        FadsConfigT crossOver = FadsConfigT.builder().optionCode(22L).optionValue("2").build();

        when(fadsConfigRepository.findAll(any(org.springframework.data.jpa.domain.Specification.class)))
                .thenReturn(List.of(beginDate, crossOver));

        Map<String, Object> result = commonService.findAllConfigValues();

        assertEquals(2, result.size());
        assertEquals("2026-01-01", result.get(FadsConfigEnum.timePeriodBeginDate.name()));
        assertEquals("2", result.get(FadsConfigEnum.xOverValue.name()));
        assertTrue(result.containsKey("timePeriodBeginDate"));
        verify(fadsConfigRepository).findAll(any(org.springframework.data.jpa.domain.Specification.class));
    }

    @Test
    void getZoneIdReturnsConfiguredZone() {
        FadsConfigT config = FadsConfigT.builder().optionCode(StudyConstants.DATE_TIME_ZONE_ID).optionValue("UTC").build();
        when(fadsConfigRepository.findById(StudyConstants.DATE_TIME_ZONE_ID)).thenReturn(Optional.of(config));

        ZoneId result = commonService.getZoneId();

        assertEquals(ZoneId.of("UTC"), result);
    }

    @Test
    void getZoneIdFallsBackToSystemDefaultWhenMissing() {
        when(fadsConfigRepository.findById(StudyConstants.DATE_TIME_ZONE_ID)).thenReturn(Optional.empty());

        ZoneId result = commonService.getZoneId();

        assertEquals(ZoneId.systemDefault(), result);
    }
}

