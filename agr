
package com.optum.fads.CaseClaimCorrections.api.util;

import static org.junit.jupiter.api.Assertions.assertEquals;
import static org.junit.jupiter.api.Assertions.assertTrue;

import java.math.BigDecimal;
import java.util.Date;

import org.junit.jupiter.api.Test;

import com.optum.fads.caseclaimcorrections.api.entity.CaClaimCorrectionsT;

class CaClaimCorrectionsComparatorTest {

    private final CaClaimCorrectionsComparator comparator = new CaClaimCorrectionsComparator();

    @Test
    void compareHandlesNullSides() {
        assertEquals(1, comparator.compare(new CaClaimCorrectionsT(), null));
        assertEquals(1, comparator.compare(null, new CaClaimCorrectionsT()));
        assertEquals(0, comparator.compare(null, null));
    }

    @Test
    void compareUsesClaimFieldsWhenBothObjectsExist() {
        CaClaimCorrectionsT left = buildCorrection("A", "1", "ABC");
        CaClaimCorrectionsT right = buildCorrection("B", "1", "ABC");

        int result = comparator.compare(left, right);

        assertTrue(result < 0);
    }

    private static CaClaimCorrectionsT buildCorrection(String tcn, String liNum, String findingsCode) {
        CaClaimCorrectionsT correction = new CaClaimCorrectionsT();
        correction.setHdrClmTcn(tcn);
        correction.setLiNum(liNum);
        correction.setHdrClmPdDt(new Date());
        correction.setLiDrugNdc("12345678901");
        correction.setLiPdUosQty(BigDecimal.ONE);
        correction.setLiDrugDosageFormDesc("TAB");
        correction.setLiDrugDaysSupply(BigDecimal.TEN);
        correction.setHdrDrugDispensingFee(BigDecimal.ONE);
        correction.setHdrPdAmt(BigDecimal.TEN);
        correction.setHdrCopayAmt(BigDecimal.ONE);
        correction.setCtIngredientCost(BigDecimal.ONE);
        correction.setCtFindingsCd(findingsCode);
        correction.setDocReceivedInd("Y");
        return correction;
    }
}

package com.optum.fads.CaseClaimCorrections.api.exception;

import static org.junit.jupiter.api.Assertions.assertEquals;
import static org.junit.jupiter.api.Assertions.assertInstanceOf;

import java.util.List;
import java.util.Map;

import org.junit.jupiter.api.Test;
import org.springframework.core.MethodParameter;
import org.springframework.http.HttpStatus;
import org.springframework.validation.BeanPropertyBindingResult;
import org.springframework.validation.FieldError;
import org.springframework.web.bind.MethodArgumentNotValidException;

import com.optum.fads.caseclaimcorrections.api.exception.ErrorInfo;

class GlobalExceptionHandlerTest {

    private final GlobalExceptionHandler handler = new GlobalExceptionHandler();

    @Test
    void handleExceptionBuildsJoinedErrorMessage() {
        ErrorInfo first = ErrorInfo.builder().errorMessage("first error").build();
        ErrorInfo second = ErrorInfo.builder().errorMessage("second error").build();
        CaseClaimCorrectionException exception =
                new CaseClaimCorrectionException(List.of(first, second), "1001", HttpStatus.CONFLICT);

        var response = handler.handleException(exception);

        assertEquals(HttpStatus.CONFLICT, response.getStatusCode());
        ErrorResponseDTO body = assertInstanceOf(ErrorResponseDTO.class, response.getBody());
        assertEquals("409", body.getErrorCode());
        assertEquals("first error; second error", body.getErrorMessage());
    }

    @Test
    void handleValidationExceptionReturnsFieldMessages() throws NoSuchMethodException {
        BeanPropertyBindingResult bindingResult = new BeanPropertyBindingResult(new Object(), "claimCorrectionDTO");
        bindingResult.addError(new FieldError("claimCorrectionDTO", "caseId", "Case ID cannot be null"));
        bindingResult.addError(new FieldError("claimCorrectionDTO", "hdrClmTcn", "Claim TCN cannot be null"));
        MethodParameter parameter = new MethodParameter(
                ValidationTarget.class.getDeclaredMethod("accept", String.class), 0);
        MethodArgumentNotValidException exception = new MethodArgumentNotValidException(parameter, bindingResult);

        var response = handler.handleValidationException(exception);

        assertEquals(HttpStatus.BAD_REQUEST, response.getStatusCode());
        @SuppressWarnings("unchecked")
        Map<String, String> body = (Map<String, String>) response.getBody();
        assertEquals("Case ID cannot be null", body.get("caseId"));
        assertEquals("Claim TCN cannot be null", body.get("hdrClmTcn"));
    }

    static class ValidationTarget {
        void accept(String value) {
        }
    }
}

package com.optum.fads.CaseClaimCorrections.api.config;

import static org.junit.jupiter.api.Assertions.assertEquals;
import static org.junit.jupiter.api.Assertions.assertInstanceOf;
import static org.junit.jupiter.api.Assertions.assertNotNull;
import static org.junit.jupiter.api.Assertions.assertThrows;

import java.lang.reflect.Field;
import java.time.Instant;
import java.util.List;

import org.junit.jupiter.api.Test;
import org.springframework.mock.web.MockHttpServletRequest;
import org.springframework.security.crypto.password.PasswordEncoder;
import org.springframework.security.oauth2.jwt.Jwt;
import org.springframework.security.oauth2.jwt.JwtDecoder;
import org.springframework.security.oauth2.jwt.JwtException;
import org.springframework.web.cors.CorsConfiguration;
import org.springframework.web.cors.UrlBasedCorsConfigurationSource;

import com.optum.fads.caseclaimcorrections.api.security.UserJwtAuthenticationConverter;
import com.optum.fads.caseclaimcorrections.api.service.IUserDetailsService;

class SecurityConfigTest {

    private final SecurityConfig config = new SecurityConfig(new NoOpUserDetailsService());

    @Test
    void jwtDecoderParsesJwtClaims() {
        JwtDecoder decoder = config.jwtDecoder();
        String token =
                "eyJhbGciOiJub25lIn0.eyJzdWIiOiJ1c2VyMSIsImlhdCI6MTcxMjM2MDAwMCwiZXhwIjoxNzEyMzYzNjAwfQ.";

        Jwt jwt = decoder.decode(token);

        assertEquals("user1", jwt.getSubject());
        assertInstanceOf(Instant.class, jwt.getClaim("iat"));
        assertInstanceOf(Instant.class, jwt.getClaim("exp"));
    }

    @Test
    void jwtDecoderRejectsInvalidToken() {
        JwtDecoder decoder = config.jwtDecoder();

        assertThrows(JwtException.class, () -> decoder.decode("not-a-jwt"));
    }

    @Test
    void createsConverterPasswordEncoderAndCorsConfig() throws Exception {
        Field field = SecurityConfig.class.getDeclaredField("uniqueIdClaims");
        field.setAccessible(true);
        field.set(config, List.of("email", "sub"));

        UserJwtAuthenticationConverter converter = config.userJwtAuthenticationConverter();
        PasswordEncoder encoder = config.passwordEncoder();
        UrlBasedCorsConfigurationSource source =
                (UrlBasedCorsConfigurationSource) config.corsConfigurationSource();
        CorsConfiguration corsConfiguration = source.getCorsConfiguration(new MockHttpServletRequest());

        assertNotNull(converter);
        assertNotNull(encoder);
        assertEquals(List.of(CorsConfiguration.ALL), corsConfiguration.getAllowedOrigins());
        assertEquals(List.of(CorsConfiguration.ALL), corsConfiguration.getAllowedMethods());
        assertEquals(List.of(CorsConfiguration.ALL), corsConfiguration.getAllowedHeaders());
    }

    static class NoOpUserDetailsService implements IUserDetailsService {
        @Override
        public org.springframework.security.core.userdetails.UserDetails loadUserByUsername(String username) {
            return null;
        }
    }
}
