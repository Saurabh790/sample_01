class DataRuleDetailMapperTest {

    @Test
    void convertToDataRuleDTOMapsNestedFields() {
        PrmDrDataRuleT entity = new PrmDrDataRuleT();
        entity.setDrId(5001);
        entity.setDataRuleName("alpharule");

        PrmMbMasterT mb = new PrmMbMasterT();
        mb.setMbCtecFid(801);
        entity.setPrmMbMasterT(mb);

        PrmDrLuOperatorT operator = new PrmDrLuOperatorT();
        operator.setOperatorCd("EQ");
        entity.setPrmDrLuOperatorT(operator);

        UiUserBase creator = new UiUserBase();
        creator.setUiSystemId("creator");
        entity.setUiUserBaseCr(creator);

        UiUserBase updater = new UiUserBase();
        updater.setUiSystemId("updater");
        entity.setUiUserBaseUpd(updater);

        DataRuleDTO dto = DataRuleDetailMapper.INSTANCE.convertToDataRuleDTO(entity);

        assertEquals(5001, dto.getDataRuleId());
        assertEquals("alpharule", dto.getDataRuleName());
        assertEquals(801, dto.getDataElementId());
        assertEquals("EQ", dto.getOperator());
        assertEquals("creator", dto.getCreatedBySystemId());
        assertEquals("updater", dto.getModifiedBySystemId());
    }

    @Test
    void convertToPrmDrDataRuleTMapsInverseFields() {
        DataRuleDTO dto = new DataRuleDTO();
        dto.setDataRuleId(5002);
        dto.setDataRuleName("betarule");
        dto.setDataElementId(901);
        dto.setOperator("NE");
        dto.setCreatedBySystemId("creator2");
        dto.setModifiedBySystemId("updater2");

        PrmDrDataRuleT entity = DataRuleDetailMapper.INSTANCE.convertToPrmDrDataRuleT(dto);

        assertEquals(5002, entity.getDrId());
        assertEquals("betarule", entity.getDataRuleName());
        assertEquals(901, entity.getPrmMbMasterT().getMbCtecFid());
        assertEquals("NE", entity.getPrmDrLuOperatorT().getOperatorCd());
        assertEquals("creator2", entity.getUiUserBaseCr().getUiSystemId());
        assertEquals("updater2", entity.getUiUserBaseUpd().getUiSystemId());
    }
}


package com.optum.fads.pgp.datarules.security;

import static org.junit.jupiter.api.Assertions.assertEquals;
import static org.junit.jupiter.api.Assertions.assertThrows;
import static org.mockito.Mockito.when;

import java.time.Instant;
import java.util.List;
import java.util.Map;

import org.junit.jupiter.api.Test;
import org.junit.jupiter.api.extension.ExtendWith;
import org.mockito.Mock;
import org.mockito.junit.jupiter.MockitoExtension;
import org.springframework.security.authentication.BadCredentialsException;
import org.springframework.security.authentication.UsernamePasswordAuthenticationToken;
import org.springframework.security.oauth2.jwt.Jwt;

import com.optum.fads.pgp.datarules.dto.AppUser;
import com.optum.fads.pgp.datarules.service.IUserDetailsService;

@ExtendWith(MockitoExtension.class)
class UserJwtAuthenticationConverterTest {

    @Mock
    private IUserDetailsService userDetailsService;

    @Test
    void convertMapsGroupsToAuthoritiesAndUsesPreferredClaim() {
        UserJwtAuthenticationConverter converter =
                new UserJwtAuthenticationConverter(userDetailsService, List.of("preferred_username", "email"));
        AppUser user = new AppUser();
        user.setUserId("creator");
        when(userDetailsService.loadUserByUsername("creator")).thenReturn(user);

        Jwt jwt = new Jwt(
                "token",
                Instant.now(),
                Instant.now().plusSeconds(60),
                Map.of("alg", "none"),
                Map.of("preferred_username", "creator", "groups", List.of("admins", "users")));

        UsernamePasswordAuthenticationToken token =
                (UsernamePasswordAuthenticationToken) converter.convert(jwt);

        assertEquals(user, token.getPrincipal());
        assertEquals(2, token.getAuthorities().size());
        assertEquals("ROLE_ADMINS", token.getAuthorities().iterator().next().getAuthority());
    }

    @Test
    void convertThrowsWhenUserNotFound() {
        UserJwtAuthenticationConverter converter =
                new UserJwtAuthenticationConverter(userDetailsService, List.of("preferred_username"));
        when(userDetailsService.loadUserByUsername("missing")).thenReturn(null);

        Jwt jwt = new Jwt(
                "token",
                Instant.now(),
                Instant.now().plusSeconds(60),
                Map.of("alg", "none"),
                Map.of("preferred_username", "missing"));

        assertThrows(BadCredentialsException.class, () -> converter.convert(jwt));
    }
}

