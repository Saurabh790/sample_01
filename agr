    @Test
    void updateClaimCorrectionUpdatesOldestFindingAmountWhenNoNewFindingsWereAdded() {
        ClaimCorrectionDTO dto = baseClaimCorrectionDto();
        dto.setFindingObservations(new ArrayList<>());
        CaClaimCorrectionsT current = correctionEntity(10, 4, "TCN-10", BigDecimal.valueOf(70));
        CaClaimFindingsObsT laterVersion = CaClaimFindingsObsT.builder().versionSeqNum(BigDecimal.valueOf(5)).build();
        CaClaimFindingsObsT earliestVersion = CaClaimFindingsObsT.builder().versionSeqNum(BigDecimal.valueOf(2)).build();

        when(claimCorrectionsRepo.findById(CaClaimCorrectionsTId.builder().caseId(10).clmSeqNum(4).build()))
                .thenReturn(Optional.empty());
        when(claimCorrectionMapper.convertToCaClaimCorrectionsT(dto)).thenReturn(current);
        when(caClaimFindingsObsRepo.findByMaxVersionMinSeq(10, "TCN-10", 4))
                .thenReturn(new ArrayList<>(List.of(laterVersion, earliestVersion)));

        caseDetailClaimsService.updateClaimCorrection(dto, "USR4");

        verify(caClaimFindingsObsRepo).save(argThat(saved ->
                saved == earliestVersion && saved.getCorrectPdAmt().equals(70.0)));
    }

    @Test
    void updateClaimCorrectionTriggersFinancialTermsRefreshWhenConfigEnabled() {
        ClaimCorrectionDTO dto = baseClaimCorrectionDto();
        CaClaimCorrectionsT existing = correctionEntity(10, 4, "TCN-10", BigDecimal.valueOf(50));
        CaClaimCorrectionsT current = correctionEntity(10, 4, "TCN-10", BigDecimal.valueOf(90));
        CaseConfigT config = new CaseConfigT();
        config.setOptionCode("CLAIMS_CORR_FIN_UPD");
        config.setOptionValue("Y");

        when(claimCorrectionsRepo.findById(CaClaimCorrectionsTId.builder().caseId(10).clmSeqNum(4).build()))
                .thenReturn(Optional.of(existing));
        when(claimCorrectionMapper.convertToCaClaimCorrectionsT(dto)).thenReturn(current);
        when(caseConfigRepo.findById("CLAIMS_CORR_FIN_UPD")).thenReturn(Optional.of(config));
        when(caClaimFindingsObsRepo.findByMaxVersionMinSeq(10, "TCN-10", 4)).thenReturn(List.of());
        doNothing().when(caseDetailClaimsService).updateFinancialTerms(10);

        caseDetailClaimsService.updateClaimCorrection(dto, "USR5");

        verify(caClaimListRepo).updateClaimCorrectPdAmt(10, 4, BigDecimal.valueOf(90));
        verify(caseDetailClaimsService).updateFinancialTerms(10);
    }

    private static ClaimCorrectionDTO baseClaimCorrectionDto() {
        return ClaimCorrectionDTO.builder()
                .caseId(10)
                .clmSeqNum(4)
                .hdrClmTcn("TCN-10")
                .liNum("1")
                .auditClaim(ClaimDTO.builder().hdrPdAmt(70.0).build())
                .build();
    }

    private static CaClaimCorrectionsT correctionEntity(Integer caseId, Integer claimSeqNum, String hdrClmTcn, BigDecimal hdrPdAmt) {
        return CaClaimCorrectionsT.builder()
                .id(CaClaimCorrectionsTId.builder().caseId(caseId).clmSeqNum(claimSeqNum).build())
                .hdrClmTcn(hdrClmTcn)
                .liNum("1")
                .hdrClmPdDt(new Date())
                .hdrPdAmt(hdrPdAmt)
                .build();
    }

    @SuppressWarnings("unchecked")
    private static java.util.Comparator<CaClaimFindingsObsT> readComparator() {
        try {
            var field = CaseDetailClaimsService.class.getDeclaredField("FINDINGS_VERSION_SEQ_ASC_ORDER");
            field.setAccessible(true);
            return (java.util.Comparator<CaClaimFindingsObsT>) field.get(null);
        } catch (ReflectiveOperationException ex) {
            throw new AssertionError(ex);
        }
    }
}

