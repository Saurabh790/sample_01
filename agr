package com.optum.fads.caseentrybatch.api.service;

import static org.junit.Assert.assertEquals;
import static org.junit.Assert.assertNotNull;
import static org.junit.Assert.assertNull;
import static org.junit.Assert.assertSame;
import static org.mockito.ArgumentMatchers.any;
import static org.mockito.Mockito.verify;
import static org.mockito.Mockito.when;

import java.time.ZoneId;
import java.util.Arrays;
import java.util.Collections;
import java.util.Optional;

import org.junit.Test;
import org.junit.runner.RunWith;
import org.mockito.ArgumentCaptor;
import org.mockito.InjectMocks;
import org.mockito.Mock;
import org.mockito.junit.MockitoJUnitRunner;

import com.optum.fads.caseentrybatch.api.common.CaseEntryConstants;
import com.optum.fads.caseentrybatch.api.domain.CaEmailsBatchT;
import com.optum.fads.caseentrybatch.api.domain.CaLuValuesT;
import com.optum.fads.caseentrybatch.api.domain.CaMetaBaseNoticeT;
import com.optum.fads.caseentrybatch.api.domain.UiUserBase;
import com.optum.fads.caseentrybatch.api.dto.EmailData;
import com.optum.fads.caseentrybatch.api.dto.EmailSpecification;
import com.optum.fads.caseentrybatch.api.repo.CaEmailsBatchRepository;
import com.optum.fads.caseentrybatch.api.repo.CaLuValuesRepository;
import com.optum.fads.caseentrybatch.api.repo.CaMetaBaseNoticeRepository;
import com.optum.fads.caseentrybatch.api.repo.CaseConfigRepository;
import com.optum.fads.caseentrybatch.api.repo.UserRepository;
import com.optum.fads.caseentrybatch.api.service.impl.CaseBatchEmailService;
import com.optum.fads.caseentrybatch.api.util.CaseBatchUtil;

@RunWith(MockitoJUnitRunner.class)
public class CaseBatchEmailServiceTests {

    @Mock
    private UserRepository userRepository;

    @Mock
    private CaMetaBaseNoticeRepository caMetaBaseNoticeRepository;

    @Mock
    private CaEmailsBatchRepository caEmailsBatchRepository;

    @Mock
    private CaseBatchUtil caseBatchUtil;

    @Mock
    private CaseConfigRepository caseConfigRepository;

    @Mock
    private CaLuValuesRepository caLuValuesRepository;

    @InjectMocks
    private CaseBatchEmailService caseBatchEmailService;

    @Test
    public void sendMailBuildsEmailSpecificationAndDelegatesToUtility() {
        EmailSpecification emailSpecification = new EmailSpecification();
        when(caseBatchUtil.getEmailSpecs()).thenReturn(emailSpecification);
        when(caseBatchUtil.sendMail(emailSpecification)).thenReturn(true);

        boolean result = caseBatchEmailService.sendMail("user@test.com", "subject", "body");

        assertEquals(true, result);
        assertEquals("user@test.com", emailSpecification.getSendToEmail());
        assertEquals("subject", emailSpecification.getEmailSubject());
        assertEquals("body", emailSpecification.getEmailText());
    }

    @Test
    public void getUiUserBaseReturnsUserWhenPresent() {
        UiUserBase userBase = new UiUserBase();
        userBase.setUiSystemId("WA123456");
        when(userRepository.findById("WA123456")).thenReturn(Optional.of(userBase));

        UiUserBase result = caseBatchEmailService.getUiUserBase("WA123456");

        assertSame(userBase, result);
    }

    @Test
    public void getUiUserBaseReturnsNullWhenUserMissing() {
        when(userRepository.findById("WA000000")).thenReturn(Optional.empty());

        UiUserBase result = caseBatchEmailService.getUiUserBase("WA000000");

        assertNull(result);
    }

    @Test
    public void setEmailSubjTextBuildsSuccessNotificationText() {
        when(caLuValuesRepository.findByIdFieldId(CaseEntryConstants.INVST_TYPE_CODE)).thenReturn(Collections.emptyList());

        EmailData emailData = new EmailData();
        emailData.setNoticeId(CaseEntryConstants.BATCH_SUCCESS_NOTIFICATION);
        emailData.setBatchId(21);
        emailData.setCaseIdList(Arrays.asList("PAU-2024-00001", "PAU-2024-00002"));

        CaMetaBaseNoticeT notice = new CaMetaBaseNoticeT();
        notice.setSubjEmail("Case Batch ID [BATCH ID] Completed Successfully");
        notice.setRemComment("Case Batch ID [BATCH ID] created case(s) [CASE ID].");

        EmailData result = caseBatchEmailService.setEmailSubjText(emailData, "Anil", "Wagh", notice);

        assertEquals("Case Batch ID 21 Completed Successfully", result.getEmailSubject());
        assertEquals("Case Batch ID 21 created case(s) PAU-2024-00001, PAU-2024-00002.", result.getEmailText());
    }

    @Test
    public void saveEmailBatchTSavesExpectedEntity() {
        EmailData emailData = new EmailData();
        emailData.setBatchId(35);
        emailData.setNoticeId(CaseEntryConstants.BATCH_SUCCESS_NOTIFICATION);
        emailData.setEmailSubject("subject");
        emailData.setEmailText("body");

        when(caEmailsBatchRepository.getNextSequenceId(35)).thenReturn(null);
        when(caseBatchUtil.getCtAdminSystemId()).thenReturn("CT_ADMIN");
        when(caseBatchUtil.getZoneId()).thenReturn(ZoneId.of("Asia/Calcutta"));

        caseBatchEmailService.saveEmailBatchT(emailData, "user@test.com");

        ArgumentCaptor<CaEmailsBatchT> captor = ArgumentCaptor.forClass(CaEmailsBatchT.class);
        verify(caEmailsBatchRepository).saveAndFlush(captor.capture());
        CaEmailsBatchT saved = captor.getValue();

        assertNotNull(saved.getId());
        assertEquals(Integer.valueOf(35), saved.getId().getCtBatchId());
        assertEquals(Integer.valueOf(1), saved.getId().getSeqNum());
        assertEquals(CaseEntryConstants.SUCCESS_MESSAGE, saved.getEmailType());
        assertEquals("user@test.com", saved.getToEmail());
        assertEquals("CT_ADMIN", saved.getUserId());
        assertEquals("subject", saved.getEmailSubj());
        assertEquals("body", saved.getEmailText());
    }

    @Test
    public void getMetaBaseNoticeTReturnsNoticeWhenPresent() {
        CaMetaBaseNoticeT notice = new CaMetaBaseNoticeT();
        notice.setNoticeId(CaseEntryConstants.BATCH_SUCCESS_NOTIFICATION);
        when(caMetaBaseNoticeRepository.findById(CaseEntryConstants.BATCH_SUCCESS_NOTIFICATION)).thenReturn(Optional.of(notice));

        CaMetaBaseNoticeT result = caseBatchEmailService.getMetaBaseNoticeT(CaseEntryConstants.BATCH_SUCCESS_NOTIFICATION);

        assertSame(notice, result);
    }
}
