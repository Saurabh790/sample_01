    @Test
    public void createIntGenPrRpInvstEntriesBuildsProviderCaseAndInvestigationData() {
        CaseBatchIndividualService spyService = org.mockito.Mockito.spy(caseBatchIndividualService);
        ReflectionTestUtils.setField(spyService, "modelMapper", createConfiguredModelMapper());

        CaseBaseInfo caseInfo = new CaseBaseInfo();
        caseInfo.setCaseId(90);
        caseInfo.setSequenceId(12);
        caseInfo.setParticpantId("PV-100");

        CaseProviderDTO provider = new CaseProviderDTO();
        provider.setParticipantId("PV-100");
        provider.setParticipantName("Provider Test");
        org.mockito.Mockito.doReturn(provider).when(spyService).findCaseProvider(CaseEntryConstants.PROVIDER, "PV-100");

        CaUniverseT caUniverseT = createUniverse();
        caUniverseT.setCaseTypeCd(CaseEntryConstants.PROVIDER);
        caUniverseT.setParticipantId("PV-100");
        caUniverseT.setInvstTypeCd(CaseEntryConstants.INVESTIGATION_TYPE_PRELIMINARY);

        CaIntelligentKeyT result = spyService.createIntGenPrRpInvstEntries(caseInfo, LocalDateTime.now(), caUniverseT);

        assertNotNull(result.getCaGeneralT());
        assertNotNull(result.getCaProviderT());
        assertNull(result.getCaRecipientT());
        assertNotNull(result.getCaInvstPreliminaryT());
        assertEquals("Provider Test", result.getCaGeneralT().getParticipantName());
    }

    @Test
    public void createIntGenPrRpInvstEntriesBuildsRecipientCaseAndAssignmentData() {
        CaseBatchIndividualService spyService = org.mockito.Mockito.spy(caseBatchIndividualService);
        ReflectionTestUtils.setField(spyService, "modelMapper", createConfiguredModelMapper());

        CaseBaseInfo caseInfo = new CaseBaseInfo();
        caseInfo.setCaseId(91);
        caseInfo.setSequenceId(13);
        caseInfo.setParticpantId("MB-100");

        CaseRecipientDTO recipient = new CaseRecipientDTO();
        recipient.setParticipantId("MB-100");
        recipient.setParticipantName("Member Test");
        org.mockito.Mockito.doReturn(recipient).when(spyService).findCaseRecipient(CaseEntryConstants.MEMBER, "MB-100");

        CaUniverseT caUniverseT = createUniverse();
        caUniverseT.setCaseTypeCd(CaseEntryConstants.MEMBER);
        caUniverseT.setParticipantId("MB-100");
        caUniverseT.setInvstTypeCd("FS");

        CaIntelligentKeyT result = spyService.createIntGenPrRpInvstEntries(caseInfo, LocalDateTime.now(), caUniverseT);

        assertNotNull(result.getCaGeneralT());
        assertNull(result.getCaProviderT());
        assertNotNull(result.getCaRecipientT());
        assertNotNull(result.getCaInvstFullscaleT());
        assertEquals(1, result.getCaInvstFsAssignTs().size());
        assertEquals("Member Test", result.getCaGeneralT().getParticipantName());
    }

    private CaUniverseT createUniverse() {
        CaUniverseTPK id = new CaUniverseTPK();
        id.setCtBatchId(10);

        UiUserBase userBase = new UiUserBase();
        userBase.setUiSystemId("WA123456");

        CaUniverseT caUniverseT = new CaUniverseT();
        caUniverseT.setId(id);
        caUniverseT.setUiUserBase(userBase);
        caUniverseT.setCaPrmNodeCd("PAU");
        caUniverseT.setCaYearId(2024);
        caUniverseT.setProjectStatus("ACTIVE");
        caUniverseT.setAssignUsr("WA123456");
        caUniverseT.setAssignSectionCd("PR");
        caUniverseT.setAssignDate(new Date());
        caUniverseT.setCaseStatusCd("OPEN");
        caUniverseT.setCaseStatusDt(new Date());
        caUniverseT.setCaseTypeCd(CaseEntryConstants.PROVIDER);
        return caUniverseT;
    }

    private ModelMapper createConfiguredModelMapper() {
        ModelMapper modelMapper = new ModelMapper();
        modelMapper.typeMap(CaseProviderDTO.class, com.optum.fads.caseentrybatch.api.domain.CaProviderT.class)
                .addMappings(mapper -> mapper.skip(com.optum.fads.caseentrybatch.api.domain.CaProviderT::setCaseId));
        modelMapper.typeMap(CaseRecipientDTO.class, com.optum.fads.caseentrybatch.api.domain.CaRecipientT.class)
                .addMappings(mapper -> mapper.skip(com.optum.fads.caseentrybatch.api.domain.CaRecipientT::setCaseId));
        return modelMapper;
    }
