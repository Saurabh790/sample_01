package com.optum.fads.caseentrybatch.api.repo.specs;

import java.util.ArrayList;
import java.util.List;

import jakarta.persistence.criteria.CriteriaBuilder;
import jakarta.persistence.criteria.CriteriaQuery;
import jakarta.persistence.criteria.Predicate;
import jakarta.persistence.criteria.Root;
import jakarta.persistence.criteria.Subquery;

import org.springframework.data.jpa.domain.Specification;

import com.optum.fads.caseentrybatch.api.domain.CaIntelligentKeyT;
import com.optum.fads.caseentrybatch.api.domain.CaMetaBaseNoticeT;


/**
 * @author awagh
 *
 */
public class CaseEntryBatchSpecification{

	public static Specification<CaIntelligentKeyT> findMaxSequenceIdSpecification(String prmNode, short caseYearId ) {

		return new Specification<CaIntelligentKeyT>() {
			private static final long serialVersionUID = 1L;
			@Override
			public Predicate toPredicate(Root<CaIntelligentKeyT> root, CriteriaQuery<?> criteriaQuery, CriteriaBuilder criteriaBuilder) {
//				FADS_DEV.CA_INTELLIGENT_KEY_T_UK1 : ca_prm_node, ca_year_id, ca_sequence_id
				
				 CriteriaQuery<CaIntelligentKeyT> q = criteriaBuilder.createQuery(CaIntelligentKeyT.class);
				 List<Predicate> predicates = new ArrayList<>(); 
				 Predicate prmNodePredicate = criteriaBuilder.equal(root.get("caLuPrmNodeT").get("nodeCd"), prmNode);
				 Predicate caseYearIdPredicate = criteriaBuilder.equal(root.get("caYearId"), caseYearId); 
				 predicates.add(prmNodePredicate); 
				 predicates.add(caseYearIdPredicate);
				 
			     Subquery<Integer> sub = q.subquery(Integer.class);     
			     Root<CaIntelligentKeyT> subRoot = sub.from(CaIntelligentKeyT.class);     
			//     sub.select(criteriaBuilder.max(subRoot.get("caSequenceId")))
			//        .where(predicates.toArray(new Predicate[predicates.size()])).getRestriction();
			     
			     sub.select(criteriaBuilder.max(subRoot.get("caSequenceId")))
			        .where(predicates.toArray(new Predicate[predicates.size()])).getRestriction();
			     
			     return criteriaBuilder.equal(root.get("caSequenceId"), sub);
			    
//				return criteriaQuery.where(predicates.toArray(new Predicate[predicates.size()])).getRestriction();
			}
		};
	}	
	
	public static Specification<CaMetaBaseNoticeT> findMetaBaseNoticeSpecification(String tableName, String columnName) {

		return new Specification<CaMetaBaseNoticeT>() {
			private static final long serialVersionUID = 1L;

			@Override
			public Predicate toPredicate(Root<CaMetaBaseNoticeT> root, CriteriaQuery<?> query, CriteriaBuilder criteriaBuilder) {
				Predicate tableNamePredicate = criteriaBuilder.equal(root.get("tableName"),tableName);	
				Predicate columnNamePredicate = criteriaBuilder.equal(root.get("columnName"),columnName);
				Predicate finalPredicate = criteriaBuilder.and(tableNamePredicate, columnNamePredicate);
				return query.where(finalPredicate).getRestriction();
			}
		};
	}
	
}
