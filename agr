package com.optum.fads.caseentrybatch.api.service;

import static org.junit.Assert.assertEquals;
import static org.junit.Assert.assertTrue;
import static org.mockito.ArgumentMatchers.any;
import static org.mockito.ArgumentMatchers.eq;
import static org.mockito.Mockito.doReturn;
import static org.mockito.Mockito.doThrow;
import static org.mockito.Mockito.never;
import static org.mockito.Mockito.verify;
import static org.mockito.Mockito.when;

import java.math.BigDecimal;
import java.time.ZoneId;
import java.util.Arrays;
import java.util.Collections;
import java.util.Date;
import java.util.List;

import org.junit.Test;
import org.junit.runner.RunWith;
import org.mockito.InjectMocks;
import org.mockito.Mock;
import org.mockito.junit.MockitoJUnitRunner;
import org.springframework.test.util.ReflectionTestUtils;

import com.optum.fads.caseentrybatch.api.common.CaseEntryConstants;
import com.optum.fads.caseentrybatch.api.domain.CaUniverseBatchT;
import com.optum.fads.caseentrybatch.api.domain.CaUniverseBatchTPK;
import com.optum.fads.caseentrybatch.api.domain.CaUniverseT;
import com.optum.fads.caseentrybatch.api.domain.UiUserBase;
import com.optum.fads.caseentrybatch.api.dto.EmailData;
import com.optum.fads.caseentrybatch.api.dto.EmailSpecification;
import com.optum.fads.caseentrybatch.api.repo.CaUniverseBatchRepository;
import com.optum.fads.caseentrybatch.api.service.impl.CaseBatchEmailService;
import com.optum.fads.caseentrybatch.api.service.impl.CaseBatchService;
import com.optum.fads.caseentrybatch.api.snowflakeDomain.DmClaimDrugT;
import com.optum.fads.caseentrybatch.api.snowflakeRepo.DmClaimDrugRepository;
import com.optum.fads.caseentrybatch.api.util.CaseBatchUtil;

@RunWith(MockitoJUnitRunner.class)
public class CaseBatchServiceTests {

    @Mock
    private CaUniverseBatchRepository caUniverseBatchRepository;

    @Mock
    private CaseBatchEmailService caseBatchEmailService;

    @Mock
    private ICaseBatchIndividualService caseBatchIndividualService;

    @Mock
    private CaseBatchUtil caseBatchUtil;

    @Mock
    private DmClaimDrugRepository dmClaimDrugRepository;

    @InjectMocks
    private CaseBatchService caseBatchService;

    @Test
    public void createBatchCaseReturnsSuccessWhenNoPendingBatchIdsExist() {
        when(caUniverseBatchRepository.findDistinctBatchIds()).thenReturn(Collections.emptyList());

        String result = caseBatchService.createBatchCase();

        assertEquals(CaseEntryConstants.SUCCESS_MESSAGE, result);
        verify(caUniverseBatchRepository, never()).findAllByBatchId(any(Integer.class));
    }

    @Test
    public void createBatchCaseProcessesSingleBatchAndDeletesItWhenSuccessful() {
        CaUniverseBatchT batchRow = createBatchRow("TCN-1", "1", "PART-1");
        DmClaimDrugT claimDrug = createClaimDrug("PART-1");

        when(caUniverseBatchRepository.findDistinctBatchIds()).thenReturn(Collections.singletonList(10));
        when(caUniverseBatchRepository.findAllByBatchId(10)).thenReturn(Collections.singletonList(batchRow));
        when(caseBatchUtil.getZoneId()).thenReturn(ZoneId.of("UTC"));
        when(dmClaimDrugRepository.findClaimDrugTbyId(eq("TCN-1"), eq("1"), any())).thenReturn(claimDrug);

        String result = caseBatchService.createBatchCase();

        assertEquals(CaseEntryConstants.SUCCESS_MESSAGE, result);
        verify(caseBatchIndividualService).createIndBatchCaseEntries(any(List.class));
        verify(caUniverseBatchRepository).deleteByBatchId(10);
    }

    @Test
    public void createCaUniverseTListMarksDuplicateClaimsAndReturnsEmptyList() {
        CaUniverseBatchT first = createBatchRow("TCN-1", "1", "PART-1");
        CaUniverseBatchT second = createBatchRow("TCN-1", "1", "PART-1");
        when(caseBatchUtil.getZoneId()).thenReturn(ZoneId.of("UTC"));

        List<CaUniverseT> result = caseBatchService.createCaUniverseTList(Arrays.asList(first, second));

        assertTrue(result.isEmpty());
        assertEquals(CaseEntryConstants.DUPLICATE, first.getRecMatchInd());
        verify(dmClaimDrugRepository, never()).findClaimDrugTbyId(any(), any(), any());
    }

    @Test
    public void createBatchCaseSavesInvalidRowsAndSendsInvalidMailWhenUniverseListShrinks() {
        CaseBatchService spyService = org.mockito.Mockito.spy(caseBatchService);
        CaUniverseBatchT first = createBatchRow("TCN-1", "1", "PART-1");
        CaUniverseBatchT second = createBatchRow("TCN-2", "1", "PART-2");
        first.setRecMatchInd(CaseEntryConstants.NO);
        second.setRecMatchInd(CaseEntryConstants.DUPLICATE);

        CaUniverseT caUniverseT = new CaUniverseT();
        doReturn(new java.util.ArrayList<>(Collections.singletonList(caUniverseT)))
                .when(spyService).createCaUniverseTList(any(List.class));
        when(caUniverseBatchRepository.findDistinctBatchIds()).thenReturn(Collections.singletonList(10));
        when(caUniverseBatchRepository.findAllByBatchId(10)).thenReturn(Arrays.asList(first, second));
        when(caseBatchUtil.getEmailSpecs()).thenReturn(new EmailSpecification());
        when(caUniverseBatchRepository.saveAll(any(List.class))).thenReturn(Arrays.asList(first, second));

        String result = spyService.createBatchCase();

        assertEquals(CaseEntryConstants.SUCCESS_MESSAGE, result);
        verify(caUniverseBatchRepository).saveAll(Arrays.asList(first, second));
        verify(caUniverseBatchRepository).flush();
        verify(caseBatchEmailService).postBatchProcessMail(any(EmailData.class), any(EmailSpecification.class));
        verify(caUniverseBatchRepository, never()).deleteByBatchId(10);
        verify(caseBatchIndividualService, never()).createIndBatchCaseEntries(any(List.class));
    }

    @Test
    public void createBatchCaseSendsFailureNotificationsWhenExceptionOccurs() {
        CaseBatchService spyService = org.mockito.Mockito.spy(caseBatchService);
        CaUniverseBatchT batchRow = createBatchRow("TCN-1", "1", "PART-1");
        RuntimeException failure = new RuntimeException("batch failure");

        doThrow(failure).when(spyService).createCaUniverseTList(any(List.class));
        when(caUniverseBatchRepository.findDistinctBatchIds()).thenReturn(Collections.singletonList(10));
        when(caUniverseBatchRepository.findAllByBatchId(10)).thenReturn(Collections.singletonList(batchRow));
        when(caseBatchUtil.getEmailSpecs()).thenReturn(new EmailSpecification());

        String result = spyService.createBatchCase();

        assertEquals(CaseEntryConstants.SUCCESS_MESSAGE, result);
        verify(caseBatchEmailService, org.mockito.Mockito.times(2))
                .postBatchProcessMail(any(EmailData.class), any(EmailSpecification.class));
        verify(caUniverseBatchRepository, never()).deleteByBatchId(10);
    }

    private CaUniverseBatchT createBatchRow(String hdrClmTcn, String liNum, String participantId) {
        CaUniverseBatchTPK id = new CaUniverseBatchTPK();
        id.setCtBatchId(10);
        id.setCtBatchDate(new Date());

        UiUserBase userBase = new UiUserBase();
        userBase.setUiSystemId("WA123456");

        CaUniverseBatchT row = new CaUniverseBatchT();
        row.setId(id);
        row.setUiUserBase(userBase);
        row.setHdrClmTcn(hdrClmTcn);
        row.setLiNum(liNum);
        row.setHdrClmPdDt(new Date());
        row.setParticipantId(participantId);
        row.setCaseTypeCd("PV");
        row.setProvRole(CaseEntryConstants.PROVIDER_ROLE_BILLING);
        row.setCaPrmNodeCd("PAU");
        row.setCaYearId(2024);
        row.setProjectStatus("N");
        row.setInvstTypeCd(CaseEntryConstants.INVESTIGATION_TYPE_PRELIMINARY);
        row.setLiDrugValidClmInd("Y");
        row.setAssignUsr("WA123456");
        return row;
    }

    private DmClaimDrugT createClaimDrug(String participantId) {
        DmClaimDrugT claimDrug = new DmClaimDrugT();
        claimDrug.setHdrPayToProvId(participantId);
        claimDrug.setHdrPrescrProvId(participantId);
        claimDrug.setHdrRecipOrigId(participantId);
        claimDrug.setHdrRecipFullNm("John Smith");
        claimDrug.setHdrPdAmt(BigDecimal.TEN);
        claimDrug.setLiPdAmt(BigDecimal.ONE);
        claimDrug.setLiBillAmt(BigDecimal.ONE);
        claimDrug.setHdrBillAmt(BigDecimal.ONE);
        return claimDrug;
    }
}
