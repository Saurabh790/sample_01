        studyService = new StudyService();
        inject("studyRepository", studyRepository);
        inject("jobsRepository", jobsRepository);
        inject("fadsConfigRepository", fadsConfigRepository);
        inject("studyMiniMapper", studyMiniMapper);
        inject("studyDetailMapper", studyDetailMapper);
    }

    @Test
    void getStudyAppliesThresholdsAndExceptionProcessesToMatchingItems() {
        long studyId = 10L;
        PrmStudyMasterT entity = new PrmStudyMasterT();
        StudyDTO mapped = new StudyDTO();

        ReportItem unmatchedItem = ReportItem.builder().reportItemId(999L).build();
        ReportSection laterSection = ReportSection.builder()
                .reportSectionId(2L)
                .rsOrder(99L)
                .reportItems(Set.of(unmatchedItem))
                .build();

        ReportItem targetItem = ReportItem.builder().reportItemId(200L).build();
        ReportSection targetSection = ReportSection.builder()
                .reportSectionId(1L)
                .rsOrder(99L)
                .reportItems(Set.of(targetItem))
                .build();

        mapped.setReportSections(Set.of(laterSection, targetSection));
        mapped.setTimePeriods(List.of(TimePeriod.builder().timePeriodId(7L).build()));

        StudyRsRiItem studyItem = StudyRsRiItem.builder()
                .reportSectionId(1L)
                .reportItemId(200L)
                .rsOrder(1L)
                .lowerLimit(BigDecimal.ONE)
                .upperLimit(BigDecimal.TEN)
                .percentage(BigDecimal.valueOf(15))
                .standardDeviation(BigDecimal.valueOf(3))
                .weight(BigDecimal.valueOf(4))
                .build();

        StudyRsRiException exception = StudyRsRiException.builder()
                .reportSectionId(1L)
                .reportItemId(200L)
                .timePeriodId(7L)
                .exceptionFlag(BigDecimal.ONE)
                .overLimitFlag(BigDecimal.ZERO)
                .build();

        when(studyRepository.findById(studyId)).thenReturn(Optional.of(entity));
        when(studyDetailMapper.toStudyDTO(entity)).thenReturn(mapped);
        when(studyDetailMapper.toStudyRsRiItems(any())).thenReturn(List.of(studyItem));
        when(studyDetailMapper.toStudyRsRiExceptions(any())).thenReturn(List.of(exception));

        StudyDTO result = studyService.getStudy(studyId);

        assertNotNull(result);
        ReportSection updatedSection = result.getReportSections().stream()
                .filter(section -> section.getReportSectionId() == 1L)
                .findFirst()
                .orElseThrow();
        ReportItem updatedItem = updatedSection.getReportItems().iterator().next();
        assertEquals(1L, updatedSection.getRsOrder());
        assertEquals(BigDecimal.ONE, updatedItem.getLowerLimit());
        assertEquals(BigDecimal.TEN, updatedItem.getUpperLimit());
        assertEquals(BigDecimal.valueOf(15), updatedItem.getPercentage());
        assertEquals(BigDecimal.valueOf(3), updatedItem.getStandardDeviation());
        assertEquals(BigDecimal.valueOf(4), updatedItem.getWeight());
        assertEquals(1, updatedItem.getExceptionProcesses().size());
        assertEquals(7L, updatedItem.getExceptionProcesses().get(0).getTimePeriodId());
    }

    @Test
    void createStudyBuildsNestedEntitiesIncludingActivityLimitsAndExceptions() {
        StudyDTO studyDTO = baseStudyDto();
        PrmStudyMasterT entity = baseStudyEntity(0L);

        PrmStudyTimePeriodsT timePeriodEntity = PrmStudyTimePeriodsT.builder()
                .id(PrmStudyTimePeriodsTPK.builder().pbId(0L).pbTimePrd(1L).build())
                .build();
        entity.setPrmStudyTimePeriodsTs(new ArrayList<>(List.of(timePeriodEntity)));
        entity.setPrmStudyBpActLimitsTs(new ArrayList<>(List.of(PrmStudyBpActLimitsT.builder()
                .id(PrmStudyBpActLimitsTPK.builder().pbId(0L).bpId(11L).build())
                .vcFlag(BigDecimal.ONE)
                .vcMin(BigDecimal.valueOf(2))
                .vcMax(BigDecimal.valueOf(8))
                .build())));

        when(studyDetailMapper.convertToPrmStudyMasterT(studyDTO)).thenReturn(entity);
        when(studyRepository.getNextStudyId()).thenReturn(321L);
        when(studyRepository.saveAndFlush(any(PrmStudyMasterT.class))).thenAnswer(invocation -> invocation.getArgument(0));
        when(studyDetailMapper.toStudyDTO(any(PrmStudyMasterT.class))).thenReturn(studyDTO);

        StudyDTO result = studyService.createStudy(studyDTO);

        assertNotNull(result);

        ArgumentCaptor<PrmStudyMasterT> captor = ArgumentCaptor.forClass(PrmStudyMasterT.class);
        verify(studyRepository).saveAndFlush(captor.capture());
        PrmStudyMasterT saved = captor.getValue();

        assertEquals(321L, saved.getPbId());
        assertEquals(BigDecimal.ZERO, saved.getPbExcpOnlyFlag());
        assertEquals(BigDecimal.ONE, saved.getPbUseDwFlag());
        assertEquals(BigDecimal.ONE, saved.getPbUseVwFlag());
        assertEquals(1, saved.getPrmStudyTimePeriodsTs().size());
        assertEquals(321L, saved.getPrmStudyTimePeriodsTs().get(0).getId().getPbId());
        assertEquals(studyDTO.getCreateDate(), saved.getPrmStudyTimePeriodsTs().get(0).getCreateDte());
        assertEquals(studyDTO.getUpdateDate(), saved.getPrmStudyTimePeriodsTs().get(0).getUpdateDte());
        assertEquals(1, saved.getPrmStudyBpActLimitsTs().size());
        assertEquals(321L, saved.getPrmStudyBpActLimitsTs().get(0).getId().getPbId());
        assertEquals(11L, saved.getPrmStudyBpActLimitsTs().get(0).getId().getBpId());
        assertEquals(1, saved.getPrmStudyRsRiTs().size());
        assertEquals(321L, saved.getPrmStudyRsRiTs().get(0).getId().getPbId());
        assertEquals(1L, saved.getPrmStudyRsRiTs().get(0).getId().getRsOrder());
        assertEquals(1, saved.getPrmStudyRsRiExceptTs().size());
        assertEquals(321L, saved.getPrmStudyRsRiExceptTs().get(0).getId().getPbId());
        assertEquals(7L, saved.getPrmStudyRsRiExceptTs().get(0).getId().getPbTimePrd());
    }

    @Test
    void updateStudyRebuildsNestedCollectionsForExistingStudyId() {
        StudyDTO studyDTO = baseStudyDto();
        PrmStudyMasterT entity = baseStudyEntity(555L);
        entity.setPrmStudyTimePeriodsTs(new ArrayList<>(List.of(PrmStudyTimePeriodsT.builder()
                .id(PrmStudyTimePeriodsTPK.builder().pbId(555L).pbTimePrd(1L).build())
