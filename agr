        PrmStudyBpActLimitsT activityLimitEntity = new PrmStudyBpActLimitsT();
        activityLimitEntity.setId(activityLimitId);
        activityLimitEntity.setPrmBpBehaviorPatsT(behaviorPattern);
        activityLimitEntity.setVcMin(BigDecimal.valueOf(10));
        activityLimitEntity.setVcMax(BigDecimal.valueOf(20));
