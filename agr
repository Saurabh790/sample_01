<settings xmlns="http://maven.apache.org/SETTINGS/1.0.0"
          xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xsi:schemaLocation="http://maven.apache.org/SETTINGS/1.0.0
                              https://maven.apache.org/xsd/settings-1.0.0.xsd">

  <!-- ===================== -->
  <!-- Mirrors Configuration -->
  <!-- ===================== -->
  <mirrors>
    
    <!-- JFrog for internal artifacts -->
    <mirror>
      <id>jfrog</id>
      <!-- IMPORTANT: do NOT override central -->
      <mirrorOf>*,!central</mirrorOf>
      <url>https://centraluhg.jfrog.io/artifactory/com-optum-omms-maven-releases-vir</url>
    </mirror>

  </mirrors>

  <!-- ===================== -->
  <!-- Servers (Credentials) -->
  <!-- ===================== -->
  <servers>
    
    <server>
      <id>jfrog</id>
      <username>YOUR_USERNAME</username>
      <password>YOUR_PASSWORD</password>
    </server>

  </servers>

  <!-- ===================== -->
  <!-- Profiles -->
  <!-- ===================== -->
  <profiles>
    
    <profile>
      <id>default</id>

      <!-- Repositories -->
      <repositories>
        
        <!-- JFrog Releases -->
        <repository>
          <id>jfrog</id>
          <url>https://centraluhg.jfrog.io/artifactory/com-optum-omms-maven-releases-vir</url>
          <releases>
            <enabled>true</enabled>
          </releases>
          <snapshots>
            <enabled>false</enabled>
          </snapshots>
        </repository>

        <!-- JFrog Snapshots -->
        <repository>
          <id>jfrog-snapshots</id>
          <url>https://centraluhg.jfrog.io/artifactory/com-optum-omms-maven-snapshots</url>
          <releases>
            <enabled>false</enabled>
          </releases>
          <snapshots>
            <enabled>true</enabled>
          </snapshots>
        </repository>

        <!-- Maven Central (CRITICAL for plugins) -->
        <repository>
          <id>central</id>
          <url>https://repo.maven.apache.org/maven2</url>
          <releases>
            <enabled>true</enabled>
          </releases>
          <snapshots>
            <enabled>false</enabled>
          </snapshots>
        </repository>

      </repositories>

      <!-- Plugin Repositories -->
      <pluginRepositories>
        
        <!-- Maven Central for plugins -->
        <pluginRepository>
          <id>central</id>
          <url>https://repo.maven.apache.org/maven2</url>
          <releases>
            <enabled>true</enabled>
          </releases>
          <snapshots>
            <enabled>false</enabled>
          </snapshots>
        </pluginRepository>

        <!-- Optional: JFrog plugins if needed -->
        <pluginRepository>
          <id>jfrog</id>
          <url>https://centraluhg.jfrog.io/artifactory/com-optum-omms-maven-releases-vir</url>
        </pluginRepository>

      </pluginRepositories>

    </profile>

  </profiles>

  <!-- ===================== -->
  <!-- Activate Profile -->
  <!-- ===================== -->
  <activeProfiles>
    <activeProfile>default</activeProfile>
  </activeProfiles>

</settings>
