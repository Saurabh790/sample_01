package com.optum.fads.pgp.datarules.config;

import static org.junit.jupiter.api.Assertions.assertEquals;
import static org.junit.jupiter.api.Assertions.assertNotNull;
import static org.junit.jupiter.api.Assertions.assertThrows;
import static org.junit.jupiter.api.Assertions.assertTrue;

import java.time.Instant;
import java.util.HashMap;
import java.util.List;
import java.util.Map;

import org.junit.jupiter.api.Test;
import org.springframework.mock.web.MockHttpServletRequest;
import org.springframework.security.oauth2.jwt.JwtException;
import org.springframework.test.util.ReflectionTestUtils;
import org.springframework.web.cors.CorsConfiguration;
import org.springframework.web.cors.CorsConfigurationSource;

import com.optum.fads.pgp.datarules.service.IUserDetailsService;

class SecurityConfigTest {

    @Test
    void beanFactoryMethodsCreateExpectedBeans() {
        IUserDetailsService userDetailsService = org.mockito.Mockito.mock(IUserDetailsService.class);
        SecurityConfig config = new SecurityConfig(userDetailsService);
        ReflectionTestUtils.setField(config, "uniqueIdClaims", List.of("email", "preferred_username"));

        assertNotNull(config.userJwtAuthenticationConverter());
        assertNotNull(config.passwordEncoder());

        CorsConfigurationSource source = config.corsConfigurationSource();
        MockHttpServletRequest request = new MockHttpServletRequest();
        request.setRequestURI("/test");
        CorsConfiguration cors = source.getCorsConfiguration(request);
        assertNotNull(cors);
        assertEquals(List.of(CorsConfiguration.ALL), cors.getAllowedOrigins());
        assertEquals(List.of(CorsConfiguration.ALL), cors.getAllowedMethods());
        assertEquals(List.of(CorsConfiguration.ALL), cors.getAllowedHeaders());
    }

    @Test
    void convertDateToInstantConvertsDateValues() {
        IUserDetailsService userDetailsService = org.mockito.Mockito.mock(IUserDetailsService.class);
        SecurityConfig config = new SecurityConfig(userDetailsService);
        Map<String, Object> claims = new HashMap<>();
        java.util.Date issuedAt = java.util.Date.from(Instant.parse("2026-04-01T10:00:00Z"));
        claims.put("iat", issuedAt);

        ReflectionTestUtils.invokeMethod(config, "convertDateToInstant", claims, "iat");

        assertTrue(claims.get("iat") instanceof Instant);
        assertEquals(issuedAt.toInstant(), claims.get("iat"));
    }

    @Test
    void convertDateToInstantLeavesNonDateValuesUntouched() {
        IUserDetailsService userDetailsService = org.mockito.Mockito.mock(IUserDetailsService.class);
        SecurityConfig config = new SecurityConfig(userDetailsService);
        Map<String, Object> claims = new HashMap<>();
        claims.put("iat", "already-a-string");

        ReflectionTestUtils.invokeMethod(config, "convertDateToInstant", claims, "iat");

        assertEquals("already-a-string", claims.get("iat"));
    }

    @Test
    void jwtDecoderThrowsForInvalidToken() {
        IUserDetailsService userDetailsService = org.mockito.Mockito.mock(IUserDetailsService.class);
        SecurityConfig config = new SecurityConfig(userDetailsService);

        JwtException ex = assertThrows(JwtException.class, () -> config.jwtDecoder().decode("not-a-jwt"));

        assertTrue(ex.getMessage().contains("Failed to parse JWT"));
    }
}
