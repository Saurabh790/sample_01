package com.optum.fads.caseentrybatch.api.exception;

import static org.junit.Assert.assertEquals;
import static org.junit.Assert.assertSame;

import org.junit.Test;
import org.springframework.http.HttpStatus;

public class PiApiExceptionTest {

    private enum TestErrorDetail implements ErrorDetail {
        SAMPLE;

        @Override
        public String getMessage() {
            return "Error for {}";
        }

        @Override
        public String getCode() {
            return "CASE_001";
        }

        @Override
        public HttpStatus getHttpStatus() {
            return HttpStatus.BAD_REQUEST;
        }
    }

    @Test
    public void constructorWithErrorDetailSetsMessageCodeAndStatus() {
        PiApiException exception = new PiApiException(TestErrorDetail.SAMPLE);

        assertEquals("Error for {}", exception.getMessage());
        assertEquals("CASE_001", exception.getErrorCode());
        assertSame(HttpStatus.BAD_REQUEST, exception.getHttpStatus());
    }

    @Test
    public void constructorFormatsMessageArguments() {
        PiApiException exception = new PiApiException(TestErrorDetail.SAMPLE, "batch");

        assertEquals("Error for batch", exception.getMessage());
        assertEquals("CASE_001", exception.getErrorCode());
        assertSame(HttpStatus.BAD_REQUEST, exception.getHttpStatus());
    }

    @Test
    public void constructorWithCausePreservesCause() {
        IllegalStateException cause = new IllegalStateException("boom");

        PiApiException exception = new PiApiException(TestErrorDetail.SAMPLE, cause, "batch");

        assertEquals("Error for batch", exception.getMessage());
        assertSame(cause, exception.getCause());
        assertEquals("CASE_001", exception.getErrorCode());
        assertSame(HttpStatus.BAD_REQUEST, exception.getHttpStatus());
    }
}
package com.optum.fads.caseentrybatch.api.job;

import static org.mockito.Mockito.times;
import static org.mockito.Mockito.verify;

import org.junit.Test;
import org.junit.runner.RunWith;
import org.mockito.InjectMocks;
import org.mockito.Mock;
import org.mockito.junit.MockitoJUnitRunner;
import org.quartz.JobExecutionContext;
import org.springframework.test.util.ReflectionTestUtils;

import com.optum.fads.caseentrybatch.api.service.ICaseBatchService;

@RunWith(MockitoJUnitRunner.class)
public class CaseEntryBatchJobTest {

    @Mock
    private ICaseBatchService caseBatchService;

    @Mock
    private JobExecutionContext context;

    @InjectMocks
    private TestableCaseEntryBatchJob job;

    @Test
    public void executeInternalDelegatesToBatchService() throws Exception {
        ReflectionTestUtils.setField(job, "iCaseBatchService", caseBatchService);

        job.run(context);

        verify(caseBatchService, times(1)).createBatchCase();
    }

    private static class TestableCaseEntryBatchJob extends CaseEntryBatchJob {
        void run(JobExecutionContext context) throws Exception {
            executeInternal(context);
        }
    }
}
