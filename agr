        notice.setNoticeId(CaseEntryConstants.BATCH_FAIL_NOTIFICATION_ADMIN);
        notice.setNoticeFlag(CaseEntryConstants.ONE_STR);
        notice.setSubjEmail("Admin [BATCH ID]");
        notice.setRemComment("Errors: [error log info]");

        CaseConfigT config = new CaseConfigT();
        config.setOptionCode(CaseEntryConstants.SYSTEM_ADMIN_DIST_LIST);
        config.setOptionValue("admin@test.com");

        EmailData emailData = new EmailData();
        emailData.setNoticeId(CaseEntryConstants.BATCH_FAIL_NOTIFICATION_ADMIN);
        emailData.setBatchId(99);
        emailData.setErrorLog("claim issue");

        when(caMetaBaseNoticeRepository.findById(CaseEntryConstants.BATCH_FAIL_NOTIFICATION_ADMIN)).thenReturn(Optional.of(notice));
        when(caseConfigRepository.findById(CaseEntryConstants.SYSTEM_ADMIN_DIST_LIST)).thenReturn(Optional.of(config));
        when(caLuValuesRepository.findByIdFieldId(CaseEntryConstants.INVST_TYPE_CODE)).thenReturn(Collections.emptyList());
        when(caseBatchUtil.sendMail(emailSpecification)).thenReturn(true);
        when(caEmailsBatchRepository.getNextSequenceId(99)).thenReturn(3);
        when(caseBatchUtil.getCtAdminSystemId()).thenReturn("CT_ADMIN");
        when(caseBatchUtil.getZoneId()).thenReturn(ZoneId.of("Asia/Calcutta"));

        caseBatchEmailService.postBatchProcessMail(emailData, emailSpecification);

        assertEquals("admin@test.com", emailSpecification.getSendToEmail());
        assertEquals("Admin 99", emailSpecification.getEmailSubject());
        verify(caEmailsBatchRepository).saveAndFlush(any(CaEmailsBatchT.class));
    }

