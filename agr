package com.optum.fads.pgp.behavior.api.repo;

import org.springframework.data.jpa.repository.JpaRepository;
import org.springframework.data.jpa.repository.Modifying;
import org.springframework.data.jpa.repository.Query;
import org.springframework.data.repository.query.Param;
import org.springframework.stereotype.Repository;
import org.springframework.transaction.annotation.Transactional;

import com.optum.fads.pgp.behavior.api.domain.PrmErExtractRuleT;

@Transactional
@Repository
public interface BehaviorPatternErRepository extends JpaRepository<PrmErExtractRuleT, Integer> {

    @Modifying
    @Query("delete from PrmErExtractRuleT er where er.erId = :erId")
    int deleteErById(@Param("erId") Integer erId);

    @Query("from PrmErExtractRuleT er where er.erId = :erId")
    PrmErExtractRuleT getExtractRuleById(@Param("erId") Integer erId);

    @Query("select coalesce(max(er.erId), 0) + 1 from PrmErExtractRuleT er")
    Integer retrieveNextErId();
}



