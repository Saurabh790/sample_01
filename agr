@ExtendWith(MockitoExtension.class)
class UserDetailsServiceTest {

    @Mock
    private UserRepository userRepository;

    @InjectMocks
    private UserDetailsService service;

    @Test
    void loadUserByUsernameMapsNestedRoleAndAccesses() {
        when(userRepository.findByUiEMailAddressOrUiUserId("creator", "creator"))
                .thenReturn(Optional.of(buildUser()));

        AppUser result = (AppUser) service.loadUserByUsername("creator");

        assertEquals("creator@optum.com", result.getUserEmail());
        assertEquals("creator", result.getUserId());
        assertEquals("SYS1", result.getUserSystemId());
        assertEquals("7", result.getRole().getId());
        assertEquals("Admins", result.getRole().getRoleName());
        assertEquals(1, result.getRole().getAllowedAccesses().size());
        assertEquals("1", result.getRole().getAllowedAccesses().get(0).getId());
        assertEquals("STUDY", result.getRole().getAllowedAccesses().get(0).getName());
        assertEquals("Study Module", result.getRole().getAllowedAccesses().get(0).getLabel());
        assertEquals("RW", result.getRole().getAllowedAccesses().get(0).getValue());
    }

    @Test
    void loadUserByUsernameThrowsWhenUserMissing() {
        when(userRepository.findByUiEMailAddressOrUiUserId("missing", "missing")).thenReturn(Optional.empty());

        assertThrows(UsernameNotFoundException.class, () -> service.loadUserByUsername("missing"));
    }

    private UiUserBase buildUser() {
        UiUserBase user = new UiUserBase();
        user.setUiEMailAddress("creator@optum.com");
        user.setUiUserId("creator");
        user.setUiSystemId("SYS1");

        SeSurAccess access = new SeSurAccess();
        access.setSurAccessId("RW");

        SeSurModule module = new SeSurModule();
        module.setSurModuleId("1");
        module.setSurModuleName("Study Module");

        SeSurGrpModAccessPK id = new SeSurGrpModAccessPK();
        id.setSurGrpId(7L);
        id.setSurModuleId("1");

        SeSurGrpModAccess modAccess = new SeSurGrpModAccess();
        modAccess.setId(id);
        modAccess.setSeSurAccess(access);
        modAccess.setSeSurModule(module);

        SeSurGrp surGrp = new SeSurGrp();
        surGrp.setSurGrpId(7L);
        surGrp.setSurGrpName("Admins");
        surGrp.setSeSurGrpModAccesses(List.of(modAccess));

        SeUsrGrp usrGrp = new SeUsrGrp();
        usrGrp.setSeSurGrp(surGrp);
        user.setSeUsrGrp(usrGrp);
        return user;
    }
}
