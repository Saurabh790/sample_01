/**
 * The ResponseBuilder holds all the methods used to build API response.
 */
@Component
public class ResponseBuilder {

	private final String serviceName;

    @Autowired
    private Tracer tracer;

	private final DateTimeFormatter formatter = DateTimeFormatter.ofPattern("yyyy-MM-dd'T'HH:mm:ss");

	/**
	 * Constructor.
	 *
	 * @param serviceName name of the service
	 */
	@Autowired
	public ResponseBuilder(@Value("${spring.application.name}") final String serviceName, Tracer tracer) {
		this.serviceName = serviceName;
		this.tracer = tracer;
	}

	/**
	 * Builds an empty response.
	 *
	 * @return response
	 */
	public RestResponse buildEmptyResponse() {
		return RestResponse.builder().meta(buildMeta()).build();
	}

	/**
	 * Builds response for a valid request with single result.
	 *
	 * @param <T>    type of the result
	 * @param result result
	 * @return response
	 */
	public <T> ResponseData<T> buildResponse(final T result) {
		return buildResponseWithoutResultMeta(result);
	}

	/**
	 * Builds response for a valid request with single result that has more than one
	 * total record.
	 *
	 * @param <T>                  type of the result
	 * @param result               result
	 * @param totalNumberOfRecords total number of records
	 * @return response
	 */
	public <T> Response<T> buildResponse(final T result, final long totalNumberOfRecords) {
		final var resultMeta = ResultMeta.builder().numberOfRecords(1).totalNumberOfRecords(totalNumberOfRecords)
				.build();
		final var responseResult = ResponseResult.<T>builder().data(result).resultMeta(resultMeta).build();
		return Response.<T>builderResponse().meta(buildMeta()).result(responseResult).build();
	}

	/**
	 * Builds response for a valid request with result object that may contain a
	 * response object. The numberOfRecords could be set explicitly which may not be
	 * derived by just the result object.
	 *
	 * @param <T>                  type of the result
	 * @param result               result
	 * @param numberOfRecords      number of records with search results
	 * @param totalNumberOfRecords total number of records
	 * @return response
	 */
	public <T> Response<T> buildResponse(final T result, final int numberOfRecords, final long totalNumberOfRecords) {
		final var resultMeta = ResultMeta.builder().numberOfRecords(numberOfRecords)
				.totalNumberOfRecords(totalNumberOfRecords).build();
		final var responseResult = ResponseResult.<T>builder().data(result).resultMeta(resultMeta).build();
		return Response.<T>builderResponse().meta(buildMeta()).result(responseResult).build();
	}

	/**
	 * Builds response for a valid request with result object that may contain a
	 * response object. Adding numberOfPages
	 *
	 * @param <T>                  type of the result
	 * @param result               result
	 * @param numberOfRecords      number of records with search results
	 * @param numberOfPages        total number of pages
	 * @param totalNumberOfRecords total number of records
	 * @return response
	 */
	public <T> Response<T> buildResponse(final T result, final int numberOfRecords, final int numberOfPages,
			final long totalNumberOfRecords) {
		final var resultMeta = ResultMeta.builder().numberOfRecords(numberOfRecords).numberOfPages(numberOfPages)
				.totalNumberOfRecords(totalNumberOfRecords).build();
		final var responseResult = ResponseResult.<T>builder().data(result).resultMeta(resultMeta).build();
		return Response.<T>builderResponse().meta(buildMeta()).result(responseResult).build();
	}

	/**
	 * Builds response for a valid request with a list of results.
	 *
	 * @param results results
	 * @return response
	 */
	public <T> Response<List<T>> buildResponse(final List<T> results) {
		return buildResponse(results, CollectionUtils.isEmpty(results) ? 0 : results.size());
	}

	/**
	 * Builds response for a valid request with a partial list of results.
	 *
	 * @param results              results
	 * @param totalNumberOfRecords the total number of records
	 * @return response
	 */
	public <T> Response<List<T>> buildResponse(final List<T> results, final long totalNumberOfRecords) {
		final var resultMeta = ResultMeta.builder()
				.numberOfRecords(CollectionUtils.isEmpty(results) ? 0 : results.size())
				.totalNumberOfRecords(totalNumberOfRecords).build();
		final var result = ResponseResult.<List<T>>builder().data(results).resultMeta(resultMeta).build();
		return Response.<List<T>>builderResponse().meta(buildMeta()).result(result).build();
	}

	/**
	 * Builds a responseEntity with single result and the given httpStatus code
	 *
	 * @param <T>        type of the result
	 * @param result     result
	 * @param httpStatus the httpStatus code for the response
	 * @return response
	 */
	public <T> ResponseEntity<ResponseData<T>> buildResponseEntity(final T result, HttpStatus httpStatus) {
		return new ResponseEntity<>(buildResponseWithoutResultMeta(result), httpStatus);
	}

	/**
	 * Builds an error response for the given exceptions.
	 *
	 * @param exceptions exceptions with error details
	 * @return ErrorResponse object populated for the exception
	 */
	public ErrorResponse buildErrorResponse(final Collection<StudyApiException> exceptions) {
		return buildErrorResponse(exceptions.stream());
	}

	/**
	 * s Builds an error response for the given exceptions.
	 *
	 * @param exceptions exceptions with error details
	 * @return ErrorResponse object populated for the exception
	 */
	public ErrorResponse buildErrorResponse(final StudyApiException... exceptions) {
		return buildErrorResponse(Arrays.stream(exceptions));
	}

	/**
	 * Builds an error response for the given exceptions.
	 *
	 * @param exceptions stream of PiApiExceptions
	 * @return ErrorResponse object populated for the exception
	 */
	public ErrorResponse buildErrorResponse(final Stream<StudyApiException> exceptions) {
		final var errorResults = exceptions.map(exception -> ErrorResult.builder().code(exception.getErrorCode())
				.message(exception.getMessage()).build()).collect(toList());
		return ErrorResponse.builderErrorResponse().meta(buildMeta()).errors(errorResults).build();
	}

	public <T> ResponseData<T> buildResponseWithoutResultMeta(final T result) {
		final var responseResultData = ResponseResultData.<T>builder().data(result).build();
		return ResponseData.<T>builderResponseData().meta(buildMeta()).result(responseResultData).build();
	}

	/**
	 * Builds result meta data
	 *
	 * @return meta data
	 */
	private ResponseMeta buildMeta() {
		return ResponseMeta.builder().date(LocalDateTime.now(ZoneOffset.UTC))
				.correlationId(tracer.currentSpan().context().traceIdString()).serviceName(serviceName).build();
	}

}
