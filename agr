    private PrmDrDataRuleT buildRuleWithoutValues(int dataRuleId, String name) {
        UiUserBase creator = new UiUserBase();
        creator.setUiSystemId("creator");
        creator.setUiFirstName("Test");
        creator.setUiLastName("Creator");

        UiUserBase updater = new UiUserBase();
        updater.setUiSystemId("updater");
        updater.setUiFirstName("Test");
        updater.setUiLastName("Updater");

        PrmMbMasterT mbMaster = new PrmMbMasterT();
        mbMaster.setMbCtecFid(801);
        mbMaster.setMbCustDatadesc("Age");
        mbMaster.setMbCtecFtype("CHAR");

        PrmDrLuOperatorT operator = new PrmDrLuOperatorT();
        operator.setOperatorCd("EQ");

        PrmDrDataRuleT rule = new PrmDrDataRuleT();
        rule.setDrId(dataRuleId);
        rule.setDataRuleName(name);
        rule.setCreateDate(LocalDateTime.of(2026, 4, 1, 10, 0));
        rule.setUpdateDate(LocalDateTime.of(2026, 4, 1, 11, 0));
        rule.setUiUserBaseCr(creator);
        rule.setUiUserBaseUpd(updater);
        rule.setPrmMbMasterT(mbMaster);
        rule.setPrmDrLuOperatorT(operator);
        rule.setPrmDrSingleValuesTs(List.of());
        rule.setPrmDrRangesTs(List.of());
        return rule;
    }

    private PrmDrDataRuleT buildRule() {
        PrmDrDataRuleT rule = buildRuleWithoutValues(5001, "alpharule");

        PrmDrSingleValuesTPK singleId = new PrmDrSingleValuesTPK();
        singleId.setDrId(5001);
        singleId.setDrValue("A");
        PrmDrSingleValuesT singleValue = new PrmDrSingleValuesT();
        singleValue.setId(singleId);
        singleValue.setDrLabel("Adult");

        PrmDrRangesTPK rangeId = new PrmDrRangesTPK();
        rangeId.setDrId(5001);
        rangeId.setSeqNum(1L);
        PrmDrRangesT rangeValue = new PrmDrRangesT();
        rangeValue.setId(rangeId);
        rangeValue.setDrRangeFrom("10");
        rangeValue.setDrRangeTo("20");

        rule.setPrmDrSingleValuesTs(List.of(singleValue));
        rule.setPrmDrRangesTs(List.of(rangeValue));
        return rule;
    }
