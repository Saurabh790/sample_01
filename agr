class ResponseBuilderTest {

    private ResponseBuilder responseBuilder;

    @BeforeEach
    void setUp() {
        Tracer tracer = mock(Tracer.class);
        Span span = mock(Span.class);
        TraceContext traceContext = TraceContext.newBuilder().traceId(123L).spanId(456L).sampled(true).build();

        when(tracer.currentSpan()).thenReturn(span);
        when(span.context()).thenReturn(traceContext);

        responseBuilder = new ResponseBuilder("study-api", tracer);
    }

    @Test
    void buildEmptyResponseIncludesMeta() {
        RestResponse response = responseBuilder.buildEmptyResponse();

        assertNotNull(response.getMeta());
        assertEquals("study-api", response.getMeta().getServiceName());
        assertEquals("000000000000007b", response.getMeta().getCorrelationId());
    }

    @Test
    void buildSingleResponseWithoutMetaWrapsData() {
        ResponseData<String> response = responseBuilder.buildResponse("value");

        assertEquals("study-api", response.getMeta().getServiceName());
        assertEquals("value", response.getResult().getData());
    }

    @Test
    void buildListResponseCalculatesRecordCounts() {
        Response<List<String>> response = responseBuilder.buildResponse(List.of("a", "b"), 4L);

        assertEquals(2, response.getResult().getResultMeta().getNumberOfRecords());
        assertEquals(4L, response.getResult().getResultMeta().getTotalNumberOfRecords());
        assertEquals(List.of("a", "b"), response.getResult().getData());
    }

    @Test
    void buildPagedResponseIncludesPagesAndTotals() {
        Response<String> response = responseBuilder.buildResponse("row", 1, 3, 10L);

        assertEquals(1, response.getResult().getResultMeta().getNumberOfRecords());
        assertEquals(3, response.getResult().getResultMeta().getNumberOfPages());
        assertEquals(10L, response.getResult().getResultMeta().getTotalNumberOfRecords());
    }

    @Test
    void buildResponseEntityUsesProvidedStatus() {
        ResponseEntity<ResponseData<String>> response = responseBuilder.buildResponseEntity("saved", HttpStatus.CREATED);

        assertEquals(HttpStatus.CREATED, response.getStatusCode());
        assertEquals("saved", response.getBody().getResult().getData());
    }

    @Test
    void buildErrorResponseMapsExceptionDetails() {
        StudyApiException first = new StudyApiException(errorDetail("E1", "First"));
        StudyApiException second = new StudyApiException(errorDetail("E2", "Second"));

        ErrorResponse response = responseBuilder.buildErrorResponse(first, second);

        assertEquals(2, response.getErrors().size());
        assertEquals("E1", response.getErrors().get(0).getCode());
        assertEquals("Second", response.getErrors().get(1).getMessage());
    }

    @Test
    void buildResponseWithoutResultMetaLeavesMetaOnlyResultPayload() {
        ResponseData<String> response = responseBuilder.buildResponseWithoutResultMeta("plain");

        assertEquals("plain", response.getResult().getData());
        assertSame("study-api", response.getMeta().getServiceName());
        assertTrue(response.getMeta().getDate() != null);
    }

    private static ErrorDetail errorDetail(String code, String message) {
        return new ErrorDetail() {
            @Override
            public String getMessage() {
                return message;
            }

            @Override
            public String getCode() {
                return code;
            }

            @Override
            public HttpStatus getHttpStatus() {
                return HttpStatus.BAD_REQUEST;
            }
        };
    }
}
