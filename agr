import com.optum.fads.pgp.datarules.service.IUserDetailsService;

class SecurityConfigTest {

    @Test
    void beanFactoryMethodsCreateExpectedBeans() {
        IUserDetailsService userDetailsService = org.mockito.Mockito.mock(IUserDetailsService.class);
        SecurityConfig config = new SecurityConfig(userDetailsService);
        ReflectionTestUtils.setField(config, "uniqueIdClaims", List.of("email", "preferred_username"));

        assertNotNull(config.userJwtAuthenticationConverter());
        assertNotNull(config.passwordEncoder());

        CorsConfigurationSource source = config.corsConfigurationSource();
        CorsConfiguration cors = source.getCorsConfiguration(null);
        assertNotNull(cors);
        assertEquals(List.of(CorsConfiguration.ALL), cors.getAllowedOrigins());
        assertEquals(List.of(CorsConfiguration.ALL), cors.getAllowedMethods());
        assertEquals(List.of(CorsConfiguration.ALL), cors.getAllowedHeaders());
    }

    @Test
    void jwtDecoderThrowsForInvalidToken() {
        IUserDetailsService userDetailsService = org.mockito.Mockito.mock(IUserDetailsService.class);
        SecurityConfig config = new SecurityConfig(userDetailsService);

        JwtException ex = assertThrows(JwtException.class, () -> config.jwtDecoder().decode("not-a-jwt"));

        assertTrue(ex.getMessage().contains("Failed to parse JWT"));
    }
}
package com.optum.fads.pgp.datarules.config;

import static org.junit.jupiter.api.Assertions.assertEquals;
import static org.junit.jupiter.api.Assertions.assertInstanceOf;
import static org.mockito.Mockito.when;

import org.junit.jupiter.api.Test;
import org.springframework.jdbc.datasource.DriverManagerDataSource;
import org.springframework.test.util.ReflectionTestUtils;

import com.azure.security.keyvault.secrets.SecretClient;
import com.azure.security.keyvault.secrets.models.KeyVaultSecret;

class ServiceConfigTest {

    @Test
    void customDataSourceUsesSecretsFromKeyVaultClient() {
        SecretClient secretClient = org.mockito.Mockito.mock(SecretClient.class);
        when(secretClient.getSecret("db-user")).thenReturn(new KeyVaultSecret("db-user", "sa"));
        when(secretClient.getSecret("db-password")).thenReturn(new KeyVaultSecret("db-password", "pwd"));

        ServiceConfig config = new ServiceConfig(secretClient);
        ReflectionTestUtils.setField(config, "userNameSecretName", "db-user");
        ReflectionTestUtils.setField(config, "passwordSecretName", "db-password");
        ReflectionTestUtils.setField(config, "jdbcUrl", "jdbc:h2:mem:testdb");
        ReflectionTestUtils.setField(config, "driverClassName", "org.h2.Driver");

        var dataSource = config.customDataSource();

        assertInstanceOf(DriverManagerDataSource.class, dataSource);
        DriverManagerDataSource ds = (DriverManagerDataSource) dataSource;
        assertEquals("org.h2.Driver", ds.getDriverClassName());
        assertEquals("jdbc:h2:mem:testdb", ds.getUrl());
        assertEquals("sa", ds.getUsername());
        assertEquals("pwd", ds.getPassword());
    }
}
