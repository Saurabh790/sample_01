        if (optional.isPresent()) {
            caClaimCorrectionsT = (CaClaimCorrectionsT) optional.get();
        } else {
            caClaimCorrectionsT = new CaClaimCorrectionsT();
        }
        ClaimDTO sourceClaim = claimCorrectionMapper.getSourceClaim(caUniverseT);
        ClaimDTO auditClaim = claimCorrectionMapper.getAuditedClaim(caClaimCorrectionsT);
        ClaimCorrectionDTO claimCorrectionDTO = ClaimCorrectionDTO.builder()
                .caseId(caseId)
                .clmSeqNum(clmSeqNum)
                .hdrClmPdDt(caClaimCorrectionsT.getHdrClmPdDt())
                .hdrClmTcn(caClaimCorrectionsT.getHdrClmTcn())
                .liNum(caClaimCorrectionsT.getLiNum())
                .docReceivedInd(caClaimCorrectionsT.getDocReceivedInd())
                .sourceClaim(sourceClaim)
                .auditClaim(auditClaim).build();
        return claimCorrectionDTO;
    }




    /**
     * @param claimCorrectionDTO
     * @param userSystemId
     */
    @Override
    public void updateClaimCorrection(ClaimCorrectionDTO claimCorrectionDTO, String userSystemId) {
        int val = 0;
        if (claimCorrectionDTO.getAuditClaim().getHdrPdAmt() == null) {
       	 claimCorrectionDTO.getAuditClaim().setHdrPdAmt(0.0);
        }
        Optional<CaClaimCorrectionsT> optional = claimCorrectionsRepo.findById(CaClaimCorrectionsTId.builder().caseId(claimCorrectionDTO.getCaseId()).clmSeqNum(claimCorrectionDTO.getClmSeqNum()).build());
        if (optional.isPresent()) {
            CaClaimCorrectionsT existingCaClaimCorrectionsT = (CaClaimCorrectionsT) optional.get();
            CaClaimCorrectionsT currentCaClaimCorrectionsT = claimCorrectionMapper.convertToCaClaimCorrectionsT(claimCorrectionDTO);
            val = new CaClaimCorrectionsComparator().compare(existingCaClaimCorrectionsT, currentCaClaimCorrectionsT);
            if(val != 0) {
                if ( existingCaClaimCorrectionsT.getHdrPdAmt() ==  null ||
                	  (!existingCaClaimCorrectionsT.getHdrPdAmt().equals(currentCaClaimCorrectionsT.getHdrPdAmt()))){
	                caClaimListRepo.updateClaimCorrectPdAmt(claimCorrectionDTO.getCaseId(),claimCorrectionDTO.getClmSeqNum(),currentCaClaimCorrectionsT.getHdrPdAmt());
                	Optional<CaseConfigT>  optionalCaseConfigT = caseConfigRepo.findById(CustomFieldConstant.CLAIM_CORR_FIN_UPD);
                    if(optionalCaseConfigT.isPresent()) {
                    	CaseConfigT caseConfigT= (CaseConfigT)optionalCaseConfigT.get();
                        if(caseConfigT.getOptionValue().equalsIgnoreCase("Y")) {
                        	updateFinancialTerms(claimCorrectionDTO.getCaseId());
                        }
                    }  
	            }
            }
        }
        CaClaimCorrectionsT caClaimCorrectionsT = claimCorrectionMapper.convertToCaClaimCorrectionsT(claimCorrectionDTO);
        claimCorrectionsRepo.saveAndFlush(caClaimCorrectionsT);
         if (val != 0) {
         //    Integer histSeqId = caClaimCorrectionsHistRepo.getNextSequnceId(claimCorrectionDTO.getCaseId());
             Integer histSeqId = caClaimCorrectionsHistRepo.getNextClmCorrHistSequenceId(claimCorrectionDTO.getCaseId(), 
            		 claimCorrectionDTO.getClmSeqNum());
             if(histSeqId == null) {
                 histSeqId = Integer.valueOf(1);
             }
            CaClaimCorrectionsHistT caClaimCorrectionsHistT=claimCorrectionMapper.convertToCaClaimCorrectionsHisT(claimCorrectionDTO);
            caClaimCorrectionsHistT.getId().setHistSeqNum(histSeqId);
          //  caClaimCorrectionsHistT.setChangeDt(Instant.now());
    		caClaimCorrectionsHistT.setChangeDt(LocalDateTime.now(getZoneId()));
            caClaimCorrectionsHistT.setChangeUsr(UiUserBase.builder().uiSystemId(userSystemId).build());
            caClaimCorrectionsHistT.setCaIntelligentKeyT(CaIntelligentKeyT.builder().id(claimCorrectionDTO.getCaseId()).build());
            caClaimCorrectionsHistRepo.save(caClaimCorrectionsHistT);
        }
         AtomicInteger amtInFinding = new AtomicInteger(0);
        if (claimCorrectionDTO.getFindingObservations() != null && claimCorrectionDTO.getFindingObservations().size() > 0) {
            claimCorrectionDTO.getFindingObservations().stream().forEach(e -> {
                if(FindingOperation.NEW.equals(e.getOperation())){
                    BigDecimal versionNextSequenceId =null;
                    CaClaimFindingsObsT caClaimFindingsObsT = claimFindingsObsMapper.convertToCaClaimFindingsObsT(e);
                    caClaimFindingsObsT.getId().setCaseId(claimCorrectionDTO.getCaseId());
                    caClaimFindingsObsT.setClmSeqNum(caClaimCorrectionsT.getId().getClmSeqNum());
                    caClaimFindingsObsT.setHdrClmTcn(caClaimCorrectionsT.getHdrClmTcn());
                    caClaimFindingsObsT.setFindingsObsDt(LocalDateTime.now(getZoneId()));
                    caClaimFindingsObsT.setCaIntelligentKeyT(CaIntelligentKeyT.builder().id(claimCorrectionDTO.getCaseId()).build());
                    caClaimFindingsObsT.setFindingsObsUser(UiUserBase.builder().uiSystemId(userSystemId).build());
                    caClaimFindingsObsT.setCorrectPdAmt(claimCorrectionDTO.getAuditClaim().getHdrPdAmt());
                    amtInFinding.getAndIncrement();
                    BigDecimal nextId = caClaimFindingsObsRepo.getNextSequnceId(caClaimFindingsObsT.getId().getCaseId());
                    if(nextId == null) {
                        nextId = new BigDecimal(1);
                    }
                    caClaimFindingsObsT.getId().setSeqNum(nextId);
                    if(caClaimFindingsObsT.getDiscrepancyTypeCd().equalsIgnoreCase("O")) {
                        versionNextSequenceId = caClaimFindingsObsRepo.getNextObservationVersionSequnceId(caClaimFindingsObsT.getId().getCaseId(),caClaimFindingsObsT.getClmSeqNum());
                    } else{
                        versionNextSequenceId = caClaimFindingsObsRepo.getNextVersionSequnceId(caClaimFindingsObsT.getId().getCaseId(),caClaimFindingsObsT.getClmSeqNum(), caClaimFindingsObsT.getFindingsVersionCd());
                    }

                    if(versionNextSequenceId == null) {
                        versionNextSequenceId = new BigDecimal(1);
                    }
                    caClaimFindingsObsT.setVersionSeqNum(versionNextSequenceId);
                    caClaimFindingsObsRepo.save(caClaimFindingsObsT);

                }else if(FindingOperation.DELETE.equals(e.getOperation())) {
                    CaClaimFindingsObsTId caClaimFindingsObsTId=  CaClaimFindingsObsTId.builder().caseId(claimCorrectionDTO.getCaseId()).seqNum(BigDecimal.valueOf(e.getSeqNum())).build();
                    Optional<CaClaimFindingsObsT>  optionalCaClaimFindingsObsT = caClaimFindingsObsRepo.findById(caClaimFindingsObsTId);
                    if(optionalCaClaimFindingsObsT.isPresent()) {
                        CaClaimFindingsObsT caClaimFindingsObsT= (CaClaimFindingsObsT)optionalCaClaimFindingsObsT.get();
                        caClaimFindingsObsT.setDeleteFlag(FindingOperation.DELETE_FLAG);
                        caClaimFindingsObsRepo.save(caClaimFindingsObsT);
                    }
                }



            });
        }
        if (amtInFinding.get() == 0) {
        	List<CaClaimFindingsObsT> caClaimFindingsObsTList = caClaimFindingsObsRepo.findByMaxVersionMinSeq(claimCorrectionDTO.getCaseId(), 
        			claimCorrectionDTO.getHdrClmTcn(), claimCorrectionDTO.getClmSeqNum());
        	if (!caClaimFindingsObsTList.isEmpty()) {
        		if (caClaimFindingsObsTList.size() > 1) {
        			Collections.sort(caClaimFindingsObsTList, FINDINGS_VERSION_SEQ_ASC_ORDER);
        		}
        		CaClaimFindingsObsT caClaimFindingsObsT = caClaimFindingsObsTList.get(0);
        		caClaimFindingsObsT.setCorrectPdAmt(claimCorrectionDTO.getAuditClaim().getHdrPdAmt());
	            caClaimFindingsObsRepo.save(caClaimFindingsObsT);
        	}
        }
        

    }
    
    /**
     * @param CaseId
     */
    @Override
    public void updateFinancialTerms(Integer caseId) {
    	
    	BigDecimal sumCorrectPdAmt = BigDecimal.ZERO;
    	BigDecimal sumHdrPdAmt = BigDecimal.ZERO;
    	BigDecimal totalPaidAmt = BigDecimal.ZERO;
    	List<CaClaimListT> caClaimsList = caClaimListRepo.findClaimsByCaseId(caseId);
    	/*
    	caClaimsList.stream().forEach(claim->{
    		sumCorrectPdAmt = sumCorrectPdAmt.add(claim.getCtCorrectPdAmt());
    		sumHdrPdAmt = sumHdrPdAmt.add(claim.getHdrPdAmt());	
		});
    	*/
    	for (CaClaimListT claim: caClaimsList) {
    		sumCorrectPdAmt = sumCorrectPdAmt.add(claim.getCtCorrectPdAmt());
    		sumHdrPdAmt = sumHdrPdAmt.add(claim.getHdrPdAmt());	
    	}
    	BigDecimal recoupAmt =  sumHdrPdAmt.subtract(sumCorrectPdAmt);
    	BigDecimal outstandAmt =  recoupAmt.subtract(totalPaidAmt);
    	Integer financialTermsCount = caFinancialTermsRepo.getFinancialTermsCount(caseId);
    	if (financialTermsCount == null || financialTermsCount ==0) {
    		//createFinancialTermsEntry(caseId, recoupAmt, informalAmt, finCustAmtA, totalPaidAmt, outstandAmt);
    		createFinancialTermsEntry(caseId, recoupAmt, sumCorrectPdAmt, sumHdrPdAmt, totalPaidAmt, outstandAmt);
    	} else {
    		Optional<CaFinancialTermsT> optional = caFinancialTermsRepo.findById(caseId);
    		if (optional.isPresent()) {
    			CaFinancialTermsT caFinancialTermsT = optional.get();
    			totalPaidAmt = caFinancialTermsT.getTotalPaidAmt();
    			outstandAmt =  recoupAmt.subtract(totalPaidAmt);
    		}
    		log.info(" Update caFinancialTermsT Case ID " + caseId);
    		caFinancialTermsRepo.updateFinancialTermsT(caseId,recoupAmt,sumCorrectPdAmt,sumHdrPdAmt,outstandAmt);
    	}
    }
    
    public void createFinancialTermsEntry(Integer caseId, BigDecimal recoupAmt, BigDecimal sumCorrectPdAmt, BigDecimal sumHdrPdAmt, 
    		BigDecimal totalPaidAmt, BigDecimal outstandAmt) {
			
    	CaFinancialTermsT caFinancialTermsT = CaFinancialTermsT.builder().caseId(caseId)
					.recoupAmt(recoupAmt).informalAmt(sumCorrectPdAmt).finCustAmtA(sumHdrPdAmt)
					.totalPaidAmt(totalPaidAmt).outstandAmt(outstandAmt).build();
			log.info(" Save caFinancialTermsT Case ID " + caseId);
			caFinancialTermsRepo.save(caFinancialTermsT);
	
			
	}
    
    /** 
	 * This method will get the ZoneId corresponding to the time zone used at the customer site
	 * Parameters: the time zone is stored in an entry in the FADS_CONFIG_T table 
	 */
	public ZoneId getZoneId() {
		ZoneId zid = ZoneId.systemDefault();;
		Optional<FadsConfigT> optional = fadsConfigRepository.findById(CustomFieldConstant.DATE_TIME_ZONE_ID);
		if (optional.isPresent()) {
			FadsConfigT fadsConfigT = optional.get();
			zid = ZoneId.of(fadsConfigT.getOptionValue());	//  the zone ID corresponding to date-time zone used
		}
		return zid;
	}
