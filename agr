//        DmClaimT dmClaimT = dmClaimRepository.findByhdrClmTcnAndLiNum(hdrClmTcn, liNum);
        CaUniverseT caUniverseT = caUniverseRepository.findByTcnLiNumCaseId(hdrClmTcn, liNum, caseId);
