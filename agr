	@Override
	public SeCaseGrp findById(java.lang.Integer id) {
		log.debug("getting SeCaseGrp instance with id: " + id);
		try {
			SeCaseGrp instance = (SeCaseGrp) getCurrentSession().get(
					"com.optum.fads.security.domain.SeCaseGrp", id);
			return instance;
		} catch (RuntimeException re) {
			log.error("get failed", re);
			throw re;
		}
	}

	public List<SeCaseGrp> findByExample(SeCaseGrp instance) {
		log.debug("finding SeCaseGrp instance by example");
		try {
			List<SeCaseGrp> results = (List<SeCaseGrp>) getCurrentSession()
					.createCriteria(
							"com.optum.fads.security.domain.SeCaseGrp")
					.add(create(instance)).list();
			log.debug("find by example successful, result size: "
					+ results.size());
			return results;
		} catch (RuntimeException re) {
			log.error("find by example failed", re);
			throw re;
		}
	}

	public List findByProperty(String propertyName, Object value) {
		try {
			/*String text = "from SeCaseGrp as model where model."
					+ propertyName + "= ?";*/
			
			StringBuilder queryStr = new StringBuilder();
			queryStr.append("from SeCaseGrp as model where model.");
			queryStr.append(propertyName);
			queryStr.append("=:propertyName");
			
			Query queryObject = getCurrentSession().createQuery(queryStr.toString());
			queryObject.setParameter(0, value);
			return queryObject.list();
		} catch (RuntimeException re) {
			log.error("find by property name failed", re);
			throw re;
		}
	}

	public List<SeCaseGrp> findByGrpName(Object grpName) {
		return findByProperty(GRP_NAME, grpName);
	}

	/* (non-Javadoc)
	 * @see com.optum.fads.security.dao.impl.SeCaseGrpDAO#findAll()
	 */
	@Override
	public List<CaseGroup> findAll() {
		log.debug("finding all SeCaseGrp instances");
		try {
			StringBuilder sb = new StringBuilder();
			sb.append(" select a.caseGrpId as groupId, ");
			sb.append(" a.caseGrpName as groupName ");
			//sb.append(" from SeCaseGrp a order by a.caseGrpId desc ");
			sb.append(" from SeCaseGrp a order by a.caseGrpName asc ");

			String text = sb.toString(); // "from SeCaseGrp";
			Query queryObject = getCurrentSession().createQuery(text);
			queryObject.setResultTransformer(new AliasToBeanResultTransformer(CaseGroup.class));
			return queryObject.list();
		} catch (RuntimeException re) {
			log.error("find all failed", re);
			throw re;
		}
	}

