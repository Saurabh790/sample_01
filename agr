@ExtendWith(MockitoExtension.class)
class UserDetailsServiceTest {

    @InjectMocks
    private UserDetailsService userDetailsService;

    @Mock
    private UserRepository userRepository;

    @Test
    void loadUserByUsernameThrowsWhenUserMissing() {
        when(userRepository.findByUiEMailAddressOrUiUserId("missing", "missing")).thenReturn(Optional.empty());

        UsernameNotFoundException ex =
                assertThrows(UsernameNotFoundException.class, () -> userDetailsService.loadUserByUsername("missing"));

        assertTrue(ex.getMessage().contains("missing"));
    }

    @Test
    void loadUserByUsernameMapsUserRoleAndAllowedAccesses() {
        UiUserBase entity = new UiUserBase();
        entity.setUiSystemId("SYS-1");
        entity.setUiUserId("study.user");
        entity.setUiEMailAddress("study.user@test.com");

        SeUsrGrp userGroup = new SeUsrGrp();
        SeSurGrp roleGroup = new SeSurGrp();
        roleGroup.setSurGrpId(77L);
        roleGroup.setSurGrpName("Study Admin");
        roleGroup.setSeSurGrpModAccesses(List.of(
                access("1", "Study Workspace", "RW", 77L),
                access("2", "Job Monitor", "R", 77L)));
        userGroup.setSeSurGrp(roleGroup);
        entity.setSeUsrGrp(userGroup);

        when(userRepository.findByUiEMailAddressOrUiUserId("study.user", "study.user")).thenReturn(Optional.of(entity));

        AppUser result = (AppUser) userDetailsService.loadUserByUsername("study.user");

        assertEquals("SYS-1", result.getUsername());
        assertEquals("study.user", result.getUserId());
        assertEquals("study.user@test.com", result.getUserEmail());
        assertNotNull(result.getRole());
        assertEquals("77", result.getRole().getId());
        assertEquals("Study Admin", result.getRole().getRoleName());
        assertEquals(2, result.getRole().getAllowedAccesses().size());
        assertTrue(result.getRole().getAllowedAccesses().stream().anyMatch(access ->
                "1".equals(access.getModuleId())
                        && "STUDY".equals(access.getModuleCode())
                        && "Study Workspace".equals(access.getModuleName())
                        && "RW".equals(access.getAccess())));
        assertTrue(result.getRole().getAllowedAccesses().stream().anyMatch(access ->
                "2".equals(access.getModuleId())
                        && "JOBMONITOR".equals(access.getModuleCode())
                        && "R".equals(access.getAccess())));
    }

    private static SeSurGrpModAccess access(String moduleId, String moduleName, String accessId, long groupId) {
        SeSurGrpModAccessPK id = new SeSurGrpModAccessPK();
        id.setSurGrpId(groupId);
        id.setSurModuleId(moduleId);

        SeSurModule module = new SeSurModule();
        module.setSurModuleId(moduleId);
        module.setSurModuleName(moduleName);

        SeSurAccess access = new SeSurAccess();
        access.setSurAccessId(accessId);

        SeSurGrpModAccess grpAccess = new SeSurGrpModAccess();
        grpAccess.setId(id);
        grpAccess.setSeSurModule(module);
        grpAccess.setSeSurAccess(access);
        return grpAccess;
    }
}
