        modAccess.setSeSurModule(module);

        SeSurGrp surGrp = new SeSurGrp();
        surGrp.setSurGrpId(7L);
        surGrp.setSurGrpName("Admins");
        surGrp.setSeSurGrpModAccesses(List.of(modAccess));

        SeUsrGrp usrGrp = new SeUsrGrp();
        usrGrp.setSeSurGrp(surGrp);
