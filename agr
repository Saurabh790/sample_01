        Map<String, String> expectedMap = Map.of("studyName", searchInput);

        String sortValue = StudySortEnum.valueOf(sortBy.name()).value;
        Pageable pageable = PageRequest.of(0, recordsPerPage, Sort.by(Sort.Order.asc(sortValue).ignoreCase()));

