@Service
public class CommonService implements ICommonService {

	@Autowired
	private LuValuesRepository luValuesRepository;

	@Autowired
	private FadsConfigRepository fadsConfigRepository;

	@Autowired
	private CommonMapper commonMapper;

	@Override
	@Transactional
	public List<LabelValue> findAllEncClaimTypes() {
		List<FadsLuValueT> list = luValuesRepository.findByIdFieldId(StudyConstants.ENC_TYPES_FIELD_ID);
		return commonMapper.convertToLabelValues(list);

	}

	@Override
	public List<LabelValue> findAllCrossOverTypes() {
		List<FadsLuValueT> list = luValuesRepository.findByIdFieldId(StudyConstants.XOVERS_TYPES_FIELD_ID);
		return commonMapper.convertToLabelValues(list);

	}

	@Override
	public Map<String, Object> findAllConfigValues() {
		List<Long> optioncodes = Stream.of(FadsConfigEnum.values()).map(FadsConfigEnum::getOptionCode)
				.collect(Collectors.toList());

		HashMap<String, Object> map = new HashMap<String, Object>();

		List<FadsConfigT> configValues = fadsConfigRepository.findAll(new Specification<FadsConfigT>() {		
			private static final long serialVersionUID = 1L;

			@Override
			public Predicate toPredicate(Root<FadsConfigT> root, CriteriaQuery<?> query,
                                         CriteriaBuilder criteriaBuilder) {
				return root.get("optionCode").in(optioncodes);
			};
		});
		configValues.forEach(fadsConfig ->{
			map.put(FadsConfigEnum.valueOf(fadsConfig.getOptionCode().longValue()).name(), fadsConfig.getOptionValue());			
			
		});
		
		return map;
	}
	/** 
	 * This method will get the ZoneId corresponding to the time zone used at the customer site
	 * Parameters: the time zone is stored in an entry in the FADS_CONFIG_T table 
	 */
	public ZoneId getZoneId() {
		ZoneId zid = ZoneId.systemDefault();;
		Optional<FadsConfigT> optional = fadsConfigRepository.findById(StudyConstants.DATE_TIME_ZONE_ID);
		if (optional.isPresent()) {
			FadsConfigT fadsConfigT = optional.get();
			zid = ZoneId.of(fadsConfigT.getOptionValue());	//  the zone ID corresponding to date-time zone used
		}
		return zid;

	}
	
}
