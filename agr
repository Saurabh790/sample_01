            @RequestParam(value = "pageNumber", defaultValue = "1", required = false) Integer pageNumber,
            @RequestParam(value = "recordsPerPage", defaultValue = "10", required = false) Integer recordsPerPage,
            @RequestParam(name = "sortBy", required = false, defaultValue = "seqNum") String sortBy,
            @RequestParam(name = "sortOrder", required = false, defaultValue = "1") Integer sortOrder
    ) {
        log.info("find All Finding Oberserve data");
     //   String sortValue = FindingObsSortEnum.valueOf(sortBy.name()).value;
        if (pageNumber > 0) {
            --pageNumber;
        } else {
            pageNumber = 0;
        }
        Pageable pageable = PageRequest.of(pageNumber, recordsPerPage, Sort.by(Sort.Order.desc(sortBy)));
        if (SortOrder.valueOf(sortOrder).toString().equalsIgnoreCase("asc")) {
            pageable = PageRequest.of(pageNumber, recordsPerPage, Sort.by(Sort.Order.asc(sortBy)));
        }
        return findingsObsService.findAllFindingObservations(caseId,claimSeqId, pageable);
    }

    @PutMapping("case-claim/{caseId}")
    public ResponseEntity<Object> updateAuditCorrection(@PathVariable("caseId") Integer caseId,
                                                        @RequestBody @Valid ClaimCorrectionDTO claimCorrectionDTO) {
        List<String> operationsList = Arrays.asList("N", "D");
        List<String> errors = null;
/*
        if (bindingResult.hasErrors()) {

            errors = bindingResult.getAllErrors()
                    .stream()
                    .map(objectError -> objectError.getDefaultMessage())
                    .collect(Collectors.toList());
        }

        if (errors != null && errors.size() > 0) {
            return ResponseEntity.badRequest().body(errors);
        }*/
        log.info("updateAuditCorrection {}", caseId);
        AppUser user = (AppUser) SecurityContextHolder.getContext().getAuthentication().getPrincipal();
        if(claimCorrectionDTO.getFindingObservations().size()>0){
            List<FindingObservation> noOperationOperators=   claimCorrectionDTO.getFindingObservations().stream().filter(u ->!operationsList.contains(u.getOperation())).collect(Collectors.toList());
            if(!noOperationOperators.isEmpty()){
                return ResponseEntity.
                        status(HttpStatus.BAD_REQUEST)
                        .body(" Operation is empty or null");
            }
        }
        if(claimCorrectionDTO.getDocReceivedInd().equalsIgnoreCase("N")){
            claimCorrectionDTO.setDocReceivedInd(null);
        }
        caseDetailClaimsService.updateClaimCorrection(claimCorrectionDTO, user.getUserSystemId());
        return new ResponseEntity<>("Save/Update success", HttpStatus.OK);
    }

