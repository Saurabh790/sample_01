	/**
	 * this method will create a new data rule
	 * 
	 * Parameters - dataRuleDTO
	 */
	public DataRuleDTO addDataRule(DataRuleDTO dataRuleDTO) {

		DataRuleDTO retDataRuleDTO = new DataRuleDTO();
		DateTimeFormatter dateTimeFormatter = DateTimeFormatter.ofPattern(
				DataRuleConstants.DATE_FORMAT_MMDDYYYY_HHMMSS_A,
				Locale.ENGLISH);
		String dataRuleNameLc = dataRuleDTO.getDataRuleName().toLowerCase().trim();

		try {
			PrmDrDataRuleT dataRule = dataRulesRepository.getDataRuleByName(dataRuleNameLc);
			if (dataRule == null) {
				Integer dataRuleId = dataRuleMasterRepository.retrieveNextDrId();
				dataRuleDTO.setDataRuleId(dataRuleId);
				PrmDrDataRuleT prmDrDataRuleT = new PrmDrDataRuleT();
				UiUserBase uiUserBaseCr = new UiUserBase();
				uiUserBaseCr.setUiSystemId(dataRuleDTO.getCreatedBySystemId());
				prmDrDataRuleT.setUiUserBaseCr(uiUserBaseCr); // Set UiUserBase
				UiUserBase uiUserBaseUpd = new UiUserBase();
				uiUserBaseUpd.setUiSystemId(dataRuleDTO.getModifiedBySystemId());
				prmDrDataRuleT.setUiUserBaseUpd(uiUserBaseUpd);

				PrmMbMasterT prmMbMasterT = new PrmMbMasterT();
				prmDrDataRuleT.setPrmMbMasterT(prmMbMasterT); // Set PrmMbMasterT

				PrmDrLuOperatorT prmDrLuOperatorT = new PrmDrLuOperatorT();
				prmDrDataRuleT.setPrmDrLuOperatorT(prmDrLuOperatorT); // Set PrmDrLuOperatorT
				prmDrDataRuleT.getPrmDrLuOperatorT().setOperatorCd(dataRuleDTO.getOperator());

				prmDrDataRuleT.setDrId(dataRuleId);
				prmDrDataRuleT.setDataRuleName(dataRuleDTO.getDataRuleName().trim());
				prmDrDataRuleT.getPrmMbMasterT().setMbCtecFid(dataRuleDTO.getDataElementId());

				prmDrDataRuleT.setCreateDate(LocalDateTime.parse(dataRuleDTO.getCreatedDate(), dateTimeFormatter));
				prmDrDataRuleT.setUpdateDate(LocalDateTime.parse(dataRuleDTO.getModifiedDate(), dateTimeFormatter));
				dataRuleMasterRepository.saveAndFlush(prmDrDataRuleT);

				saveCodeRangeValues(dataRuleId, dataRuleDTO);
				logit.info("Data Rule saved with Datarule ID = {}", dataRuleId);

				retDataRuleDTO = getDataRuleById(dataRuleId);
				if (retDataRuleDTO.getRangeValue() == null) {
					retDataRuleDTO.setRangeValue(dataRuleDTO.getRangeValue());
					if (DataRuleConstants.NO_VALUE.equalsIgnoreCase(dataRuleDTO.getRangeValue())) {
						retDataRuleDTO.setSelectedValues(
								dataRuleDTO.getSelectedValues().stream().collect(Collectors.toList()));
					} else {
						retDataRuleDTO
								.setRangeValues(dataRuleDTO.getRangeValues().stream().collect(Collectors.toList()));
					}
				}

			} else {
				retDataRuleDTO.setDataRuleId(dataRule.getDrId());
				retDataRuleDTO.setDataRuleName(DataRuleConstants.DATA_RULE_NAME_EXISTS);
				retDataRuleDTO.setModifiedBySystemId(dataRule.getUiUserBaseUpd().getUiSystemId());
				retDataRuleDTO.setCreatedBySystemId(dataRule.getUiUserBaseCr().getUiSystemId());
			}
		} catch (Exception e) {
			throw new DataRulesApiException(DataRuleConstants.EXCEPTION_MESSAGE, e);
		}

		return retDataRuleDTO;
	}

	/**
	 * this method will update a data rule records based on input data
	 * 
	 * Parameters - dataRuleDTO
	 */
	public String updateDataRule(Integer dataRuleId, DataRuleDTO dataRuleDTO) {

		String updDataRuleMessage = "";
		DateTimeFormatter dateTimeFormatter = DateTimeFormatter.ofPattern(
				DataRuleConstants.DATE_FORMAT_MMDDYYYY_HHMMSS_A,
				Locale.ENGLISH);
		try {
			PrmDrDataRuleT prmDrDataRuleT = dataRuleDetailMapper.convertToPrmDrDataRuleT(dataRuleDTO);
			PrmDrDataRuleT dataRuleInd = dataRuleMasterRepository.retrieveDataRuleById(dataRuleId);
			prmDrDataRuleT.setCreateDate(dataRuleInd.getCreateDate());
			prmDrDataRuleT.setUpdateDate(LocalDateTime.parse(dataRuleDTO.getModifiedDate(), dateTimeFormatter));
			prmDrDataRuleT = dataRulesRepository.saveAndFlush(prmDrDataRuleT);
			// saveAndFlush() will throw a DataAccessException upon failure to update
			dataRuleSingleValuesRepository.deleteSingleValuesByDataRuleId(dataRuleId);

			dataRuleRangesRepository.deleteRangesByDataRuleId(dataRuleId);

			saveCodeRangeValues(dataRuleId, dataRuleDTO);
			updDataRuleMessage = DataRuleConstants.UPDATE_SUCCESS_MESSAGE;
		} catch (Exception e) {
			updDataRuleMessage = e.getMessage();
			logit.info("Datarule update failed ID= {} exception= {}", dataRuleId, updDataRuleMessage);
			// throw new DataRulesApiException(DataRuleConstants.EXCEPTION_MESSAGE, e );
		}
		return updDataRuleMessage;
	}

	private void saveCodeRangeValues(Integer dataRuleId, DataRuleDTO dataRuleDTO) {
		logit.info(" Save Range/Code values for data rule ID {} ", dataRuleDTO.getDataRuleId());
		List<PrmDrSingleValuesT> prmDrSingleValues;
		List<PrmDrRangesT> prmDrRanges;
		long seqNum = 1;
		if (DataRuleConstants.NO_VALUE.equalsIgnoreCase(dataRuleDTO.getRangeValue())) {
			prmDrSingleValues = new ArrayList<>();
			// Avail values come from the field MB_LU_SQL in PRM_MB_MASTER_T
			logit.info("dataRuleDTO SelectedValues present");
			List<DrCodeValueDTO> codeValueList = dataRuleDTO.getSelectedValues();
			for (DrCodeValueDTO drCodeValueDTO : codeValueList) {
				PrmDrSingleValuesT prmDrSingleValuesT = new PrmDrSingleValuesT();
				PrmDrSingleValuesTPK prmDrSingleValuesTPK = new PrmDrSingleValuesTPK();
				prmDrSingleValuesTPK.setDrId(dataRuleId);
				prmDrSingleValuesTPK.setDrValue(drCodeValueDTO.getCode());
				prmDrSingleValuesT.setId(prmDrSingleValuesTPK);
				prmDrSingleValuesT.setDrLabel(drCodeValueDTO.getValue());
				prmDrSingleValues.add(prmDrSingleValuesT);
			}
			logit.info("dataRuleSingleValuesRepository.saveAll - prmDrSingleValues = {}", prmDrSingleValues.size());
			dataRuleSingleValuesRepository.saveAll(prmDrSingleValues); // Save the code values in batch
			dataRuleSingleValuesRepository.flush();
		} else if (DataRuleConstants.HAS_VALUE.equalsIgnoreCase(dataRuleDTO.getRangeValue())) { // default is "empty"
			prmDrRanges = new ArrayList<>();
			logit.info("dataRuleDTO Range Values present");
			for (DrRangeValuesDTO drRangeValuesDTO : dataRuleDTO.getRangeValues()) {
				PrmDrRangesT prmDrRangesT = new PrmDrRangesT();
				PrmDrRangesTPK prmDrRangesTPK = new PrmDrRangesTPK();
				prmDrRangesTPK.setDrId(dataRuleId);
				prmDrRangesTPK.setSeqNum(seqNum++);
				prmDrRangesT.setId(prmDrRangesTPK);
				prmDrRangesT.setDrRangeFrom(drRangeValuesDTO.getFrom());
				prmDrRangesT.setDrRangeTo(drRangeValuesDTO.getTo());
				prmDrRanges.add(prmDrRangesT);
			}
			logit.info("dataRuleRangesValuesRepository.saveAll - prmDrRanges = {}", prmDrRanges.size());
			dataRuleRangesRepository.saveAll(prmDrRanges); // Save the range values in batch
			dataRuleRangesRepository.flush();
		}
	}

	/**
	 * this method will delete selected data rule
	 * 
	 * Parameters - Data Rule IdD
	 */
	public List<String> deleteDataRule(Integer dataruleRecId) {
		int dataRulesDeleted = 0;
		List<String> deleteDataRuleMessages = new ArrayList<>();
		boolean delDataRuleConstraint = false;
		List<Integer> erIdList;
		List<Integer> cgIdList;
		logit.info(" Delete datarule for input ID {}", dataruleRecId);
		try {
			PrmDrDataRuleT prmDrDataRuleT = dataRuleMasterRepository.retrieveDataRuleById(dataruleRecId);
			if (prmDrDataRuleT == null) {
				deleteDataRuleMessages.add(DataRuleConstants.DATA_RULE_DOES_NOT_EXIST);
			} else {
				List<PrmErDrT> prmErDrListInDb = dataRuleMasterRepository.retrieveErDrValues(dataruleRecId);
				if (!prmErDrListInDb.isEmpty()) {
					erIdList = new ArrayList<>();
					for (PrmErDrT prmErDrT : prmErDrListInDb) {
						erIdList.add(prmErDrT.getId().getErId());
					}
					if (erIdList.size() > 1) {
						List<PrmBpBehaviorPatsT> behaviorPatternList = dataRuleMasterRepository
								.getBehaviorPatternByErIds(erIdList);
						for (PrmBpBehaviorPatsT behaviorPattern : behaviorPatternList) {
							deleteDataRuleMessages
									.add(DataRuleConstants.BP_CONST + "   " + behaviorPattern.getBehaviorPatternName());
						}
					} else {
						PrmBpBehaviorPatsT prmBpBehaviorPatsT = dataRuleMasterRepository
								.getBehaviorPatternByErId(erIdList.get(0));
						deleteDataRuleMessages
								.add(DataRuleConstants.BP_CONST + "   " + prmBpBehaviorPatsT.getBehaviorPatternName());
					}
					delDataRuleConstraint = true;
				}

				List<PrmPgDrT> prmPgDrListInDb = dataRuleMasterRepository.retrievePgDrValues(dataruleRecId);
				if (!prmPgDrListInDb.isEmpty()) {
					cgIdList = new ArrayList<>();
					for (PrmPgDrT prmPgDrT : prmPgDrListInDb) {
						cgIdList.add(prmPgDrT.getId().getCgId());
					}
					if (cgIdList.size() > 1) {
						List<PrmPgPeerGroupT> peerGroupList = dataRuleMasterRepository.getStudyGroupByIds(cgIdList);
						for (PrmPgPeerGroupT peerGroup : peerGroupList) {
							deleteDataRuleMessages
									.add(DataRuleConstants.PG_CONST + "   " + peerGroup.getStudyGroupName());
						}
					} else {
						PrmPgPeerGroupT prmPgPeerGroup = dataRuleMasterRepository.getStudyGroupById(cgIdList.get(0));
						deleteDataRuleMessages
								.add(DataRuleConstants.PG_CONST + "   " + prmPgPeerGroup.getStudyGroupName());
					}
					delDataRuleConstraint = true;
				}

				if (!delDataRuleConstraint) {
					dataRuleRangesRepository.deleteRangesByDataRuleId(dataruleRecId);
					dataRuleSingleValuesRepository.deleteSingleValuesByDataRuleId(dataruleRecId);
					dataRulesDeleted = dataRuleMasterRepository.deleteDatarule(dataruleRecId);
					if (dataRulesDeleted > 0) {
						deleteDataRuleMessages.add(DataRuleConstants.DELETE_SUCCESS_MESSAGE);
					} else {
						deleteDataRuleMessages.add(DataRuleConstants.DELETE_FAIL_MESSAGE);
					}
				}
			}
		} catch (Exception e) {
			throw new DataRulesApiException(DataRuleConstants.EXCEPTION_MESSAGE, e);
		}
		return deleteDataRuleMessages;
	}

	private Pageable createPageableDataRules(ListTableParams listTableParams) {
		Pageable pageable = null;
		String sortStr1;
		String sortStr2 = "";
		String sortByStr = listTableParams.getSortBy();
		int pageNumberI = listTableParams.getPageNumber() - 1;
		int pageSizeI = listTableParams.getRecordsPerPage();
		// Pageable represents the Page configuration with sorting
		Sort.Order order1 = null;
		Sort.Order order2 = null;
		Sort.Direction sortDirection;
		Sort sort1;
		if (listTableParams.getSortOrder() > 0) {
			sortDirection = Sort.Direction.ASC;
		} else {
			sortDirection = Sort.Direction.DESC;
		}
		switch (sortByStr) {
			case DataRuleConstants.DATA_RULE_NAME:
				sortStr1 = sortByStr;
				order1 = new Sort.Order(sortDirection, sortStr1).ignoreCase();
				sort1 = Sort.by(order1);
				break;
			case DataRuleConstants.CREATE_DATE:
				sortStr1 = sortByStr;
				order1 = new Sort.Order(sortDirection, sortStr1);
				sort1 = Sort.by(order1);
				break;
			case DataRuleConstants.MODIFIED_DATE:
				sortStr1 = DataRuleConstants.UPDATE_DATE;
				order1 = new Sort.Order(sortDirection, sortStr1);
				sort1 = Sort.by(order1);
				break;
			case DataRuleConstants.CREATED_BY:
				sortStr1 = "uiUserBaseCr.uiFirstName";
				sortStr2 = "uiUserBaseCr.uiLastName";
				order1 = new Sort.Order(sortDirection, sortStr1).ignoreCase();
				order2 = new Sort.Order(sortDirection, sortStr2).ignoreCase();
				sort1 = Sort.by(order1, order2);
				break;
			case DataRuleConstants.MODIFIED_BY:
				sortStr1 = "uiUserBaseUpd.uiFirstName";
				sortStr2 = "uiUserBaseUpd.uiLastName";
				order1 = new Sort.Order(sortDirection, sortStr1).ignoreCase();
				order2 = new Sort.Order(sortDirection, sortStr2).ignoreCase();
				sort1 = Sort.by(order1, order2);
				break;
			default:
				sortStr1 = DataRuleConstants.DATA_RULE_ID;
				order1 = new Sort.Order(sortDirection, sortStr1);
				sort1 = Sort.by(order1);
				break;
		}
		pageable = PageRequest.of(pageNumberI, pageSizeI, sort1);
		return pageable;
	}

	private List<DataRuleDTO> populateDataRuleList(List<PrmDrDataRuleT> dataruleList, boolean details) {
		List<DataRuleDTO> dataRuleDataList = new ArrayList<>();
		for (PrmDrDataRuleT dataRuleInd : dataruleList) {
			DataRuleDTO dataRuleDTO = new DataRuleDTO();
			dataRuleDTO.setDataRuleId(dataRuleInd.getDrId());
			dataRuleDTO.setDataRuleName(dataRuleInd.getDataRuleName());
			dataRuleDTO.setDataElementName(dataRuleInd.getPrmMbMasterT().getMbCustDatadesc());
			dataRuleDTO.setOperator(dataRuleInd.getPrmDrLuOperatorT().getOperatorCd());
			dataRuleDTO.setCreatedBy(dataRuleInd.getUiUserBaseCr().getUiFirstName() + DataRuleConstants.BLANK_STR
					+ dataRuleInd.getUiUserBaseCr().getUiLastName());
			dataRuleDTO.setCreatedDate(formatLocalDate(dataRuleInd.getCreateDate()));
			dataRuleDTO.setModifiedBy(dataRuleInd.getUiUserBaseUpd().getUiFirstName() + DataRuleConstants.BLANK_STR
					+ dataRuleInd.getUiUserBaseUpd().getUiLastName());
			dataRuleDTO.setModifiedDate(formatLocalDate(dataRuleInd.getUpdateDate()));
			dataRuleDTO.setCreatedBySystemId(dataRuleInd.getUiUserBaseCr().getUiSystemId());
			dataRuleDTO.setModifiedBySystemId(dataRuleInd.getUiUserBaseUpd().getUiSystemId());
			dataRuleDTO.setDataElementId(dataRuleInd.getPrmMbMasterT().getMbCtecFid());
			dataRuleDTO.setDataElementDataType(dataRuleInd.getPrmMbMasterT().getMbCtecFtype());
			if (details) {
				setCodeRangeValues(dataRuleInd, dataRuleDTO);
			} else {
				dataRuleDTO.setSelectedValues(new ArrayList<DrCodeValueDTO>());
				dataRuleDTO.setRangeValues(new ArrayList<DrRangeValuesDTO>());
			}
			dataRuleDataList.add(dataRuleDTO);
		}
		return dataRuleDataList;
	}

	private void setCodeRangeValues(PrmDrDataRuleT dataRuleInd, DataRuleDTO dataRuleDTO) {
		if (dataRuleInd.getPrmDrSingleValuesTs() != null && !dataRuleInd.getPrmDrSingleValuesTs().isEmpty()) {
			dataRuleDTO.setRangeValue(DataRuleConstants.NO_VALUE);
			List<DrCodeValueDTO> codeValuesList = new ArrayList<>();
			for (PrmDrSingleValuesT singleValue : dataRuleInd.getPrmDrSingleValuesTs()) {
				DrCodeValueDTO codeBean = new DrCodeValueDTO();
				codeBean.setValue(singleValue.getDrLabel());
				codeBean.setCode(singleValue.getId().getDrValue());
				codeValuesList.add(codeBean);
			}
			dataRuleDTO.setSelectedValues(codeValuesList);
			logit.info(" Code Values list populated with {} code Value data", codeValuesList.size());
		} else {
			dataRuleDTO.setSelectedValues(new ArrayList<DrCodeValueDTO>());
		}
		if (dataRuleInd.getPrmDrRangesTs() != null && !dataRuleInd.getPrmDrRangesTs().isEmpty()) {
			dataRuleDTO.setRangeValue(DataRuleConstants.HAS_VALUE);
			List<DrRangeValuesDTO> drRangeValuesList = new ArrayList<>();
			for (PrmDrRangesT rangeFromTo : dataRuleInd.getPrmDrRangesTs()) {
				DrRangeValuesDTO rangeBean = new DrRangeValuesDTO();
				rangeBean.setFrom(rangeFromTo.getDrRangeFrom());
				rangeBean.setTo(rangeFromTo.getDrRangeTo());
				drRangeValuesList.add(rangeBean);
			}
			dataRuleDTO.setRangeValues(drRangeValuesList);
			logit.info(" Range Values list populated with {} range Value data", drRangeValuesList.size());
		} else {
			dataRuleDTO.setRangeValues(new ArrayList<DrRangeValuesDTO>());
		}
	}

	private String replDataRuleName(String searchInput) {
		StringBuilder strbldr = new StringBuilder();
		String dataRuleNameVal;
		String replacedInput = "";
		// if space followed by = or preceded by = is in the search input string, the
		// space is an encoded string %20
		if (StringUtils.containsAny(searchInput, DataRuleConstants.SPACE_ENCODED_STR)) {
			searchInput = searchInput.replaceAll(DataRuleConstants.SPACE_ENCODED_STR, DataRuleConstants.BLANK_STR);
		}
		if (StringUtils.containsAny(searchInput, DataRuleConstants.PLUS_REPL_STR)) {
			searchInput = searchInput.replaceAll(DataRuleConstants.PLUS_REPL_STR, DataRuleConstants.PLUS_STR);
		}
		if (StringUtils.containsAny(searchInput, DataRuleConstants.COMMA_REPL_STR)) {
			searchInput = searchInput.replaceAll(DataRuleConstants.COMMA_REPL_STR, DataRuleConstants.COMMA_STR);
		}
		if (StringUtils.containsAny(searchInput, DataRuleConstants.PERCENT_CHAR)
				|| StringUtils.containsAny(searchInput, DataRuleConstants.UNDERSCORE_CHAR)) {
			if (StringUtils.containsAny(searchInput, DataRuleConstants.PERCENT_CHAR)) {
				replacedInput = searchInput.replaceAll("\\%", "\\\\%");
			} else if (StringUtils.containsAny(searchInput, DataRuleConstants.UNDERSCORE_CHAR)) {
				replacedInput = searchInput.replaceAll("\\_", "\\\\_");
			}
			strbldr.append(DataRuleConstants.PERCENT_STR);
			strbldr.append(replacedInput);
			strbldr.append(DataRuleConstants.PERCENT_STR);
			dataRuleNameVal = strbldr.toString();
		} else {
			dataRuleNameVal = DataRuleConstants.PERCENT_STR + searchInput + DataRuleConstants.PERCENT_STR;
		}
		return dataRuleNameVal;
	}

	// For LocalDateTime
	protected String formatLocalDate(LocalDateTime dt) {
		DateTimeFormatter dateTimeFormatter;
		if (dt == null)
			return null;
		dateTimeFormatter = DateTimeFormatter.ofPattern(DataRuleConstants.DATE_FORMAT_MMDDYYYY_HHMM_A,
				Locale.ENGLISH);
		return dateTimeFormatter.format(dt);
	}

