package com.optum.fads.pgp.study.api.security;

import com.optum.fads.pgp.study.security.UserJwtAuthenticationConverter;
import com.optum.fads.pgp.study.service.IUserDetailsService;
import org.junit.jupiter.api.BeforeEach;
import org.junit.jupiter.api.Test;
import org.mockito.Mock;
import org.mockito.MockitoAnnotations;
import org.springframework.security.authentication.AbstractAuthenticationToken;
import org.springframework.security.authentication.BadCredentialsException;
import org.springframework.security.core.userdetails.User;
import org.springframework.security.oauth2.jwt.Jwt;

import java.util.List;
import java.util.Map;

import static org.junit.jupiter.api.Assertions.*;
import static org.mockito.Mockito.*;

class UserJwtAuthenticationConverterTest {

    private UserJwtAuthenticationConverter converter;

    @Mock
    private IUserDetailsService userDetailsService;

    @BeforeEach
    void setUp() {
        MockitoAnnotations.openMocks(this);
        converter = new UserJwtAuthenticationConverter(userDetailsService, List.of("upn", "unique_name", "email", "sub"));
    }

    @Test
    void testConvert_whenValidJwt_shouldReturnAuthenticationToken() {
        // Arrange
        Map<String, Object> claims = Map.of(
                "email", "testuser@example.com",
                "groups", List.of("admin", "user")
        );
        Jwt jwt = Jwt.withTokenValue("token")
                .header("alg", "HS256")
                .claims(claimsMap -> claimsMap.putAll(claims)) // Use a lambda to populate claims
                .build();

        User mockUser = new User("testuser@example.com", "password", List.of());
        when(userDetailsService.loadUserByUsername("testuser@example.com")).thenReturn(mockUser);

        // Act
        AbstractAuthenticationToken token = converter.convert(jwt);

        // Assert
        assertNotNull(token);
        assertEquals(mockUser, token.getPrincipal());
        assertEquals("n/a", token.getCredentials());
        assertEquals(2, token.getAuthorities().size());
        assertTrue(token.getAuthorities().stream().anyMatch(auth -> auth.getAuthority().equals("ROLE_ADMIN")));
        assertTrue(token.getAuthorities().stream().anyMatch(auth -> auth.getAuthority().equals("ROLE_USER")));
    }

    @Test
    void testConvert_whenJwtHasNoGroups_shouldReturnEmptyAuthorities() {
        // Arrange
        Map<String, Object> claims = Map.of(
                "email", "testuser@example.com"
        );
        Jwt jwt = Jwt.withTokenValue("token")
                .header("alg", "HS256")
                .claims(claimsMap -> claimsMap.putAll(claims))
                .build();

        User mockUser = new User("testuser@example.com", "password", List.of());
        when(userDetailsService.loadUserByUsername("testuser@example.com")).thenReturn(mockUser);

        // Act
        AbstractAuthenticationToken token = converter.convert(jwt);

        // Assert
        assertNotNull(token);
        assertEquals(mockUser, token.getPrincipal());
        assertEquals("n/a", token.getCredentials());
        assertTrue(token.getAuthorities().isEmpty());
    }

    @Test
    void testConvert_whenJwtHasNoEmailOrUsername_shouldThrowBadCredentialsException() {
        // Arrange
        Map<String, Object> claims = Map.of(
                "groups", List.of("admin", "user")
        );
        Jwt jwt = Jwt.withTokenValue("token")
                .header("alg", "HS256")
                .claims(claimsMap -> claimsMap.putAll(claims))
                .build();

        // Act & Assert
        assertThrows(BadCredentialsException.class, () -> converter.convert(jwt));
        verify(userDetailsService, never()).loadUserByUsername(anyString());
    }

    @Test
    void testConvert_whenUserNotFound_shouldThrowBadCredentialsException() {
        // Arrange
        Map<String, Object> claims = Map.of(
                "email", "nonexistentuser@example.com",
                "groups", List.of("admin", "user")
        );
        Jwt jwt = Jwt.withTokenValue("token")
                .header("alg", "HS256")
                .claims(claimsMap -> claimsMap.putAll(claims))
                .build();

        when(userDetailsService.loadUserByUsername("nonexistentuser@example.com")).thenReturn(null);

        // Act & Assert
        assertThrows(BadCredentialsException.class, () -> converter.convert(jwt));
    }
}
