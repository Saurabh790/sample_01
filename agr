    private void saveFinancials(CaIntelligentKeyT caIntelligentKeyT, Integer caseId, Session session) throws FinancialException {
        try {

            CaFinancialCalculateT caFinancialCalculateT = caIntelligentKeyT.getCaFinancialCalculateT();
            if (caFinancialCalculateT != null) {
                caFinancialCalculateT.setCaseId(caseId);
                session.saveOrUpdate(caFinancialCalculateT);
            }
          
		/*	if(caseId>0){
				int ledgerResult= session.createQuery("delete from CaFinancialPayLedgerT where id.caseId = :caseId").setParameter("caseId", caseId).executeUpdate();
				logger.info(" deleted old items :"+ledgerResult+" from CaFinancialPayLedgerT ");
			}+
		*/
            Iterator<CaFinancialPayLedgerT> caFinancialPayLedgerTs = caIntelligentKeyT.getCaFinancialPayLedgerTs().iterator();
            Query query = session.createQuery(" select max(model.id.paySeqNum) from CaFinancialPayLedgerT model  where model.id.caseId=:caseId");
            query.setParameter("caseId", caseId);
            Integer nextSeqId =  (Integer) query.uniqueResult();
            if(nextSeqId==null){
				nextSeqId=0;
			}
            while (caFinancialPayLedgerTs.hasNext()) {
                CaFinancialPayLedgerT caFinancialPayLedgerT = (CaFinancialPayLedgerT) caFinancialPayLedgerTs.next();
                if (caFinancialPayLedgerT != null) {
                    caFinancialPayLedgerT.getId().setCaseId(caseId);
                    String operation = caFinancialPayLedgerT.getOperation();
                    if (operation != null && operation.equalsIgnoreCase("D")) {
                        session.delete(caFinancialPayLedgerT);
                    }else if(operation!=null && operation.equalsIgnoreCase("N")){
                    	caFinancialPayLedgerT.getId().setPaySeqNum(++nextSeqId);
						session.saveOrUpdate(caFinancialPayLedgerT);
					} else {
                        session.saveOrUpdate(caFinancialPayLedgerT);
                    }
                    //	session.saveOrUpdate(caFinancialPayLedgerT);
                }
            }

            Criteria criteria = session.createCriteria(CaFinancialPayLedgerT.class).setProjection(Projections.sum("payAmt"));
            criteria.add(Restrictions.eq("id.caseId", caseId));
            CaFinancialTermsT caFinancialTermsT = caIntelligentKeyT.getCaFinancialTermsT();
            Double totalAmountPaid = (Double) criteria.uniqueResult();
            if (totalAmountPaid == null) {
                totalAmountPaid = 0.00;
            }
            if (caFinancialTermsT != null) {
                Double recoupAmt = caFinancialTermsT.getRecoupAmt();
                if (recoupAmt == null) {
                    recoupAmt = 0.00;
                }
                double outstandingAmt;
                if (recoupAmt >= totalAmountPaid) {
                    outstandingAmt = recoupAmt - totalAmountPaid;
                } else {
                    outstandingAmt = 0.00;
                }
                caFinancialTermsT.setTotalPaidAmt(totalAmountPaid);
                caFinancialTermsT.setOutstandAmt(outstandingAmt);
                caFinancialTermsT.setCaseId(caseId);
                session.saveOrUpdate(caFinancialTermsT);
            }

            CaFinancialOverPayT caFinancialOverPayT = caIntelligentKeyT.getCaFinancialOverPayT();
            if (caFinancialOverPayT != null) {
                caFinancialOverPayT.setCaseId(caseId);
                session.saveOrUpdate(caFinancialOverPayT);
            }
        } catch (HibernateException e) {
            // TODO Auto-generated catch block
            logger.error("Error at  CaseDetailDAO saveFinancials:" + e);
            throw new FinancialException("Error at saveFinancials" + e);
        } finally {
            session.flush();
            session.clear();
        }

    }

