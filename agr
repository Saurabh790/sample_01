        entity.setPrmStudyBpActLimitsTs(new ArrayList<>(List.of(PrmStudyBpActLimitsT.builder()
                .id(PrmStudyBpActLimitsTPK.builder().pbId(555L).bpId(11L).build())
                .vcFlag(BigDecimal.ONE)
                .vcMin(BigDecimal.valueOf(2))
                .vcMax(BigDecimal.valueOf(8))
                .build())));

        when(studyDetailMapper.convertToPrmStudyMasterT(studyDTO)).thenReturn(entity);
        when(studyRepository.saveAndFlush(any(PrmStudyMasterT.class))).thenAnswer(invocation -> invocation.getArgument(0));
        when(studyDetailMapper.toStudyDTO(any(PrmStudyMasterT.class))).thenReturn(studyDTO);

        StudyDTO result = studyService.updateStudy(555, studyDTO);

        assertNotNull(result);

        ArgumentCaptor<PrmStudyMasterT> captor = ArgumentCaptor.forClass(PrmStudyMasterT.class);
        verify(studyRepository).saveAndFlush(captor.capture());
        PrmStudyMasterT saved = captor.getValue();

        assertEquals(555L, saved.getPbId());
        assertEquals(BigDecimal.ZERO, saved.getPbExcpOnlyFlag());
        assertEquals(BigDecimal.ONE, saved.getPbUseDwFlag());
        assertEquals(BigDecimal.ONE, saved.getPbUseVwFlag());
        assertEquals(1, saved.getPrmStudyTimePeriodsTs().size());
        assertEquals(555L, saved.getPrmStudyTimePeriodsTs().get(0).getId().getPbId());
        assertNotNull(saved.getPrmStudyTimePeriodsTs().get(0).getUpdateDte());
        assertEquals(1, saved.getPrmStudyBpActLimitsTs().size());
        assertEquals(555L, saved.getPrmStudyBpActLimitsTs().get(0).getId().getPbId());
        assertEquals(1, saved.getPrmStudyRsRiTs().size());
        assertEquals(1, saved.getPrmStudyRsRiExceptTs().size());
    }

    @Test
    void isJobsExistWithStudyReturnsFalseForEmptyListAndTrueWhenJobsPresent() {
        when(jobsRepository.findJobsWithStudyId(1L)).thenReturn(List.of());
        when(jobsRepository.findJobsWithStudyId(2L)).thenReturn(List.of(new com.optum.fads.pgp.study.domain.JobMasterT()));

        assertTrue(!studyService.isJobsExistWithStudy(1L));
        assertTrue(studyService.isJobsExistWithStudy(2L));
    }

    private static StudyDTO baseStudyDto() {
        LocalDateTime now = LocalDateTime.of(2026, 4, 8, 10, 15);

        ReportItem reportItem = ReportItem.builder()
                .reportItemId(200L)
                .lowerLimit(BigDecimal.ONE)
                .upperLimit(BigDecimal.TEN)
                .percentage(BigDecimal.valueOf(15))
                .standardDeviation(BigDecimal.valueOf(3))
                .weight(BigDecimal.valueOf(4))
                .exceptionProcesses(List.of(new ExceptionProcess(7L, BigDecimal.ONE, BigDecimal.ZERO)))
                .build();

        ReportSection reportSection = ReportSection.builder()
                .reportSectionId(1L)
                .rsOrder(1L)
                .reportItems(Set.of(reportItem))
                .build();

        StudyDTO dto = new StudyDTO();
        dto.setCreateDate(now);
        dto.setUpdateDate(now.plusHours(1));
        dto.setTimePeriods(List.of(TimePeriod.builder()
                .timePeriodId(1L)
                .fromDate(LocalDate.of(2026, 1, 1))
                .toDate(LocalDate.of(2026, 1, 31))
                .weight(BigDecimal.valueOf(50))
                .build()));
        dto.setActivityLimits(Set.of(ActivityLimit.builder()
                .behaviorPatternId(11L)
                .flag(BigDecimal.ONE)
                .min(BigDecimal.valueOf(2))
                .max(BigDecimal.valueOf(8))
                .build()));
        dto.setReportSections(Set.of(reportSection));
        return dto;
    }

    private static PrmStudyMasterT baseStudyEntity(long studyId) {
        PrmStudyMasterT entity = new PrmStudyMasterT();
        entity.setPbId(studyId);
        entity.setPrmStudyTimePeriodsTs(new ArrayList<>());
        entity.setPrmStudyBpActLimitsTs(new ArrayList<>());
        entity.setPrmStudyRsRiTs(new ArrayList<>());
        entity.setPrmStudyRsRiExceptTs(new ArrayList<>());
        return entity;
    }

    private void inject(String fieldName, Object value) throws Exception {
        Field field = StudyService.class.getDeclaredField(fieldName);
        field.setAccessible(true);
        field.set(studyService, value);
    }
}
