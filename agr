    @Test
    void addDataRuleCreatesNewRuleWithCodeValuesWhenLookupReturnsNoStoredValues() {
        DataRuleDTO input = buildInputDto(DataRuleConstants.NO_VALUE);
        input.setDataRuleName("Alpha New Rule");
        input.setSelectedValues(new ArrayList<>(List.of(buildCodeValue("A", "Adult"), buildCodeValue("B", "Basic"))));
        input.setRangeValues(new ArrayList<>());

        when(dataRulesRepository.getDataRuleByName("alpha new rule")).thenReturn(null);
        when(dataRuleMasterRepository.retrieveNextDrId()).thenReturn(7001);
        when(dataRuleMasterRepository.saveAndFlush(any(PrmDrDataRuleT.class))).thenAnswer(inv -> inv.getArgument(0));
        when(dataRuleMasterRepository.retrieveDataRuleById(7001))
                .thenReturn(buildRuleWithoutValues(7001, "Alpha New Rule"));

        ArgumentCaptor<PrmDrDataRuleT> captor = ArgumentCaptor.forClass(PrmDrDataRuleT.class);

        DataRuleDTO result = service.addDataRule(input);

        verify(dataRuleMasterRepository).saveAndFlush(captor.capture());
        verify(dataRuleSingleValuesRepository).saveAll(anyList());
        verify(dataRuleSingleValuesRepository).flush();
        assertEquals(7001, result.getDataRuleId());
        assertEquals(DataRuleConstants.NO_VALUE, result.getRangeValue());
        assertEquals(2, result.getSelectedValues().size());
        assertEquals("creator", captor.getValue().getUiUserBaseCr().getUiSystemId());
        assertEquals("updater", captor.getValue().getUiUserBaseUpd().getUiSystemId());
    }

