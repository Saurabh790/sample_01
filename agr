        ClaimCorrectionDTO result = caseDetailClaimsService.findClaimCorrectionByCaseIdTcnLiNum(99, 7, "TCN", "1");

        assertEquals(99, result.getCaseId());
        assertEquals(7, result.getClmSeqNum());
        assertSame(auditedClaim, result.getAuditClaim());
        assertSame(sourceClaim, result.getSourceClaim());
    }

