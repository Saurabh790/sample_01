    @Test
    public void createIndBatchCaseEntriesSavesUniverseRowsAndSendsSuccessAndAssignmentMail() {
        CaseBatchIndividualService spyService = org.mockito.Mockito.spy(caseBatchIndividualService);
        ReflectionTestUtils.setField(spyService, "modelMapper", createConfiguredModelMapper());

        CaUniverseT first = createUniverse();
        first.setParticipantId("PART-1");
        first.setHdrRecipFullNm("Alpha");
        first.setInvstTypeCd(CaseEntryConstants.INVESTIGATION_TYPE_PRELIMINARY);

        CaUniverseT second = createUniverse();
        second.setParticipantId("PART-2");
        second.setHdrRecipFullNm("Beta");
        second.setInvstTypeCd(CaseEntryConstants.INVESTIGATION_TYPE_PRELIMINARY);

        CaseBaseInfo firstInfo = new CaseBaseInfo();
        firstInfo.setCaseId(200);
        firstInfo.setSequenceId(1);
        firstInfo.setCaseIdStr("PAU-2024-00001");
        firstInfo.setParticpantId("PART-1");
        firstInfo.setParticpantName("Alpha");

        CaseBaseInfo secondInfo = new CaseBaseInfo();
        secondInfo.setCaseId(201);
        secondInfo.setSequenceId(2);
        secondInfo.setCaseIdStr("PAU-2024-00002");
        secondInfo.setParticpantId("PART-2");
        secondInfo.setParticpantName("Beta");

        CaIntelligentKeyT firstKey = CaIntelligentKeyT.builder().caseId(200).build();
        CaIntelligentKeyT secondKey = CaIntelligentKeyT.builder().caseId(201).build();

        when(caseBatchUtil.getZoneId()).thenReturn(ZoneId.of("UTC"));
        when(caseBatchUtil.getEmailSpecs()).thenReturn(new EmailSpecification());
        doReturn(firstInfo).doReturn(secondInfo).when(spyService).getCaseIndValue(eq("PAU"), eq(2024), any(String.class));
        doReturn(firstKey).doReturn(secondKey).when(spyService)
                .createIntGenPrRpInvstEntries(any(CaseBaseInfo.class), any(LocalDateTime.class), any(CaUniverseT.class));
        doNothing().when(spyService).createClaimsList(any(CaIntelligentKeyT.class), any(List.class), any(String.class), any(String.class));
        doNothing().when(spyService).saveCaIntelligentKeyTentry(any(CaIntelligentKeyT.class));

        spyService.createIndBatchCaseEntries(Arrays.asList(first, second));

        verify(caUniverseRepository, org.mockito.Mockito.times(2)).saveAll(any(List.class));
        verify(caUniverseRepository, org.mockito.Mockito.times(2)).flush();
        verify(caseBatchEmailService, org.mockito.Mockito.times(2))
                .postBatchProcessMail(any(com.optum.fads.caseentrybatch.api.dto.EmailData.class), any(EmailSpecification.class));
    }

