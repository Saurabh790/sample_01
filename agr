@RunWith(MockitoJUnitRunner.class)
public class CaseBatchControllerTests {

    @Mock
    private ICaseBatchService caseBatchService;

    @InjectMocks
    private CaseBatchController caseBatchController;

    @Test
    public void runCaseBatchReturnsOkWhenBatchCreationSucceeds() {
        ReflectionTestUtils.setField(caseBatchController, "iCaseBatchService", caseBatchService);
        when(caseBatchService.createBatchCase()).thenReturn("Success");

        ResponseEntity<String> response = caseBatchController.runCaseBatch();

