    @Test
    void findClaimCorrectionByCaseIdTcnLiNumUsesExistingCorrectionWhenPresent() {
        CaUniverseT universe = new CaUniverseT();
        CaClaimCorrectionsT correction = CaClaimCorrectionsT.builder()
                .id(CaClaimCorrectionsTId.builder().caseId(385).clmSeqNum(1).build())
                .hdrClmPdDt(new Date())
                .hdrClmTcn("B0509830649171000")
                .liNum("2")
                .docReceivedInd("Y")
                .build();
        ClaimDTO sourceClaim = ClaimDTO.builder().liDrugNdc("source").build();
        ClaimDTO auditedClaim = ClaimDTO.builder().liDrugNdc("audit").build();

        when(caUniverseRepository.findByTcnLiNumCaseId("B0509830649171000", "2", 385)).thenReturn(universe);
        when(claimCorrectionsRepo.findById(CaClaimCorrectionsTId.builder().caseId(385).clmSeqNum(1).build()))
                .thenReturn(Optional.of(correction));
        when(claimCorrectionMapper.getSourceClaim(universe)).thenReturn(sourceClaim);
        when(claimCorrectionMapper.getAuditedClaim(correction)).thenReturn(auditedClaim);

        ClaimCorrectionDTO result =
                caseDetailClaimsService.findClaimCorrectionByCaseIdTcnLiNum(385, 1, "B0509830649171000", "2");

        assertEquals(385, result.getCaseId());
        assertEquals(1, result.getClmSeqNum());
        assertSame(sourceClaim, result.getSourceClaim());
        assertSame(auditedClaim, result.getAuditClaim());
        assertEquals("Y", result.getDocReceivedInd());
    }

    @Test
    void findClaimCorrectionByCaseIdTcnLiNumFallsBackToBlankCorrectionWhenMissing() {
        CaUniverseT universe = new CaUniverseT();
        ClaimDTO sourceClaim = new ClaimDTO();
        ClaimDTO auditedClaim = new ClaimDTO();

        when(caUniverseRepository.findByTcnLiNumCaseId("TCN", "1", 99)).thenReturn(universe);
        when(claimCorrectionsRepo.findById(CaClaimCorrectionsTId.builder().caseId(99).clmSeqNum(7).build()))
                .thenReturn(Optional.empty());
        when(claimCorrectionMapper.getSourceClaim(universe)).thenReturn(sourceClaim);
