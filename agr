        this(Arrays.asList(errorInfo), httpStatus, cause);
    }

    public CaseClaimCorrectionException(ErrorInfo errorInfo, String caseId, HttpStatus httpStatus) {
        this(Arrays.asList(errorInfo), caseId, httpStatus);
    }

    public CaseClaimCorrectionException(ErrorInfo errorInfo, String caseId, HttpStatus httpStatus, Throwable cause) {
        this(Arrays.asList(errorInfo), caseId, httpStatus, cause);
    }

    public CaseClaimCorrectionException(List<ErrorInfo> errorsInfo, String caseId) {
        this(errorsInfo, caseId, HttpStatus.BAD_REQUEST);
    }

    public CaseClaimCorrectionException(List<ErrorInfo> errorsInfo, String caseId, HttpStatus httpStatus) {
        this(errorsInfo, caseId, httpStatus, null);
    }

    public CaseClaimCorrectionException(ErrorInfo errorInfo, String caseId, Throwable cause) {
        this(Arrays.asList(errorInfo), caseId, cause);
    }

    public CaseClaimCorrectionException(List<ErrorInfo> errorsInfo, String caseId, Throwable cause) {
        this(errorsInfo, caseId, HttpStatus.BAD_REQUEST, cause);
    }

    public CaseClaimCorrectionException(List<ErrorInfo> errorsInfo, String caseId, HttpStatus httpStatus, Throwable cause) {
        super(cause);
        this.errorsInfo = errorsInfo;
        this.caseId = caseId;
        this.httpStatus = httpStatus;
    }

    public CaseClaimCorrectionException(List<ErrorInfo> errorsInfo, HttpStatus httpStatus, Throwable cause) {
        super(cause);
        this.errorsInfo = errorsInfo;
        this.httpStatus = httpStatus;
    }

    /**
     * @return the errors
     */
    public List<ErrorInfo> getErrorsInfo() {
        return errorsInfo;
    }

    /**
     * @param errorsInfo the set of errors.
     */
    public void setErrorsInfo(List<ErrorInfo> errorsInfo) {
        this.errorsInfo = errorsInfo;
    }

    /**
     * @return the {@link String}
     */
    public String getString() {
        return caseId;
    }

    /**
     * @param String the String to set
     */
    public void setString(String caseId) {
        this.caseId = caseId;
    }

    /**
     * @return the httpStatus
     */
    public HttpStatus getHttpStatus() {
        return httpStatus;
    }

    /**
     * @param httpStatus the httpStatus to set
     */
    public void setHttpStatus(HttpStatus httpStatus) {
        this.httpStatus = httpStatus;
    }

    @Override
    public String toString() {
        StringBuilder sb = new StringBuilder();

        sb.append("CaseId : " + caseId);
        sb.append("; ");
        if (errorsInfo != null) {
            sb.append("errorInfo : " + errorsInfo.toString());
            sb.append("; ");
        }
        sb.append("HttpStatus : " + httpStatus);

        return sb.toString();
    }

}
