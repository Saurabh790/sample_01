            <version>${project.version}</version>
        </dependency>
        <dependency>
            <groupId>com.optum.fads</groupId>
            <artifactId>fads-case-config</artifactId>
            <version>${project.version}</version>
        </dependency>
        <dependency>
            <groupId>com.optum.fads</groupId>
            <artifactId>fads-casetracking</artifactId>
            <version>${project.version}</version>
        </dependency>
        <dependency>
            <groupId>com.optum.fads</groupId>
            <artifactId>fads-pgp-behavior-api</artifactId>
            <version>${project.version}</version>
        </dependency>
        <dependency>
            <groupId>com.optum.fads</groupId>
            <artifactId>fads-pgp-reportsection-api</artifactId>
            <version>${project.version}</version>
        </dependency>
        <dependency>
            <groupId>com.optum.fads</groupId>
            <artifactId>fads-pgp-study-api</artifactId>
            <version>${project.version}</version>
        </dependency>
        <dependency>
            <groupId>com.optum.fads</groupId>
            <artifactId>fads-pgp-jobmonitor-api</artifactId>
            <version>${project.version}</version>
        </dependency>

        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter-web</artifactId>
        </dependency>

        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter-tomcat</artifactId>
            <scope>provided</scope>
        </dependency>

        <dependency>
            <groupId>org.apache.tomcat.embed</groupId>
            <artifactId>tomcat-embed-jasper</artifactId>
            <version>${tomcat.version}</version>
        </dependency>

        <dependency>
            <groupId>jakarta.servlet.jsp.jstl</groupId>
            <artifactId>jakarta.servlet.jsp.jstl-api</artifactId>
            <version>3.0.0</version>
        </dependency>

        <dependency>
            <groupId>org.glassfish.web</groupId>
            <artifactId>jakarta.servlet.jsp.jstl</artifactId>
            <version>3.0.1</version>
        </dependency>

