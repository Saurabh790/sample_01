CREATE TABLE PRM_MB_MASTER_T (
    MB_CTEC_FID INT PRIMARY KEY
);

CREATE TABLE FADS_LU_VALUES_T (
    LU_ID VARCHAR(50),
    LU_LABEL VARCHAR(100)
);

CREATE TABLE PRM_DR_LU_OPERATOR_T (
    OPERATOR_CD VARCHAR(10) PRIMARY KEY,
    OPERATOR_DESC VARCHAR(100)
);

CREATE TABLE UI_USER_BASE (
    UI_SYSTEM_ID VARCHAR(25) PRIMARY KEY
);

CREATE TABLE PRM_DR_DATA_RULE_T (
    DR_ID INT PRIMARY KEY,
    DATA_RULE_NAME VARCHAR(255),
    OPERATOR_CD VARCHAR(10),
    MB_CTEC_FID INT,
    CREATED_BY VARCHAR(25),
    MODIFIED_BY VARCHAR(25),

    CONSTRAINT FK_MB FOREIGN KEY (MB_CTEC_FID)
        REFERENCES PRM_MB_MASTER_T(MB_CTEC_FID),

    CONSTRAINT FK_OP FOREIGN KEY (OPERATOR_CD)
        REFERENCES PRM_DR_LU_OPERATOR_T(OPERATOR_CD)
);


