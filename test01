package com.optum.fads.casereminders.api.config;

import java.security.PrivateKey;
import java.util.HashMap;
import java.util.Properties;

import javax.sql.DataSource;

import org.slf4j.Logger;
import org.slf4j.LoggerFactory;
import org.springframework.beans.factory.annotation.Qualifier;
import org.springframework.beans.factory.annotation.Value;
import org.springframework.boot.autoconfigure.EnableAutoConfiguration;
import org.springframework.boot.autoconfigure.jdbc.DataSourceAutoConfiguration;
import org.springframework.context.annotation.Bean;
import org.springframework.context.annotation.Configuration;
import org.springframework.data.jpa.repository.config.EnableJpaRepositories;
import org.springframework.jdbc.core.JdbcTemplate;
import org.springframework.jdbc.datasource.DriverManagerDataSource;
import org.springframework.orm.jpa.JpaTransactionManager;
import org.springframework.orm.jpa.LocalContainerEntityManagerFactoryBean;
import org.springframework.orm.jpa.vendor.HibernateJpaVendorAdapter;
import org.springframework.transaction.PlatformTransactionManager;
import org.springframework.transaction.annotation.EnableTransactionManagement;

import com.azure.security.keyvault.secrets.SecretClient;
import com.zaxxer.hikari.HikariDataSource;

import jakarta.persistence.EntityManagerFactory;
import net.snowflake.client.jdbc.SnowflakeBasicDataSource;

@Configuration
@EnableAutoConfiguration(exclude = { DataSourceAutoConfiguration.class })
@EnableTransactionManagement
@EnableJpaRepositories(
        entityManagerFactoryRef = "snfkEntityManagerFactory",
        transactionManagerRef = "txManagerSNFK",
        basePackages = { "com.optum.fads.casereminders.api.snowflakeRepo" }
)
public class ServiceConfigSNFK {

    private static final Logger logger = LoggerFactory.getLogger(ServiceConfigSNFK.class);

    @Value("${spring.datasource.snfk.jdbcUrl}")
    private String url;

    // These values are KeyVault secret NAMES (not real values)
    @Value("${spring.datasource.snfk.userName}")
    private String username;

    @Value("${spring.datasource.snfk.password}")
    private String password;

    @Value("${spring.datasource.snfk.certKey:}")
    private String certKey;

    @Value("${spring.datasource.snfk.passphrase:}")
    private String passphrase;

    @Value("${spring.datasource.snfk.database}")
    private String database;

    @Value("${spring.datasource.snfk.schema}")
    private String schema;

    @Value("${spring.datasource.snfk.warehouse}")
    private String warehouse;

    @Value("${spring.datasource.snfk.account:}")
    private String account;

    @Value("${spring.datasource.snfk.role:}")
    private String role;

    @Value("${db.snfk-login.useCert:false}")
    private Boolean useCert;

    private final SecretClient secretClient;

    public ServiceConfigSNFK(SecretClient secretClient) {
        this.secretClient = secretClient;
    }

    @Bean(name = "fadsSNFKDataSource")
    public DataSource snfkDataSource() throws Exception {
        return Boolean.TRUE.equals(useCert) ? createCertDataSource() : createPasswordDataSource();
    }

    private DataSource createCertDataSource() throws Exception {
        logger.info("Snowflake auth using certificate PEM from Key Vault.");

        // certKey contains the secret NAME that holds PEM content
        String pem = secretClient.getSecret(certKey).getValue();

        char[] passChars = resolvePassphraseChars();
        PrivateKey privateKey = PemKeyLoader.loadPrivateKeyPem(pem, passChars);

        // username contains the secret NAME that holds actual username
        String userValue = secretClient.getSecret(username).getValue();

        SnowflakeBasicDataSource sf = new SnowflakeBasicDataSource();
        sf.setUrl(url);
        sf.setDatabaseName(database);
        sf.setSchema(schema);
        sf.setWarehouse(warehouse);
        if (account != null && !account.isBlank()) sf.setAccount(account);
        if (role != null && !role.isBlank()) sf.setRole(role);

        sf.setUser(userValue);
        sf.setPrivateKey(privateKey);

        HikariDataSource hikari = new HikariDataSource();
        hikari.setDataSource(sf);
        return hikari;
    }

    private DataSource createPasswordDataSource() {
        logger.info("Snowflake auth using username/password from Key Vault.");

        String userValue = secretClient.getSecret(username).getValue();
        String passValue = secretClient.getSecret(password).getValue();

        Properties props = new Properties();
        props.put("user", userValue);
        props.put("password", passValue);
        props.put("database", database);
        props.put("schema", schema);
        props.put("warehouse", warehouse);
        if (role != null && !role.isBlank()) props.put("role", role);
        if (account != null && !account.isBlank()) props.put("account", account);

        return new DriverManagerDataSource(url, props);
    }

    private char[] resolvePassphraseChars() {
        // passphrase contains the secret NAME holding the passphrase value
        if (passphrase == null || passphrase.isBlank()) return null;
        String passValue = secretClient.getSecret(passphrase).getValue();
        return (passValue == null || passValue.isBlank()) ? null : passValue.toCharArray();
    }

    @Bean(name = "snfkEntityManagerFactory")
    public LocalContainerEntityManagerFactoryBean snfkEntityManagerFactory(
            @Qualifier("fadsSNFKDataSource") DataSource ds) {

        LocalContainerEntityManagerFactoryBean em = new LocalContainerEntityManagerFactoryBean();
        em.setDataSource(ds);
        em.setPackagesToScan("com.optum.fads.casereminders.api.snowflakeDomain");
        em.setJpaVendorAdapter(new HibernateJpaVendorAdapter());

        HashMap<String, Object> properties = new HashMap<>();
        properties.put("hibernate.allow_update_outside_transaction", true);
        properties.put("hibernate.dialect", "com.optum.fads.casereminders.api.config.SnowflakeDialect");
        em.setJpaPropertyMap(properties);

        return em;
    }

    @Bean(name = "txManagerSNFK")
    public PlatformTransactionManager txManagerSNFK(
            @Qualifier("snfkEntityManagerFactory") EntityManagerFactory snfkEntityManagerFactory) {

        JpaTransactionManager txManager = new JpaTransactionManager();
        txManager.setEntityManagerFactory(snfkEntityManagerFactory);
        return txManager;
    }

    @Bean(name = "jdbcSnowflake")
    public JdbcTemplate snowflakeJdbcTemplate(@Qualifier("fadsSNFKDataSource") DataSource ds) {
        return new JdbcTemplate(ds);
    }
}
