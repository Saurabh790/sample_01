server:
  port: 8080
  address: 0.0.0.0
  servlet:
    context-path: /datarules

management:
  server:
    port: 8081
    address: 0.0.0.0
  endpoints:
    enabled-by-default: true
    web:
      exposure:
        include: health,info,metrics,env,loggers
  endpoint:
    health:
      enabled: true
      show-details: always

quickstart:
  generate-order-period: 10s
  process-order-period: 30s

spring:
  main:
    allow-bean-definition-overriding: true
    banner-mode: "off"

  datasource:
    url: jdbc:h2:mem:testdb;MODE=MSSQLServer;DB_CLOSE_DELAY=-1;DB_CLOSE_ON_EXIT=FALSE
    username: sa
    password:
    driver-class-name: org.h2.Driver

  jpa:
    show-sql: false
    defer-datasource-initialization: true
    hibernate:
      ddl-auto: none

  sql:
    init:
      mode: always
      platform: h2

logging:
  level:
    org:
      hibernate:
        SQL: INFO
        orm:
          jdbc:
            bind: INFO
