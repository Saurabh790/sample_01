package com.optum.fads.pgp.datarules;

import static org.junit.jupiter.api.Assertions.assertEquals;

import java.util.HashSet;
import java.util.List;
import java.util.Optional;
import java.util.Set;

import org.junit.jupiter.api.Test;
import org.slf4j.Logger;
import org.slf4j.LoggerFactory;
import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.boot.data.jpa.test.autoconfigure.DataJpaTest;

import com.optum.fads.pgp.datarules.domain.PrmDrSingleValuesT;
import com.optum.fads.pgp.datarules.domain.PrmDrSingleValuesTPK;
import com.optum.fads.pgp.datarules.repo.DataRuleSingleValuesRepository;

@DataJpaTest
class DataRuleSingleValuesRepositoryTest {

    @Autowired
    private DataRuleSingleValuesRepository dataRuleSingleValuesRepository;

    private static final Logger logit =
            LoggerFactory.getLogger(DataRuleSingleValuesRepositoryTest.class);

    @Test
    void testGetCodeValues() {
        Integer dataruleId = 986;
        List<PrmDrSingleValuesT> prmDrSingleValuesList =
                dataRuleSingleValuesRepository.retrieveCodeValues(dataruleId);

        assertEquals(4, prmDrSingleValuesList.size());
        assertEquals(dataruleId, prmDrSingleValuesList.get(0).getId().getDrId());
    }

    @Test
    void deleteSingleValuesTest() {
        Integer dataruleId = 986;
        int deleteCount = dataRuleSingleValuesRepository.deleteSingleValuesByDataRuleId(dataruleId);

        logit.info("Code Values deleted = {}", deleteCount);
        assertEquals(4, deleteCount);
    }

    @Test
    void saveSingleValuesTest() {
        Integer dataruleId = 999;
        Set<PrmDrSingleValuesT> prmDrSingleValues = new HashSet<>();

        PrmDrSingleValuesT prmDrSingleValuesT1 = new PrmDrSingleValuesT();
        PrmDrSingleValuesTPK prmDrSingleValuesTPK1 = new PrmDrSingleValuesTPK();
        prmDrSingleValuesTPK1.setDrId(dataruleId);
        prmDrSingleValuesTPK1.setDrValue("RF");
        prmDrSingleValuesT1.setId(prmDrSingleValuesTPK1);
        prmDrSingleValuesT1.setDrLabel("Referring Provider");
        prmDrSingleValues.add(prmDrSingleValuesT1);

        PrmDrSingleValuesT prmDrSingleValuesT2 = new PrmDrSingleValuesT();
        PrmDrSingleValuesTPK prmDrSingleValuesTPK2 = new PrmDrSingleValuesTPK();
        prmDrSingleValuesTPK2.setDrId(dataruleId);
        prmDrSingleValuesTPK2.setDrValue("RF");
        prmDrSingleValuesT2.setId(prmDrSingleValuesTPK2);
        prmDrSingleValuesT2.setDrLabel("Referring Provider");
        prmDrSingleValues.add(prmDrSingleValuesT2);

        logit.info("dataRuleSingleValuesRepository.saveAll - prmDrSingleValues Test");
        dataRuleSingleValuesRepository.saveAll(prmDrSingleValues);

        PrmDrSingleValuesTPK prmDrSingleValuesTPK = new PrmDrSingleValuesTPK();
        prmDrSingleValuesTPK.setDrId(dataruleId);
        prmDrSingleValuesTPK.setDrValue("RF");

        Optional<PrmDrSingleValuesT> prmDrSingleValue =
                dataRuleSingleValuesRepository.findById(prmDrSingleValuesTPK);

        assertEquals("Referring Provider", prmDrSingleValue.orElseThrow().getDrLabel());
    }
}


package com.optum.fads.pgp.datarules;

import static org.junit.jupiter.api.Assertions.assertEquals;
import static org.junit.jupiter.api.Assertions.assertNotNull;

import java.text.ParseException;
import java.time.LocalDateTime;

import org.junit.jupiter.api.Test;
import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.boot.data.jpa.test.autoconfigure.DataJpaTest;

import com.optum.fads.pgp.datarules.domain.PrmDrDataRuleT;
import com.optum.fads.pgp.datarules.domain.PrmDrLuOperatorT;
import com.optum.fads.pgp.datarules.domain.PrmMbMasterT;
import com.optum.fads.pgp.datarules.domain.UiUserBase;
import com.optum.fads.pgp.datarules.repo.DataRuleMasterRepository;

@DataJpaTest
class DataRulesMasterRepositoryTests {

    @Autowired
    private DataRuleMasterRepository dataRuleMasterRepository;

    @Test
    void testGetDataRule() {
        Integer dataRuleId = 988;
        PrmDrDataRuleT prmDrDataRuleT = dataRuleMasterRepository.retrieveDataRuleById(dataRuleId);

        assertNotNull(prmDrDataRuleT);
        assertEquals(dataRuleId, prmDrDataRuleT.getDrId());
    }

    @Test
    void testDeleteDataRule() {
        Integer dataruleId = 986;
        int deleteResult = dataRuleMasterRepository.deleteDatarule(dataruleId);

        assertEquals(1, deleteResult);
    }

    @Test
    void testUpdateDataRule() throws ParseException {
        Integer dataruleId = 988;
        int dataElementId = 117;
        LocalDateTime modifiedDate = LocalDateTime.now();

        int updateResult = dataRuleMasterRepository.updateDataRuleDb(
                "AW:Proc cd=98940-3, Chiro Manipulation 1-4 Regions",
                dataElementId,
                "2",
                "WA40122433",
                modifiedDate,
                dataruleId);

        assertEquals(1, updateResult);

        PrmDrDataRuleT prmDrDataRuleT = dataRuleMasterRepository.retrieveDataRuleById(dataruleId);
        assertEquals("AW:Proc cd=98940-3, Chiro Manipulation 1-4 Regions",
                prmDrDataRuleT.getDataRuleName());
        assertEquals("2", prmDrDataRuleT.getPrmDrLuOperatorT().getOperatorCd());
    }

    @Test
    void testNewDataRule() {
        Integer dataruleId = 999;
        LocalDateTime currentDate = LocalDateTime.now();

        PrmDrDataRuleT prmDrDataRuleT = new PrmDrDataRuleT();

        UiUserBase uiUserBase = new UiUserBase();
        uiUserBase.setUiSystemId("WA40122433");
        prmDrDataRuleT.setUiUserBaseCr(uiUserBase);
        prmDrDataRuleT.setUiUserBaseUpd(uiUserBase);

        PrmMbMasterT prmMbMasterT = new PrmMbMasterT();
        prmMbMasterT.setMbCtecFid(316);
        prmDrDataRuleT.setPrmMbMasterT(prmMbMasterT);

        PrmDrLuOperatorT prmDrLuOperatorT = new PrmDrLuOperatorT();
        prmDrLuOperatorT.setOperatorCd("1");
        prmDrLuOperatorT.setOperatorDesc("Inclusive");
        prmDrDataRuleT.setPrmDrLuOperatorT(prmDrLuOperatorT);

        prmDrDataRuleT.setDrId(dataruleId);
        prmDrDataRuleT.setDataRuleName("AW:Prov Role = Referring/Servicing");
        prmDrDataRuleT.setCreateDate(currentDate);
        prmDrDataRuleT.setUpdateDate(currentDate);

        PrmDrDataRuleT savedEntity = dataRuleMasterRepository.save(prmDrDataRuleT);

        assertEquals(prmDrDataRuleT.getDataRuleName(), savedEntity.getDataRuleName());
        assertEquals(prmDrDataRuleT.getPrmDrLuOperatorT().getOperatorCd(),
                savedEntity.getPrmDrLuOperatorT().getOperatorCd());
    }
}


