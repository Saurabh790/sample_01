	@RequestMapping(method = {RequestMethod.POST, RequestMethod.GET}, value = "caseDetail/saveAsCase/{userId}", headers = "Accept=application/json")
	public @ResponseBody Map<String, String> saveAsCase(@RequestBody CaseDetailDTO caseDetailDTO, @PathVariable("userId") String userId) {
		if (caseDetailDTO.getIntelligentKey().getCaseId() != null && caseDetailDTO.getIntelligentKey().getCaseId() > 0) {
			try {
				CaseSaveAsBean caseSaveAsBean = caseDetailDTO.getSaveAsBean();

				if (caseSaveAsBean.getPrimeNode() != null && caseUserService.isUserCaseSaveAccess(userId, caseSaveAsBean.getPrimeNode())) {
					CaseDetailDTO newCaseDTO = new CaseDetailDTO();

					String caseIntelIdString;
					Map<String, String> map = new HashMap<>();

					IntelligentKey iKey = new IntelligentKey();

					iKey.setPrimaryNode(caseSaveAsBean.getPrimeNode());
					iKey.setSecondaryNode(caseSaveAsBean.getSecondaryNode());
					iKey.setFisYearId(caseSaveAsBean.getFisYearId());
					iKey.setCaseType(caseDetailDTO.getIntelligentKey().getCaseType());
					iKey.setCreatedBy(userId);
					iKey.setCreatedDt(DateUtil.createPlainDate(new Date()));
					iKey.setUpdatedBy(userId);
					iKey.setUpdatedDt(DateUtil.createPlainDate(new Date()));

					newCaseDTO.setIntelligentKey(iKey);
					newCaseDTO.setGeneral(caseDetailDTO.getGeneral());
					//newCaseDTO.setContact(caseDetailDTO.getContact());
					newCaseDTO.setProvider(caseDetailDTO.getProvider());
					newCaseDTO.setRecipient(caseDetailDTO.getRecipient());
					newCaseDTO.setRecipientLockins(caseDetailDTO.getRecipientLockins());
					newCaseDTO.setNatSettlement(caseDetailDTO.getNatSettlement());

					if (caseSaveAsBean.isNotesSelector()) {
						newCaseDTO.setNotes(caseDetailNotesService.findNotes(caseDetailDTO.getIntelligentKey().getCaseId()));
					}
					if (caseSaveAsBean.isRemindersSelector()) {
						newCaseDTO.setReminders(reminderService.findReminders(caseDetailDTO.getIntelligentKey().getCaseId()));
					}

					IntelligentKey newCaseIntelId = caseDetailService.saveAsCase(newCaseDTO, userId);
					caseIntelIdString = CommonUtil.createIntelligentKeyId(newCaseIntelId);

					reminderEmailService.saveAsCaseEmails(caseSaveAsBean, newCaseIntelId, caseDetailDTO, userId);

					map.put("cid", caseIntelIdString);
					return map;
				}
			} catch (Exception e) {
				e.printStackTrace();
				throw new ResponseStatusException(HttpStatus.INTERNAL_SERVER_ERROR, "save as case error: ", e);
			}
		}
		return null;
	}

