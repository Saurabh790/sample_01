				 caseDetail.setIntelligentKey(intelligentKey);
				 GeneralBean general= new GeneralBean();
			     if(CaseGlobalConstants.DEFAULT_RESTRICT_TYPE!=null){
						general.setProtectStatus(CaseGlobalConstants.DEFAULT_RESTRICT_TYPE);
					
					}
				 caseDetail.setGeneral(general);
				 if ((caseType.equalsIgnoreCase(CaseConstants.CASE_TYPE_PV)) || (caseType.equalsIgnoreCase(CaseConstants.CASE_TYPE_PE))) {
					 ProviderBean provider = new  ProviderBean();
					 caseDetail.setProvider(provider);
				   } else if ((caseType.equalsIgnoreCase(CaseConstants.CASE_TYPE_RP)) || (caseType.equalsIgnoreCase(CaseConstants.CASE_TYPE_MB))) {
