package com.optum.fads.pgp.datarules.repo;

import java.util.List;

import org.springframework.data.domain.Pageable;
import org.springframework.data.jpa.repository.JpaRepository;
import org.springframework.data.jpa.repository.JpaSpecificationExecutor;
import org.springframework.data.jpa.repository.Query;
import org.springframework.data.repository.query.Param;
import org.springframework.stereotype.Repository;
import org.springframework.transaction.annotation.Transactional;

import com.optum.fads.pgp.datarules.domain.FadsConfigT;
import com.optum.fads.pgp.datarules.domain.PrmDrDataRuleT;

@Transactional
@Repository
public interface DataRulesRepository extends  JpaRepository <PrmDrDataRuleT, Integer>, JpaSpecificationExecutor<PrmDrDataRuleT> {
		
	@Query(" FROM PrmDrDataRuleT pd" )
	List<PrmDrDataRuleT> getDataRules(Pageable pageRequest );
	
	@Query(" FROM PrmDrDataRuleT pd WHERE pd.drId NOT IN :drIds" )
	List<PrmDrDataRuleT> getAvailableDataRules(@Param("drIds") List<Integer> drIds, Pageable pageRequest );

	@Query(" FROM PrmDrDataRuleT pd  WHERE lower(pd.dataRuleName) like :dataruleName "
			+ "and (lower(pd.uiUserBaseCr.userFullName) like :createdBy or lower(pd.uiUserBaseCr.uiLastName) like :createdBy) "
			+ "and (lower(pd.uiUserBaseUpd.userFullName) like :updatedBy or lower(pd.uiUserBaseUpd.uiLastName) like :updatedBy)" )
	List<PrmDrDataRuleT> getDataRulesBySearchCrit(@Param("dataruleName") String dataruleName,  
			@Param("createdBy") String createdBy, @Param("updatedBy") String updatedBy, Pageable pageRequest );
	
	// My items
	
	@Query(" FROM PrmDrDataRuleT pd  WHERE lower(pd.dataRuleName) like :dataruleName "
			+ "and (lower(pd.uiUserBaseCr.userFullName) like :createdBy or lower(pd.uiUserBaseCr.uiLastName) like :createdBy) "
			+ "and (lower(pd.uiUserBaseUpd.userFullName) like :updatedBy or lower(pd.uiUserBaseUpd.uiLastName) like :updatedBy) " 
			+ "and (lower(pd.uiUserBaseCr.uiSystemId) = :userSystemId or lower(pd.uiUserBaseUpd.uiSystemId) = :userSystemId)")
	List<PrmDrDataRuleT> getMyDataRulesBySearchCrit(@Param("dataruleName") String dataruleName,  
			@Param("createdBy") String createdBy, @Param("updatedBy") String updatedBy, @Param("userSystemId") String userSystemId,
			Pageable pageRequest );
	
	// Query for special characters in the data rule name
	
	@Query(" FROM PrmDrDataRuleT pd  WHERE lower(pd.dataRuleName) like :dataruleName  ESCAPE '\\' "
			+ "and (lower(pd.uiUserBaseCr.userFullName) like :createdBy or lower(pd.uiUserBaseCr.uiLastName) like :createdBy) "
			+ "and (lower(pd.uiUserBaseUpd.userFullName) like :updatedBy or lower(pd.uiUserBaseUpd.uiLastName) like :updatedBy)" )
	List<PrmDrDataRuleT> getDataRulesBySearchCritEsc(@Param("dataruleName") String dataruleName,  
			@Param("createdBy") String createdBy, @Param("updatedBy") String updatedBy, Pageable pageRequest );
	
	// My Items Query for special characters in the data rule name
	
	@Query(" FROM PrmDrDataRuleT pd  WHERE lower(pd.dataRuleName) like :dataruleName  ESCAPE '\\' "
			+ "and (lower(pd.uiUserBaseCr.userFullName) like :createdBy or lower(pd.uiUserBaseCr.uiLastName) like :createdBy) "
			+ "and (lower(pd.uiUserBaseUpd.userFullName) like :updatedBy or lower(pd.uiUserBaseUpd.uiLastName) like :updatedBy) " 
			+ "and (lower(pd.uiUserBaseCr.uiSystemId) = :userSystemId or lower(pd.uiUserBaseUpd.uiSystemId) = :userSystemId)")
	List<PrmDrDataRuleT> getMyDataRulesBySearchCritEsc(@Param("dataruleName") String dataruleName,  
			@Param("createdBy") String createdBy, @Param("updatedBy") String updatedBy,  @Param("userSystemId") String userSystemId,
			Pageable pageRequest );
	
	// Selected Items
	
	@Query(" FROM PrmDrDataRuleT pd  WHERE lower(pd.dataRuleName) like :dataruleName "
			+ "and (lower(pd.uiUserBaseCr.userFullName) like :createdBy or lower(pd.uiUserBaseCr.uiLastName) like :createdBy) "
			+ "and (lower(pd.uiUserBaseUpd.userFullName) like :updatedBy or lower(pd.uiUserBaseUpd.uiLastName) like :updatedBy) " 
			+ " and pd.drId NOT IN :drIds")
	List<PrmDrDataRuleT> getAvailableDataRulesBySearchCrit(@Param("dataruleName") String dataruleName,  
			@Param("createdBy") String createdBy, @Param("updatedBy") String updatedBy, @Param("drIds") List<Integer> drIds,
			Pageable pageRequest );
	
	// My Items with Selected Items
	
	@Query(" FROM PrmDrDataRuleT pd  WHERE lower(pd.dataRuleName) like :dataruleName "
			+ "and (lower(pd.uiUserBaseCr.userFullName) like :createdBy or lower(pd.uiUserBaseCr.uiLastName) like :createdBy) "
			+ "and (lower(pd.uiUserBaseUpd.userFullName) like :updatedBy or lower(pd.uiUserBaseUpd.uiLastName) like :updatedBy) " 
			+ "and (lower(pd.uiUserBaseCr.uiSystemId) = :userSystemId or lower(pd.uiUserBaseUpd.uiSystemId) = :userSystemId)"
			+ " and pd.drId NOT IN :drIds")
	List<PrmDrDataRuleT> getMyAvailableDataRulesBySearchCrit(@Param("dataruleName") String dataruleName,  
			@Param("createdBy") String createdBy, @Param("updatedBy") String updatedBy, @Param("userSystemId") String userSystemId,
			@Param("drIds") List<Integer> drIds, Pageable pageRequest );
	
	// Query for special characters in the data rule name, with Selected Items
	
	@Query(" FROM PrmDrDataRuleT pd  WHERE lower(pd.dataRuleName) like :dataruleName  ESCAPE '\\' "
			+ "and (lower(pd.uiUserBaseCr.userFullName) like :createdBy or lower(pd.uiUserBaseCr.uiLastName) like :createdBy) "
			+ "and (lower(pd.uiUserBaseUpd.userFullName) like :updatedBy or lower(pd.uiUserBaseUpd.uiLastName) like :updatedBy)" 
			+ " and pd.drId NOT IN :drIds")
	List<PrmDrDataRuleT> getAvailableDataRulesBySearchCritEsc(@Param("dataruleName") String dataruleName,  
			@Param("createdBy") String createdBy, @Param("updatedBy") String updatedBy,  @Param("drIds") List<Integer> drIds,
			Pageable pageRequest );
	
	// My Items Query for special characters in the data rule name, with Selected Items
	
	@Query(" FROM PrmDrDataRuleT pd  WHERE lower(pd.dataRuleName) like :dataruleName  ESCAPE '\\' "
			+ "and (lower(pd.uiUserBaseCr.userFullName) like :createdBy or lower(pd.uiUserBaseCr.uiLastName) like :createdBy) "
			+ "and (lower(pd.uiUserBaseUpd.userFullName) like :updatedBy or lower(pd.uiUserBaseUpd.uiLastName) like :updatedBy) " 
			+ "and (lower(pd.uiUserBaseCr.uiSystemId) = :userSystemId or lower(pd.uiUserBaseUpd.uiSystemId) = :userSystemId)" 
			+ " and pd.drId NOT IN :drIds")
	List<PrmDrDataRuleT> getMyAvailableDataRulesBySearchCritEsc(@Param("dataruleName") String dataruleName,  
			@Param("createdBy") String createdBy, @Param("updatedBy") String updatedBy,  @Param("userSystemId") String userSystemId,
			@Param("drIds") List<Integer> drIds, Pageable pageRequest );
	
	@Query(" FROM PrmDrDataRuleT pd  where lower(pd.dataRuleName) = :dataRuleName ")
	PrmDrDataRuleT getDataRuleByName(@Param("dataRuleName") String dataRuleName );
	
	@Query(" FROM FadsConfigT fc  where fc.optionCode = :optionCode ")
	FadsConfigT getFadsConfigByOptionCode(@Param("optionCode") Integer optionCode );
}
