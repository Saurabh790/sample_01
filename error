<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>
    <parent>
        <groupId>org.springframework.boot</groupId>
        <artifactId>spring-boot-starter-parent</artifactId>
        <version>4.0.0</version>
        <relativePath/> <!-- lookup parent from repository -->
    </parent>
     <groupId>com.optum.fads</groupId>
    <artifactId>fads-monolithic-application</artifactId>
    <packaging>pom</packaging>
    <version>9.0.0</version>
    <repositories>
        <repository>
            <id>central</id>
			<name>centraluhg.jfrog.io-releases</name>
			<url>https://centraluhg.jfrog.io/artifactory/com-optum-omms-maven-releases-vir</url>
        </repository>
        <repository>
            <id>snapshots</id>
            <name>snapshots-repo</name>
            <url>https://centraluhg.jfrog.io/artifactory/com-optum-omms-maven-snapshots</url>
        </repository>
    </repositories>
    <properties>
        <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>
        <maven.compiler.source>17</maven.compiler.source>
        <maven.compiler.target>17</maven.compiler.target>
        <maven.test.skip>false</maven.test.skip>
        <skipTests>${maven.test.skip}</skipTests>
        <!-- >surefire.skip>${skipTests}</surefire.skip -->
        <failsafe.skip>${skipTests}</failsafe.skip>

        <java.version>17</java.version>
        <spring.boot.version>3.</spring.boot.version>
        <spring-framework.version>6.1.15</spring-framework.version>

        <spring.security.version>6.2.7</spring.security.version>
        <tomcat.version>10.1.45</tomcat.version>
        <modelmapper.version>3.2.5</modelmapper.version>
        <jacoco.version>0.8.10</jacoco.version>
        <guava.version>32.1.2-jre</guava.version>
        <lombok.version>1.18.30</lombok.version>
        <sonar.exclusions>**/constants/**,**/domain/**</sonar.exclusions>
        <org.mapstruct.version>1.6.0</org.mapstruct.version>
        <log4j.version>2.20.0</log4j.version>
        <jaxb.version>2.3.1</jaxb.version>
        <sonar.version>3.9.1.2184</sonar.version>
        <snakeyaml.version>2.0</snakeyaml.version>
        <itextpdf.version>8.0.3</itextpdf.version>
        <junit.version>5.10.2</junit.version>
        <logback.version>1.4.14</logback.version>
    </properties>

    <dependencyManagement>
        <dependencies>
            <!-- Import Spring Security BOM to override Spring Boot's default version -->
            <dependency>
                <groupId>org.springframework.security</groupId>
                <artifactId>spring-security-bom</artifactId>
                <version>${spring.security.version}</version>
                <type>pom</type>
                <scope>import</scope>
            </dependency>
        </dependencies>
    </dependencyManagement>

    <modules>
		<module>fads-autherization</module>
		<module>fads-base-config</module>
        <module>fads-user-roles</module>
        <module>fads-case-config</module>
        <module>fads-casetracking</module>
        <module>fads-common-utils</module>
        <module>fads-pgp-persistence</module>
        <module>fads-pgp-datarules-api</module>
        <module>fads-pgp-behavior-api</module>
		<module>fads-pgp-reportsection-api</module>
        <module>fads-pgp-peergroup-api</module>
        <module>fads-pgp-study-api</module>
        <module>fads-pgp-jobmonitor-api</module>
        <module>fads-web</module>
    </modules>

</project>
