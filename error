	@RequestMapping(method = RequestMethod.GET, value="/caseDetail/{id}/{caseType}",headers="Accept=application/json")
	public @ResponseBody CaseDetailDTO getCaseDetail(@PathVariable("id") int id,@PathVariable("caseType") String caseType) {
		CaseDetailDTO caseDetail = null;
		try {
			if(id>0){
				caseDetail = caseDetailService.findCaseDetail(id);
			} else if(id==0  && caseType!=null){

				 caseDetail= new CaseDetailDTO();
				 IntelligentKey intelligentKey=new IntelligentKey();
				 Collection<LabelValueBean> caseTypes=commonLoadService.findAllCaseTypes();
				 for (LabelValueBean lvBean : caseTypes){
						 if(lvBean.getValue().equalsIgnoreCase(caseType))
						 {
							 intelligentKey.setCaseType(caseType);
							 intelligentKey.setCaseTypeDesc(lvBean.getLabel());
						 }
					 }
				//	 intelligentKey.setCreatedBy(user);
					 intelligentKey.setCreatedDt(DateUtil.getSystemDate());
				//	 intelligentKey.setUpdatedBy(user);
