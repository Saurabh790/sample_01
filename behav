    public String getOperator() {
        return operator;
    }

    public void setOperator(String operator) {
        this.operator = operator;
    }

    public List<DrRangeValuesDTO> getRangeValues() {
    	Comparator<DrRangeValuesDTO> compareByFromTo = Comparator
                .comparing(DrRangeValuesDTO::getFrom)
                .thenComparing(DrRangeValuesDTO::getTo);
    	Collections.sort(rangeValues, compareByFromTo);
        return rangeValues;
    }

    public void setRangeValues(List<DrRangeValuesDTO> rangeValues) {
        this.rangeValues = rangeValues;
    }

    public List<DrCodeValueDTO> getSelectedValues() {
        if(selectedValues==null){
        	return Collections.emptyList();
        }
        selectedValues.sort((DrCodeValueDTO dcv1, DrCodeValueDTO dcv2)
        		-> String.CASE_INSENSITIVE_ORDER.compare(dcv1.getCode().toUpperCase(), dcv2.getCode().toUpperCase()));
        return selectedValues;
    }

