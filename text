@DataJpaTest
class DataRuleRangesRepositoryTest {

    @Autowired
    private DataRuleRangesRepository dataRuleRangesRepository;

    private static final Logger logit = LoggerFactory.getLogger(DataRuleRangesRepositoryTest.class);

    @Test
    void testGetRangeValues() {
        Integer dataruleId = 988;
        List<PrmDrRangesT> prmDrRangeValuesList = dataRuleRangesRepository.retrieveRangeValues(dataruleId);
        assertEquals(4, prmDrRangeValuesList.size());
        assertEquals(dataruleId, prmDrRangeValuesList.get(0).getId().getDrId());
    }

    @Test
    void deleteRangesTest() throws ParseException {
        Integer dataruleId = 988;
        int deleteCount = dataRuleRangesRepository.deleteRangesByDataRuleId(dataruleId);
        logit.info("Range Values deleted = {}", deleteCount);
        assertEquals(4, deleteCount);
    }

    @Test
    void saveRangesTest() {
        Integer dataruleId = 998;
        Set<PrmDrRangesT> prmDrRanges = new HashSet<>();

        PrmDrRangesT prmDrRangesT1 = new PrmDrRangesT();
        PrmDrRangesTPK prmDrRangesTPK1 = new PrmDrRangesTPK();
        prmDrRangesTPK1.setDrId(dataruleId);
        prmDrRangesTPK1.setSeqNum(1);
        prmDrRangesT1.setId(prmDrRangesTPK1);
        prmDrRangesT1.setDrRangeFrom("E0424");
        prmDrRangesT1.setDrRangeTo("E0430");
        prmDrRanges.add(prmDrRangesT1);

        PrmDrRangesT prmDrRangesT2 = new PrmDrRangesT();
        PrmDrRangesTPK prmDrRangesTPK2 = new PrmDrRangesTPK();
        prmDrRangesTPK2.setDrId(dataruleId);
        prmDrRangesTPK2.setSeqNum(2);
        prmDrRangesT2.setId(prmDrRangesTPK2);
        prmDrRangesT2.setDrRangeFrom("E0431");
        prmDrRangesT2.setDrRangeTo("E0434");
        prmDrRanges.add(prmDrRangesT2);

        PrmDrRangesT prmDrRangesT3 = new PrmDrRangesT();
        PrmDrRangesTPK prmDrRangesTPK3 = new PrmDrRangesTPK();
        prmDrRangesTPK3.setDrId(dataruleId);
        prmDrRangesTPK3.setSeqNum(3);
        prmDrRangesT3.setId(prmDrRangesTPK3);
        prmDrRangesT3.setDrRangeFrom("E0435");
        prmDrRangesT3.setDrRangeTo("E0435");
        prmDrRanges.add(prmDrRangesT3);

        PrmDrRangesT prmDrRangesT4 = new PrmDrRangesT();
        PrmDrRangesTPK prmDrRangesTPK4 = new PrmDrRangesTPK();
        prmDrRangesTPK4.setDrId(dataruleId);
        prmDrRangesTPK4.setSeqNum(4);
        prmDrRangesT4.setId(prmDrRangesTPK4);
        prmDrRangesT4.setDrRangeFrom("E0440");
        prmDrRangesT4.setDrRangeTo("E0440");
        prmDrRanges.add(prmDrRangesT4);

        logit.info("dataRuleRangesRepository.saveAll - prmDrRanges Test");
        dataRuleRangesRepository.saveAll(prmDrRanges);

        PrmDrRangesTPK prmDrRangesTPK = new PrmDrRangesTPK();
        prmDrRangesTPK.setDrId(dataruleId);
        prmDrRangesTPK.setSeqNum(1);

        Optional<PrmDrRangesT> prmDrRangesT = dataRuleRangesRepository.findById(prmDrRangesTPK);
        assertTrue(prmDrRangesT.isPresent());
        assertEquals("E0424", prmDrRangesT.get().getDrRangeFrom());
        assertEquals("E0430", prmDrRangesT.get().getDrRangeTo());
    }
}




