@ExtendWith(MockitoExtension.class)
class DataRulesControllerTest {

    @Mock
    private IDataRuleDataService iDataRuleDataService;

    @Mock
    private SecurityContext securityContext;

    @Mock
    private Authentication authentication;

    @InjectMocks
    private DataRulesController dataRulesController;

    private DataRuleDTO mockDataRuleDTO;
    private AppUser mockAppUser;
    private PaginationResult mockPaginationResult;

    @BeforeEach
    void setUp() {
        mockDataRuleDTO = new DataRuleDTO();
        mockDataRuleDTO.setDataRuleId(1);
        mockDataRuleDTO.setDataRuleName("Test Data Rule");
        mockDataRuleDTO.setDataElementId(100);
        mockDataRuleDTO.setOperator("EQ");
        mockDataRuleDTO.setCreatedBySystemId("testuser");
        mockDataRuleDTO.setModifiedBySystemId("testuser");

        mockAppUser = new AppUser();
        mockAppUser.setUserSystemId("testuser");
        mockAppUser.setUserEmail("test@example.com");

        Role role = new Role();
        role.setId("ROLE_USER");
        role.setRoleName("User");

        List<AccessLevel> accessLevels = new ArrayList<>();
        accessLevels.add(new AccessLevel("1", "STUDY", "Study Module", "A"));
        role.setAllowedAccesses(accessLevels);
        mockAppUser.setRole(role);

        mockPaginationResult = new PaginationResult();
        List<DataRuleDTO> dataList = new ArrayList<>();
        dataList.add(mockDataRuleDTO);
        mockPaginationResult.setDataRulesData(dataList);
        mockPaginationResult.setTotalRecordsCount(1);

        SecurityContextHolder.clearContext();
    }

    @Test
    void testGetDataRuleById_Success() {
        when(iDataRuleDataService.getDataRuleById(1)).thenReturn(mockDataRuleDTO);

        ResponseEntity<?> response = dataRulesController.getDataRuleById(1);

        assertEquals(HttpStatus.OK, response.getStatusCode());
        assertNotNull(response.getBody());
        assertEquals(mockDataRuleDTO, response.getBody());
        verify(iDataRuleDataService, times(1)).getDataRuleById(1);
    }

    @Test
    void testGetDataRuleById_Exception() {
        when(iDataRuleDataService.getDataRuleById(anyInt()))
                .thenThrow(new DataRulesApiException("Data rule not found"));

        ResponseEntity<?> response = dataRulesController.getDataRuleById(999);

        assertEquals(HttpStatus.BAD_REQUEST, response.getStatusCode());
        assertEquals(DataRuleConstants.EXCEPTION_MESSAGE, response.getBody());
    }

    @Test
    void testGetDataRules_Success() {
        ListTableParamsReq listTableParamsReq = new ListTableParamsReq();
        listTableParamsReq.setPageNumber(0);
        listTableParamsReq.setRecordsPerPage(10);
        listTableParamsReq.setSortBy("dataRuleName");
        listTableParamsReq.setSortOrder(0);

        when(iDataRuleDataService.getDataRulesList(any(ListTableParams.class)))
                .thenReturn(mockPaginationResult);

        ResponseEntity<?> response = dataRulesController.getDataRules(listTableParamsReq, "test");

        assertEquals(HttpStatus.OK, response.getStatusCode());
        assertNotNull(response.getBody());
        assertEquals(mockPaginationResult, response.getBody());
        verify(iDataRuleDataService, times(1)).getDataRulesList(any(ListTableParams.class));
    }

    @Test
    void testNewDataRule_Success_AdminAccess() {
        setupSecurityContext();
        when(iDataRuleDataService.getZoneId()).thenReturn(ZoneId.systemDefault());
        when(iDataRuleDataService.addDataRule(any(DataRuleDTO.class))).thenReturn(mockDataRuleDTO);

        ResponseEntity<?> response = dataRulesController.newDataRule(mockDataRuleDTO);

        assertEquals(HttpStatus.CREATED, response.getStatusCode());
        assertNotNull(response.getBody());
        assertEquals(mockDataRuleDTO, response.getBody());
        verify(iDataRuleDataService, times(1)).addDataRule(any(DataRuleDTO.class));
    }

    @Test
    void testNewDataRule_Success_BusinessAccess() {
        mockAppUser.getRole().getAllowedAccesses().get(0).setAccess("B");
        setupSecurityContext();
        when(iDataRuleDataService.getZoneId()).thenReturn(ZoneId.systemDefault());
        when(iDataRuleDataService.addDataRule(any(DataRuleDTO.class))).thenReturn(mockDataRuleDTO);

        ResponseEntity<?> response = dataRulesController.newDataRule(mockDataRuleDTO);

        assertEquals(HttpStatus.CREATED, response.getStatusCode());
        assertNotNull(response.getBody());
    }

    @Test
    void testNewDataRule_Exception() {
        setupSecurityContext();
        when(iDataRuleDataService.getZoneId()).thenReturn(ZoneId.systemDefault());
        when(iDataRuleDataService.addDataRule(any(DataRuleDTO.class)))
                .thenThrow(new DataRulesApiException("Error creating data rule"));

        ResponseEntity<?> response = dataRulesController.newDataRule(mockDataRuleDTO);

        assertEquals(HttpStatus.BAD_REQUEST, response.getStatusCode());
        assertEquals(DataRuleConstants.EXCEPTION_MESSAGE, response.getBody());
    }

    @Test
    void testUpdateDataRuleById_Success_AdminAccess() {
        setupSecurityContext();
        when(iDataRuleDataService.getZoneId()).thenReturn(ZoneId.systemDefault());
        when(iDataRuleDataService.updateDataRule(eq(1), any(DataRuleDTO.class)))
                .thenReturn("Data rule updated successfully");

        ResponseEntity<String> response = dataRulesController.updateDataRuleById(1, mockDataRuleDTO);

        assertEquals(HttpStatus.OK, response.getStatusCode());
        assertEquals("Data rule updated successfully", response.getBody());
        verify(iDataRuleDataService, times(1)).updateDataRule(eq(1), any(DataRuleDTO.class));
    }

    @Test
    void testUpdateDataRuleById_Success_BusinessAccess_Owner() {
        mockAppUser.getRole().getAllowedAccesses().get(0).setAccess("B");
        mockDataRuleDTO.setCreatedBySystemId("testuser");
        setupSecurityContext();

        when(iDataRuleDataService.getZoneId()).thenReturn(ZoneId.systemDefault());
        when(iDataRuleDataService.updateDataRule(eq(1), any(DataRuleDTO.class)))
                .thenReturn("Data rule updated successfully");

        ResponseEntity<String> response = dataRulesController.updateDataRuleById(1, mockDataRuleDTO);

        assertEquals(HttpStatus.OK, response.getStatusCode());
        assertEquals("Data rule updated successfully", response.getBody());
    }

    @Test
    void testUpdateDataRuleById_Exception() {
        setupSecurityContext();
        when(iDataRuleDataService.getZoneId()).thenReturn(ZoneId.systemDefault());
        when(iDataRuleDataService.updateDataRule(anyInt(), any(DataRuleDTO.class)))
                .thenThrow(new DataRulesApiException("Error updating data rule"));

        ResponseEntity<String> response = dataRulesController.updateDataRuleById(1, mockDataRuleDTO);

        assertEquals(HttpStatus.BAD_REQUEST, response.getStatusCode());
        assertEquals(DataRuleConstants.EXCEPTION_MESSAGE, response.getBody());
    }

    @Test
    void testDeleteDataRuleById_Success() {
        List<String> deleteMessages = new ArrayList<>();
        deleteMessages.add("Data rule deleted successfully");
        when(iDataRuleDataService.deleteDataRule(1)).thenReturn(deleteMessages);

        ResponseEntity<?> response = dataRulesController.deleteDataRuleById(1);

        assertEquals(HttpStatus.OK, response.getStatusCode());
        assertNotNull(response.getBody());
        assertEquals(deleteMessages, response.getBody());
        verify(iDataRuleDataService, times(1)).deleteDataRule(1);
    }

    @Test
    void testDeleteDataRuleById_Exception() {
        when(iDataRuleDataService.deleteDataRule(anyInt()))
                .thenThrow(new DataRulesApiException("Error deleting data rule"));

        ResponseEntity<?> response = dataRulesController.deleteDataRuleById(1);

        assertEquals(HttpStatus.BAD_REQUEST, response.getStatusCode());
        assertEquals(DataRuleConstants.EXCEPTION_MESSAGE, response.getBody());
    }

    @Test
    void testGetMyDataRules_Success() {
        setupSecurityContext();
        ListTableParams listTableParams = new ListTableParams();
        listTableParams.setPageNumber(0);
        listTableParams.setRecordsPerPage(10);

        when(iDataRuleDataService.getDataRulesList(any(ListTableParams.class)))
                .thenReturn(mockPaginationResult);

        ResponseEntity<?> response = dataRulesController.getMyDataRules(listTableParams);

        assertEquals(HttpStatus.OK, response.getStatusCode());
        assertNotNull(response.getBody());
        assertEquals(mockPaginationResult, response.getBody());
        verify(iDataRuleDataService, times(1)).getDataRulesList(any(ListTableParams.class));

        assertNotNull(listTableParams.getSearchBy());
        assertEquals(true, listTableParams.getSearchBy().contains(DataRuleConstants.USER_SYSTEM_ID));
        assertEquals(true, listTableParams.getSearchInput().contains("testuser"));
    }

    @Test
    void testGetMyDataRules_Success_WithExistingSearchCriteria() {
        setupSecurityContext();
        ListTableParams listTableParams = new ListTableParams();
        listTableParams.setPageNumber(0);
        listTableParams.setRecordsPerPage(10);

        List<String> searchBy = new ArrayList<>();
        searchBy.add("dataRuleName");
        listTableParams.setSearchBy(searchBy);

        List<String> searchInput = new ArrayList<>();
        searchInput.add("test");
        listTableParams.setSearchInput(searchInput);

        when(iDataRuleDataService.getDataRulesList(any(ListTableParams.class)))
                .thenReturn(mockPaginationResult);

        ResponseEntity<?> response = dataRulesController.getMyDataRules(listTableParams);

        assertEquals(HttpStatus.OK, response.getStatusCode());
        assertNotNull(response.getBody());
        assertEquals(2, listTableParams.getSearchBy().size());
        assertEquals(true, listTableParams.getSearchBy().contains(DataRuleConstants.USER_SYSTEM_ID));
        assertEquals(true, listTableParams.getSearchInput().contains("testuser"));
    }

    @Test
    void testGetMyDataRules_Exception() {
        setupSecurityContext();
        ListTableParams listTableParams = new ListTableParams();

        when(iDataRuleDataService.getDataRulesList(any(ListTableParams.class)))
                .thenThrow(new DataRulesApiException("Error fetching my data rules"));

        ResponseEntity<?> response = dataRulesController.getMyDataRules(listTableParams);

        assertEquals(HttpStatus.BAD_REQUEST, response.getStatusCode());
        assertEquals(DataRuleConstants.EXCEPTION_MESSAGE, response.getBody());
    }

    @Test
    void testGetDataRules_NullSearchInput() {
        ListTableParamsReq listTableParamsReq = new ListTableParamsReq();
        listTableParamsReq.setPageNumber(0);
        listTableParamsReq.setRecordsPerPage(10);

        when(iDataRuleDataService.getDataRulesList(any(ListTableParams.class)))
                .thenReturn(mockPaginationResult);

        ResponseEntity<?> response = dataRulesController.getDataRules(listTableParamsReq, null);

        assertEquals(HttpStatus.OK, response.getStatusCode());
        assertNotNull(response.getBody());
    }

    @Test
    void testGetMyDataRules_NullAuthentication() {
        SecurityContextHolder.setContext(securityContext);
        when(securityContext.getAuthentication()).thenReturn(null);

        ListTableParams listTableParams = new ListTableParams();
        when(iDataRuleDataService.getDataRulesList(any(ListTableParams.class)))
                .thenReturn(mockPaginationResult);

        ResponseEntity<?> response = dataRulesController.getMyDataRules(listTableParams);

        assertEquals(HttpStatus.OK, response.getStatusCode());
    }

    private void setupSecurityContext() {
        SecurityContextHolder.setContext(securityContext);
        when(securityContext.getAuthentication()).thenReturn(authentication);
        when(authentication.getPrincipal()).thenReturn(mockAppUser);
    }
}



